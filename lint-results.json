e 'text-body' is not a Tailwind CSS class","line":154,"column":33,"messageId":"issue:unknown-classname","endLine":154,"endColumn":42,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-body"},"fix":{"range":[5842,5864],"text":"text-primary"},"desc":"Remove unknown classname 'text-body'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-body' is not a Tailwind CSS class","line":159,"column":35,"messageId":"issue:unknown-classname","endLine":159,"endColumn":44,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-body"},"fix":{"range":[6011,6020],"text":""},"desc":"Remove unknown classname 'text-body'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":160,"column":38,"messageId":"issue:unknown-classname","endLine":160,"endColumn":48,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[6060,6070],"text":""},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-body' is not a Tailwind CSS class","line":162,"column":35,"messageId":"issue:unknown-classname","endLine":162,"endColumn":44,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-body"},"fix":{"range":[6171,6180],"text":""},"desc":"Remove unknown classname 'text-body'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":163,"column":38,"messageId":"issue:unknown-classname","endLine":163,"endColumn":48,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[6220,6230],"text":""},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":165,"column":35,"messageId":"issue:unknown-classname","endLine":165,"endColumn":45,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[6358,6376],"text":"text-xs"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":171,"column":29,"messageId":"fix:sort","endLine":171,"endColumn":33,"fix":{"range":[6553,6589],"text":"mt-4 flex flex-col gap-4 md:flex-row"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":171,"column":34,"messageId":"fix:sort","endLine":171,"endColumn":42},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":171,"column":43,"messageId":"fix:sort","endLine":171,"endColumn":54},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":171,"column":61,"messageId":"fix:sort","endLine":171,"endColumn":65},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":190,"column":25,"messageId":"issue:unknown-classname","endLine":190,"endColumn":35,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[7162,7172],"text":""},"desc":"Remove unknown classname 'text-muted'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":43,"fixableErrorCount":0,"fixableWarningCount":9,"source":"import React, { useState } from 'react';\nimport { useVenues } from '../../hooks/useVenues';\nimport { checkVenueDependencies, type Venue } from '../../services/venueService';\nimport { AppCard } from '../../components/common/AppCard';\nimport { Button } from '../../components/ui/Button/Button';\nimport { Spinner } from '../../components/ui/Spinner/Spinner';\nimport { useDialog } from '../../contexts/DialogContext';\n\nexport default function VenuesView() {\n  const dialog = useDialog();\n  const { venues, isLoading, addVenue, editVenue, removeVenue } = useVenues();\n  const [isAdding, setIsAdding] = useState(false);\n  const [editingId, setEditingId] = useState<string | null>(null);\n  \n  const [name, setName] = useState('');\n  const [rowCountsStr, setRowCountsStr] = useState('');\n  const [address, setAddress] = useState('');\n  const [isOpenSeating, setIsOpenSeating] = useState(false);\n\n  const handleEdit = (v: Venue) => {\n    setEditingId(v.id);\n    setName(v.name);\n    setRowCountsStr(v.rowCounts ? v.rowCounts.join(', ') : '');\n    setAddress(v.address || '');\n    setIsOpenSeating(v.isOpenSeating || false);\n    setIsAdding(true);\n  };\n\n  const resetForm = () => {\n    setName('');\n    setRowCountsStr('');\n    setAddress('');\n    setIsOpenSeating(false);\n    setEditingId(null);\n    setIsAdding(false);\n  };\n\n  const handleSave = async (e: React.FormEvent) => {\n    e.preventDefault();\n    const rowCounts = isOpenSeating ? [] : rowCountsStr.split(',').map(s => parseInt(s.trim())).filter(n => !isNaN(n));\n    \n    try {\n      if (editingId) {\n        await editVenue(editingId, { name, rowCounts, address, isOpenSeating });\n      } else {\n        await addVenue({ name, rowCounts, address, isOpenSeating });\n      }\n      resetForm();\n    } catch {\n      await dialog.showMessage({\n        title: 'Could Not Save Venue',\n        message: 'Error saving venue',\n        variant: 'danger',\n      });\n    }\n  };\n\n  const handleDelete = async (venue: Venue) => {\n    const isLinked = await checkVenueDependencies(venue.id);\n    if (isLinked) {\n      await dialog.showMessage({\n        title: 'Delete Prevented',\n        message: 'This venue is currently linked to scheduled events and cannot be deleted.',\n        variant: 'danger',\n      });\n      return;\n    }\n\n    const shouldDelete = await dialog.confirm({\n      title: 'Delete Venue',\n      message: `Delete ${venue.name}?`,\n      confirmLabel: 'Delete',\n      variant: 'danger',\n    });\n    if (!shouldDelete) return;\n\n    await removeVenue(venue.id);\n  };\n\n  if (isLoading && venues.length === 0) return (\n    <div className=\"container text-center pt-8\">\n      <Spinner size=\"small\" /> Loading venues...\n    </div>\n  );\n\n  return (\n    <div className=\"flex-col gap-8 py-8\">\n       <div className=\"flex flex-col md:flex-row justify-between items-center\">\n        <h1 className=\"text-display m-0\">Venue Templates</h1>\n        {!isAdding && (\n          <Button onClick={() => setIsAdding(true)} variant=\"primary\">+ New Venue</Button>\n        )}\n      </div>\n\n      {isAdding && (\n        <AppCard title={editingId ? 'Edit Venue' : 'Create New Venue'}>\n          <form onSubmit={handleSave} className=\"flex-col gap-4\">\n            <div className=\"flex-col gap-1\">\n              <label className=\"text-label\">Venue Name</label>\n              <input \n                value={name} onChange={(e) => setName(e.target.value)} required\n                placeholder=\"e.g. Main Sanctuary\"\n                className=\"card w-full px-3 h-11\"\n              />\n            </div>\n            <div className=\"flex-col gap-1\">\n              <label className=\"text-label\">Address</label>\n              <input \n                value={address} onChange={(e) => setAddress(e.target.value)}\n                placeholder=\"e.g. 123 Main St, City, State\"\n                className=\"card w-full px-3 h-11\"\n              />\n            </div>\n            <div className=\"flex-row gap-1 items-center\">\n              <input \n                type=\"checkbox\"\n                id=\"isOpenSeating\"\n                checked={isOpenSeating} onChange={(e) => setIsOpenSeating(e.target.checked)}\n              />\n              <label htmlFor=\"isOpenSeating\" className=\"text-label m-0\">Open Seating (No assigned seats)</label>\n            </div>\n            {!isOpenSeating && (\n              <div className=\"flex-col gap-1\">\n                <label className=\"text-label\">Row Capacities (Comma separated)</label>\n                <input \n                  value={rowCountsStr} onChange={(e) => setRowCountsStr(e.target.value)} required\n                  placeholder=\"e.g. 12, 15, 18, 20\"\n                  className=\"card w-full px-3 h-11\"\n                />\n                <p className=\"text-muted text-sm\">Enter the number of seats for each row, starting from the front.</p>\n              </div>\n            )}\n            <div className=\"flex flex-col md:flex-row justify-end gap-4\">\n              <Button variant=\"ghost\" onClick={resetForm}>Cancel</Button>\n              <Button type=\"submit\" variant=\"primary\">Save Template</Button>\n            </div>\n          </form>\n        </AppCard>\n      )}\n\n      <div className=\"grid grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-6\">\n        {venues.map(v => (\n          <AppCard key={v.id} title={v.name} className=\"h-full\">\n            <div className=\"flex-col gap-1 flex-1\">\n              {v.address && (\n                <div className=\"text-body\">\n                  <span className=\"text-muted\">Address:</span>{' '}\n                  <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(v.address)}`} target=\"_blank\" rel=\"noopener noreferrer\" onClick={(e) => e.stopPropagation()}>\n                    {v.address}\n                  </a>\n                </div>\n              )}\n              {v.isOpenSeating ? (\n                <div className=\"text-body text-primary\">\n                  <strong>Open Seating</strong>\n                </div>\n              ) : (\n                <>\n                  <div className=\"text-body\">\n                    <span className=\"text-muted\">Rows:</span> {v.rowCounts?.length || 0}\n                  </div>\n                  <div className=\"text-body\">\n                    <span className=\"text-muted\">Total Seats:</span> {v.rowCounts?.reduce((a, b) => a + b, 0) || 0}\n                  </div>\n                  <div className=\"text-muted text-xs\">\n                    Layout: {v.rowCounts?.join(' | ') || 'None'}\n                  </div>\n                </>\n              )}\n            </div>\n            <div className=\"flex flex-col md:flex-row gap-4 mt-4\">\n              <Button variant=\"ghost\" className=\"flex-1\" onClick={() => handleEdit(v)}>Edit</Button>\n              <Button\n                variant=\"danger\"\n                className=\"flex-1\"\n                onClick={(event) => {\n                  event.stopPropagation();\n                  handleDelete(v);\n                }}\n              >\n                Delete\n              </Button>\n            </div>\n          </AppCard>\n        ))}\n      </div>\n\n      {venues.length === 0 && !isAdding && (\n        <AppCard className=\"p-8 text-center\">\n          <p className=\"text-muted\">No venue templates created yet.</p>\n        </AppCard>\n      )}\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/admin/communications/AutomatedTasksPanel.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":45,"column":42,"messageId":"fix:sort","endLine":45,"endColumn":56,"fix":{"range":[1351,1403],"text":"grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":45,"column":57,"messageId":"fix:sort","endLine":45,"endColumn":71},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":45,"column":72,"messageId":"fix:sort","endLine":45,"endColumn":77},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Cl