able-row"},"fix":{"range":[1642,1762],"text":"flex flex-col md:flex-row relative-row p-4 border-b border-border hover:bg-primary-light/50 cursor-pointer"},"desc":"Remove unknown classname 'clickable-row'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":53,"column":75,"messageId":"fix:sort","endLine":53,"endColumn":78},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":53,"column":79,"messageId":"fix:sort","endLine":53,"endColumn":87},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":53,"column":88,"messageId":"fix:sort","endLine":53,"endColumn":101},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":53,"column":128,"messageId":"fix:sort","endLine":53,"endColumn":142},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'event-list-details' is not a Tailwind CSS class","line":65,"column":27,"messageId":"issue:unknown-classname","endLine":65,"endColumn":45,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"event-list-details"},"fix":{"range":[2127,2165],"text":"flex flex-col gap-4"},"desc":"Remove unknown classname 'event-list-details'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'event-list-header' is not a Tailwind CSS class","line":66,"column":29,"messageId":"issue:unknown-classname","endLine":66,"endColumn":46,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"event-list-header"},"fix":{"range":[2196,2237],"text":"flex items-center gap-1"},"desc":"Remove unknown classname 'event-list-header'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":67,"column":58,"messageId":"fix:sort","endLine":67,"endColumn":62,"fix":{"range":[2271,2366],"text":"