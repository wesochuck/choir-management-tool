ssage":"Invalid Tailwind CSS classnames order","line":169,"column":41,"messageId":"fix:sort","endLine":169,"endColumn":44},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":169,"column":45,"messageId":"fix:sort","endLine":169,"endColumn":51},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":169,"column":52,"messageId":"fix:sort","endLine":169,"endColumn":74},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":177,"column":22,"messageId":"issue:unknown-classname","endLine":177,"endColumn":25,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[6795,6843],"text":"btn-primary !h-9 min-h-auto px-4 text-[13px]"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-primary' is not a Tailwind CSS class","line":177,"column":26,"messageId":"issue:unknown-classname","endLine":177,"endColumn":37,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-primary"},"fix":{"range":[6795,6843],"text":"btn !h-9 min-h-auto px-4 text-[13px]"},"desc":"Remove unknown classname 'btn-primary'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":183,"column":26,"messageId":"fix:sort","endLine":183,"endColumn":33,"fix":{"range":[6955,6994],"text":"text-muted pl-[var(--space-md)] text-xs"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":183,"column":34,"messageId":"fix:sort","endLine":183,"endColumn":44},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":183,"column":34,"messageId":"issue:unknown-classname","endLine":183,"endColumn":44,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[6955,6994],"text":"text-xs pl-[var(--space-md)]"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":183,"column":45,"messageId":"fix:sort","endLine":183,"endColumn":65}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":95,"fixableErrorCount":0,"fixableWarningCount":17,"source":"import React, { useState, useMemo, useRef, useEffect } from 'react';\nimport type { MusicPiece } from '../../types/musicLibrary';\nimport type { SetListItem } from '../../services/eventService';\nimport { createSetListItemFromCustomInput, createSetListItemFromMusicPiece, filterMusicLibrarySuggestions } from '../../lib/setList/setListItems';\n\ninterface SetListInlineCreatorProps {\n  library: MusicPiece[];\n  disabled?: boolean;\n  onAddItem: (item: SetListItem) => void;\n  onCreateNewPiece?: (title: string) => void;\n}\n\nexport const SetListInlineCreator: React.FC<SetListInlineCreatorProps> = ({\n  library,\n  disabled = false,\n  onAddItem,\n  onCreateNewPiece\n}) => {\n  const [type, setType] = useState<'song' | 'intermission'>('song');\n  const [query, setQuery] = useState('');\n  const [duration, setDuration] = useState('');\n  const [showSuggestions, setShowSuggestions] = useState(false);\n  const containerRef = useRef<HTMLDivElement>(null);\n\n  const filteredLibrary = useMemo(() => {\n    if (type === 'intermission') return [];\n    return filterMusicLibrarySuggestions(library, query);\n  }, [library, query, type]);\n\n  useEffect(() => {\n    const handleClickOutside = (event: MouseEvent) => {\n      if (containerRef.current && !containerRef.current.contains(event.target as Node)) {\n        setShowSuggestions(false);\n      }\n    };\n    document.addEventListener('mousedown', handleClickOutside);\n    return () => document.removeEventListener('mousedown', handleClickOutside);\n  }, []);\n\n  const handleAddItem = (piece?: MusicPiece) => {\n    try {\n      if (piece) {\n        onAddItem(createSetListItemFromMusicPiece(piece));\n        setQuery('');\n        setDuration('');\n        setShowSuggestions(false);\n      } else {\n        if (!query.trim()) return;\n        if (type === 'song' && onCreateNewPiece) {\n          onCreateNewPiece(query.trim());\n          setQuery('');\n          setDuration('');\n          setShowSuggestions(false);\n        } else {\n          onAddItem(createSetListItemFromCustomInput({\n            title: query.trim(),\n            type,\n            duration: duration.trim() || undefined\n          }));\n          setQuery('');\n          setDuration('');\n          setShowSuggestions(false);\n        }\n      }\n    } catch (err) {\n      // Logic errors (like invalid duration) should be handled by the caller or UI\n      console.error(err);\n    }\n  };\n\n  const onKeyDown = (e: React.KeyboardEvent) => {\n    if (e.key === 'Enter') {\n      e.preventDefault();\n      handleAddItem();\n    } else if (e.key === 'Escape') {\n      setShowSuggestions(false);\n    }\n  };\n\n  return (\n    <div ref={containerRef} className=\"flex-col gap-[var(--space-xs)] relative\">\n      <div className=\"flex-row card p-[var(--space-sm)_var(--space-md)] gap-[var(--space-md)] items-center bg-[var(--bg-card-hover)] border border-dashed border-[var(--border)]\">\n        <div className=\"flex-row gap-1 bg-[var(--surface)] p-[2px] rounded-[var(--radius-sm)] border border-[var(--border)]\">\n          <button\n            type=\"button\"\n            className={`btn btn-sm sl-type-btn ${type === 'song' ? 'btn-primary' : 'btn-ghost'}`}\n            onClick={() => setType('song')}\n            disabled={disabled}\n          >\n            🎼 Song\n          </button>\n          <button\n            type=\"button\"\n            className={`btn btn-sm sl-type-btn ${type === 'intermission' ? 'btn-primary' : 'btn-ghost'}`}\n            onClick={() => setType('intermission')}\n            disabled={disabled}\n          >\n            ⏸️ Intermission\n          </button>\n        </div>\n\n        <div className=\"flex-1 relative flex items-center\">\n          <input\n            type=\"text\"\n            placeholder={type === 'song' ? \"Search music library...\" : \"Intermission title...\"}\n            value={query}\n            onChange={(e) => {\n              setQuery(e.target.value);\n              setShowSuggestions(true);\n            }}\n            onFocus={() => setShowSuggestions(true)}\n            onKeyDown={onKeyDown}\n            disabled={disabled}\n            className=\"card w-full px-[36px_12px] h-9 border border-[var(--border)] text-[14px]\"\n          />\n          <svg \n            viewBox=\"0 0 24 24\" \n            fill=\"none\" \n            stroke=\"currentColor\" \n            strokeWidth=\"2.5\" \n            strokeLinecap=\"round\" \n            strokeLinejoin=\"round\" \n            className=\"absolute right-3 w-4 h-4 text-[var(--text-muted)] pointer-events-none\"\n          >\n            <circle cx=\"11\" cy=\"11\" r=\"8\"></circle>\n            <line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"></line>\n          </svg>\n \n          {showSuggestions && query.trim().length > 0 && (\n            <div className=\"card shadow-md absolute top-full left-0 right-0 z-[100] mt-1 max-h-[300px] overflow-y-auto p-1 bg-[var(--surface)] border border-[var(--border)] rounded-[var(--radius-md)]\">\n              {filteredLibrary.map(p => (\n                <button\n                  key={p.id}\n                  type=\"button\"\n                  onClick={() => handleAddItem(p)}\n                  className=\"btn btn-ghost w-full text-left flex flex-col items-start p-[8px_12px] rounded-[var(--radius-sm)] gap-[2px] min-h-auto\"\n                >\n                  <span className=\"font-semibold text-[14px]\">{p.title}</span>\n                  {p.composer && <span className=\"text-[12px] opacity-70\">by {p.composer}</span>}\n                </button>\n              ))}\n              \n              <button\n                type=\"button\"\n                onClick={() => handleAddItem()}\n                className=\"btn btn-ghost w-full text-left flex flex-row items-center p-[8px_12px] rounded-[var(--radius-sm)] gap-1 text-[var(--primary-deep)] font-semibold text-[14px] min-h-auto\"\n                // @allow-inline-style - conditional border when library has results\n                style={{ \n                  borderTop: filteredLibrary.length > 0 ? '1px solid var(--border)' : 'none'\n                }}\n              >\n                <span>\"{query.trim()}\"</span>\n                <span className=\"font-normal opacity-70 text-[13px]\">\n                  ({type === 'song' ? 'create new' : 'create new intermission'})\n                </span>\n              </button>\n            </div>\n          )}\n        </div>\n \n        <div className=\"w-[100px]\">\n          <input\n            type=\"text\"\n            placeholder=\"Duration\"\n            value={duration}\n            onChange={(e) => setDuration(e.target.value)}\n            onKeyDown={onKeyDown}\n            disabled={disabled}\n            className=\"card w-full px-3 h-9 border border-[var(--border)] text-[14px]\"\n          />\n        </div>\n \n        <button\n          type=\"button\"\n          onClick={() => handleAddItem()}\n          disabled={disabled || !query.trim()}\n          className=\"btn btn-primary !h-9 min-h-auto px-4 text-[13px]\"\n        >\n          + Add\n        </button>\n      </div>\n      {type === 'song' && (\n        <span className=\"text-xs text-muted pl-[var(--space-md)]\">\n          Tip: Select the \"(create new)\" option or press Enter to add a new piece to the music library.\n        </span>\n      )}\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-to