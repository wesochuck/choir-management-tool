9,"messageId":"fix:sort","endLine":93,"endColumn":132},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":109,"column":27,"messageId":"fix:sort","endLine":109,"endColumn":31,"fix":{"range":[3332,3375],"text":"mt-auto flex items-center justify-end gap-4"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":109,"column":32,"messageId":"fix:sort","endLine":109,"endColumn":44},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":109,"column":45,"messageId":"fix:sort","endLine":109,"endColumn":56},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":109,"column":57,"messageId":"fix:sort","endLine":109,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":109,"column":63,"messageId":"fix:sort","endLine":109,"endColumn":70}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":18,"fixableErrorCount":0,"fixableWarningCount":3,"source":"import React, { useEffect, useId, useRef } from 'react';\n\ninterface BaseModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  title: string;\n  children: React.ReactNode;\n  footer?: React.ReactNode;\n  maxWidth?: string;\n  minHeight?: string;\n}\n\nexport const BaseModal: React.FC<BaseModalProps> = ({ \n  isOpen, onClose, title, children, footer, maxWidth = '500px', minHeight\n}) => {\n  const titleId = useId();\n  const modalRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    if (!isOpen) return;\n\n    const handleKeyDown = (event: KeyboardEvent) => {\n      if (event.key === 'Escape') {\n        event.preventDefault();\n        onClose();\n      } else if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {\n        if (modalRef.current) {\n          // 1. Try to find the primary submit button in the modal\n          const submitButton = modalRef.current.querySelector<HTMLButtonElement>(\n            'button[type=\"submit\"]:not([disabled])'\n          );\n          if (submitButton) {\n            event.preventDefault();\n            submitButton.click();\n            return;\n          }\n\n          // 2. Try to find any other primary action button\n          const primaryButton = modalRef.current.querySelector<HTMLButtonElement>(\n            '.btn-primary:not([disabled]), .btn-danger:not([disabled])'\n          );\n          if (primaryButton) {\n            event.preventDefault();\n            primaryButton.click();\n            return;\n          }\n\n          // 3. Fallback: submit any form within the modal\n          const form = modalRef.current.querySelector<HTMLFormElement>('form');\n          if (form) {\n            event.preventDefault();\n            if (typeof form.requestSubmit === 'function') {\n              form.requestSubmit();\n            } else {\n              form.submit();\n            }\n          }\n        }\n      }\n    };\n\n    document.addEventListener('keydown', handleKeyDown);\n    \n    return () => {\n      document.removeEventListener('keydown', handleKeyDown);\n    };\n  }, [isOpen, onClose]);\n\n  // Auto-focus the first visible focusable element only when the modal opens\n  useEffect(() => {\n    if (!isOpen) return;\n\n    const focusTimer = setTimeout(() => {\n      if (modalRef.current) {\n        const firstFocusable = modalRef.current.querySelector<HTMLElement>(\n          'input:not([disabled]):not([type=hidden]), select:not([disabled]), textarea:not([disabled]), [tabindex=\"0\"]'\n        );\n        firstFocusable?.focus();\n      }\n    }, 50);\n\n    return () => {\n      clearTimeout(focusTimer);\n    };\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  return (\n    <div className=\"fixed inset-0 bg-bg flex items-center justify-center z-[1000] p-4\" role=\"presentation\">\n      <div\n        ref={modalRef}\n        className=\"card flex-col w-full max-h-[90vh] overflow-y-auto gap-6 shadow-md bg-surface rounded-lg p-6 border border-border\"\n        role=\"dialog\"\n        aria-modal=\"true\"\n        aria-labelledby={titleId}\n        // @allow-inline-style - dynamic maxWidth/minHeight from props\n        style={{ maxWidth, minHeight }}\n      >\n        <div className=\"flex items-center\">\n          <h2 id={titleId} className=\"m-0\">{title}</h2>\n        </div>\n\n        <div className=\"flex flex-col gap-4\">\n          {children}\n        </div>\n\n        {footer && (\n          <div className=\"flex items-center justify-end gap-4 mt-auto\">\n            {footer}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/common/MarkdownEditor.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'markdown-editor-wrapper' is not a Tailwind CSS class","line":101,"column":22,"messageId":"issue:unknown-classname","endLine":101,"endColumn":45,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"markdown-editor-wrapper"},"fix":{"range":[2543,2570],"text":"`${"},"desc":"Remove unknown classname 'markdown-editor-wrapper'"}]}],"suppressedMessages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: 'instanceRef', 'minHeight', 'placeholder', and 'value'. Either include them or remove the dependency array.","line":84,"column":6,"endLine":84,"endColumn":8,"suggestions":[{"desc":"Update the dependencies array to be: [instanceRef, minHeight, placeholder, value]","fix":{"range":[2075,2077],"text":"[instanceRef, minHeight, placeholder, value]"}}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { useEffect, useRef } from 'react';\nimport EasyMDE from 'easymde';\nimport 'easymde/dist/easymde.min.css';\n\ninterface MarkdownEditorProps {\n  value: string;\n  onChange: (value: string) => void;\n  instanceRef?: React.MutableRefObject<EasyMDE | null>;\n  minHeight?: string;\n  placeholder?: string;\n  className?: string;\n}\n\nexport function MarkdownEditor({\n  value,\n  onChange,\n  instanceRef,\n  minHeight = '180px',\n  placeholder,\n  className,\n}: MarkdownEditorProps) {\n  const textareaRef = useRef<HTMLTextAreaElement | null>(null);\n  const localInstanceRef = useRef<EasyMDE | null>(null);\n  const onChangeRef = useRef(onChange);\n  const valueRef = useRef(value);\n\n  // Keep refs up to date to avoid stale closures in EasyMDE callback\n  useEffect(() => {\n    onChangeRef.current = onChange;\n    valueRef.current = value;\n  }, [onChange, value]);\n\n  useEffect(() => {\n    if (!textareaRef.current) return;\n\n    const mde = new EasyMDE({\n      element: textareaRef.current,\n      initialValue: value ?? '',\n      spellChecker: false, // Disabling by default for cleaner UI unless requested\n      status: false,\n      minHeight,\n      placeholder,\n      toolbar: [\n        'bold',\n        'italic',\n        'heading',\n        '|',\n        'unordered-list',\n        'ordered-list',\n        '|',\n        'link',\n        'quote',\n        '|',\n        'preview',\n        'guide',\n      ],\n    });\n\n    localInstanceRef.current = mde;\n\n    if (instanceRef) {\n      instanceRef.current = mde;\n    }\n\n    const handleChange = () => {\n      const nextValue = mde.value();\n      // Only trigger onChange if the value has actually changed\n      if (nextValue !== valueRef.current) {\n        onChangeRef.current(nextValue);\n      }\n    };\n\n    mde.codemirror.on('change', handleChange);\n\n    return () => {\n      mde.codemirror.off('change', handleChange);\n      mde.toTextArea();\n      localInstanceRef.current = null;\n      if (instanceRef?.current === mde) {\n        instanceRef.current = null;\n      }\n    };\n    // eslint-disable-next-line react-hooks/exhaustive-deps\n  }, []);\n\n  // Synchronize external value changes (e.g. from templates) into EasyMDE\n  useEffect(() => {\n    const mde = localInstanceRef.current;\n    if (!mde) return;\n\n    const currentValue = mde.value();\n    const nextValue = value ?? '';\n\n    if (currentValue !== nextValue) {\n      // Use value() to set content, which preserves cursor position if possible or handles full replacement\n      mde.value(nextValue);\n    }\n  }, [value]);\n\n  return (\n    <div className={`markdown-editor-wrapper ${className || ''}`}>\n      <textarea ref={textareaRef} className=\"hidden\" />\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/common/PageLayout.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":30,"column":44,"messageId":"fix:sort","endLine":30,"endColumn":54,"fix":{"range":[791,852],"text":"sticky top-0 z-40 border-b border-border bg-surface shadow-sm"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":30,"column":55,"messageId":"fix:sort","endLine":30,"endColumn":63},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":30,"column":64,"messageId":"fix:sort","endLine":30,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":32,"column":25,"messageId":"fix:sort","endLine":32,"endColumn":29,"fix":{"range":[957,1014],"text":"mx-auto flex items-center justify-between gap-6 px-6 py-3"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":32,"column":30,"messageId":"fix:sort","endLine":32,"endColumn":42},{"ruleId":"tail