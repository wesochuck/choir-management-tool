ssage":"Classname 'card' is not a Tailwind CSS class","line":886,"column":26,"messageId":"issue:unknown-classname","endLine":886,"endColumn":30,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[38314,38328],"text":"h-10 px-3"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":895,"column":31,"messageId":"issue:unknown-classname","endLine":895,"endColumn":35,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[38650,38720],"text":"p-2 border-warning-border bg-warning-bg text-warning-text text-sm"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":895,"column":36,"messageId":"fix:sort","endLine":895,"endColumn":39,"fix":{"range":[38650,38720],"text":"card border-warning-border bg-warning-bg text-warning-text p-2 text-sm"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":895,"column":40,"messageId":"fix:sort","endLine":895,"endColumn":61},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'border-warning-border' is not a Tailwind CSS class","line":895,"column":40,"messageId":"issue:unknown-classname","endLine":895,"endColumn":61,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"border-warning-border"},"fix":{"range":[38650,38720],"text":"card p-2 bg-warning-bg text-warning-text text-sm"},"desc":"Remove unknown classname 'border-warning-border'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":895,"column":62,"messageId":"fix:sort","endLine":895,"endColumn":75},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'bg-warning-bg' is not a Tailwind CSS class","line":895,"column":62,"messageId":"issue:unknown-classname","endLine":895,"endColumn":75,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"bg-warning-bg"},"fix":{"range":[38650,38720],"text":"card p-2 border-warning-border text-warning-text text-sm"},"desc":"Remove unknown classname 'bg-warning-bg'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":895,"column":76,"messageId":"fix:sort","endLine":895,"endColumn":93},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-warning-text' is not a Tailwind CSS class","line":895,"column":76,"messageId":"issue:unknown-classname","endLine":895,"endColumn":93,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-warning-text"},"fix":{"range":[38650,38720],"text":"card p-2 border-warning-border bg-warning-bg text-sm"},"desc":"Remove unknown classname 'text-warning-text'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":899,"column":29,"messageId":"issue:unknown-classname","endLine":899,"endColumn":33,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[38890,38971],"text":"max-h-[200px] overflow-y-auto p-2 border border-gray-200 flex flex-col gap-2"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":899,"column":34,"messageId":"fix:sort","endLine":899,"endColumn":47,"fix":{"range":[38890,38971],"text":"card flex max-h-[200px] flex-col gap-2 overflow-y-auto border border-gray-200 p-2"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":899,"column":48,"messageId":"fix:sort","endLine":899,"endColumn":63},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":899,"column":64,"messageId":"fix:sort","endLine":899,"endColumn":67},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":899,"column":68,"messageId":"fix:sort","endLine":899,"endColumn":74},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":899,"column":75,"messageId":"fix:sort","endLine":899,"endColumn":90},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":899,"column":91,"messageId":"fix:sort","endLine":899,"endColumn":95},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":899,"column":96,"messageId":"fix:sort","endLine":899,"endColumn":104},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":899,"column":105,"messageId":"fix:sort","endLine":899,"endColumn":110},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":930,"column":34,"messageId":"fix:sort","endLine":930,"endColumn":47,"fix":{"range":[40390,40411],"text":"text-xs text-gray-500"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":930,"column":48,"messageId":"fix:sort","endLine":930,"endColumn":55},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":939,"column":26,"messageId":"issue:unknown-classname","endLine":939,"endColumn":30,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[40830,40884],"text":"p-2 min-h-[100px] resize-y border border-gray-200"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":939,"column":31,"messageId":"fix:sort","endLine":939,"endColumn":34,"fix":{"range":[40830,40884],"text":"card min-h-[100px] resize-y border border-gray-200 p-2"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":939,"column":35,"messageId":"fix:sort","endLine":939,"endColumn":48},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":939,"column":49,"messageId":"fix:sort","endLine":939,"endColumn":57},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":939,"column":58,"messageId":"fix:sort","endLine":939,"endColumn":64},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":939,"column":65,"messageId":"fix:sort","endLine":939,"endColumn":80},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":945,"column":34,"messageId":"fix:sort","endLine":945,"endColumn":42,"fix":{"range":[41046,41093],"text":"flex cursor-pointer flex-row items-center gap-2"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":945,"column":43,"messageId":"fix:sort","endLine":945,"endColumn":55},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":945,"column":56,"messageId":"fix:sort","endLine":945,"endColumn":61},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":945,"column":62,"messageId":"fix:sort","endLine":945,"endColumn":76},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":951,"column":30,"messageId":"fix:sort","endLine":951,"endColumn":37,"fix":{"range":[41282,41307],"text":"m-0 text-sm font-semibold"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":951,"column":38,"messageId":"fix:sort","endLine":951,"endColumn":51},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":951,"column":52,"messageId":"fix:sort","endLine":951,"endColumn":55}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":248,"fixableErrorCount":0,"fixableWarningCount":52,"source":"import { useCallback, useEffect, useMemo, useState } from 'react';\nimport { ticketService, type TicketPurchase, type TicketBundle } from '../../services/ticketService';\nimport { pb } from '../../lib/pocketbase';\nimport type { Event } from '../../services/eventService';\nimport { AppCard } from '../../components/common/AppCard';\nimport { useDialog } from '../../contexts/DialogContext';\nimport { fetchChoirTimezone, formatInTimezone } from '../../lib/timezone';\nimport { useDocumentTitle } from '../../hooks/useDocumentTitle';\nimport { Link } from 'react-router-dom';\nimport { getFirstName, getLastName } from '../../lib/stringUtils';\nimport { BaseModal } from '../../components/common/BaseModal';\n\nexport default function TicketingView() {\n  useDocumentTitle('Ticketing');\n  const dialog = useDialog();\n  const [now] = useState(() => Date.now());\n  const [activeTab, setActiveTab] = useState<'willcall' | 'bundles' | 'orders'>('willcall');\n\n  const [events, setEvents] = useState<Event[]>([]);\n  const [showPastAndInactive, setShowPastAndInactive] = useState(false);\n  const [selectedEventId, setSelectedEventId] = useState('');\n  const [purchases, setPurchases] = useState<TicketPurchase[]>([]);\n  const [allPurchases, setAllPurchases] = useState<TicketPurchase[]>([]);\n  const [bundles, setBundles] = useState<TicketBundle[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [searchQuery, setSearchQuery] = useState('');\n  const [timezone, setTimezone] = useState('America/New_York');\n  const [sortBy, setSortBy] = useState<'lastName' | 'firstName' | 'saleDate'>('lastName');\n\n  // Bundle CRUD modal state\n  const [isModalOpen, setIsModalOpen] = useState(false);\n  const [editingBundle, setEditingBundle] = useState<TicketBundle | null>(null);\n  const [title, setTitle] = useState('');\n  const [price, setPrice] = useState(0);\n  const [capacity, setCapacity] = useState(0);\n  const [saleEndDate, setSaleEndDate] = useState('');\n  const [selectedEventIds, setSelectedEventIds] = useState<string[]>([]);\n  const selectedEventIdsSet = useMemo(() => new Set(selectedEventIds), [selectedEventIds]);\n  const [isActive, setIsActive] = useState(false);\n  const [saving, setSaving] = useState(false);\n  const [publicDetails, setPublicDetails] = useState('');\n\n  const reloadData = useCallback(async () => {\n    setLoading(true);\n    try {\n      const [eventsEnabled, purchasesRes, allPurchasesRes, bundlesRes, tz] = await Promise.all([\n        pb.collection('events').getFullList<Event>({\n          filter: 'isTicketingEnabled = true',\n          sort: '-date'\n        }),\n        selectedEventId ? ticketService.getPurchasesForEvent(selectedEventId) : Promise.resolve([]),\n        ticketService.getAllPurchases(),\n        pb.collection('ticketBundles').getFullList<TicketBundle>({\n          sort: '-created',\n          expand: 'events'\n        }),\n        fetchChoirTimezone().catch(() => 'America/New_York')\n      ]);\n\n      const enabledIds = new Set(eventsEnabled.map(e => e.id));\n      const eventIdsWithPurchases = Array.from(new Set(allPurchasesRes.map(p => p.event)));\n      const missingEventIds = eventIdsWithPurchases.filter(id => !enabledIds.has(id));\n\n      let allEvents = [...eventsEnabled];\n\n      if (missingEventIds.length > 0) {\n        const chunks: string[][] = [];\n        for (let i = 0; i < missingEventIds.length; i += 50) {\n          chunks.push(missingEventIds.slice(i, i + 50));\n        }\n\n        const missingEventsPromises = chunks.map(chunk => {\n          const filterStr = chunk.map((_, idx) => `id = {:id_${idx}}`).join(' || ');\n          const placeholders = chunk.reduce((acc, id, idx) => {\n            acc[`id_${idx}`] = id;\n            return acc;\n          }, {} as Record<string, string>);\n          return pb.collection('events').getFullList<Event>({\n            filter: pb.filter(filterStr, placeholders)\n          });\n        });\n\n        const missingEventsResults = await Promise.all(missingEventsPromises);\n        const missingEvents = missingEventsResults.flat();\n        allEvents = [...allEvents, ...missingEvents];\n      }\n\n      allEvents.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());\n      setEvents(allEvents);\n      setAllPurchases(allPurchasesRes);\n      setBundles(bundlesRes);\n      setTimezone(tz);\n\n      if (selectedEventId) {\n        setPurchases(purchasesRes);\n      }\n    } catch (err) {\n      console.error(err);\n    } finally {\n      setLoading(false);\n    }\n  }, [selectedEventId]);\n\n  useEffect(() => {\n    reloadData();\n  }, [reloadData]);\n\n  const visibleEvents = useMemo(() => {\n    const cutoffTime = now - 3 * 60 * 60 * 1000;\n    return events.filter(ev => {\n      if (showPastAndInactive) return true;\n      const isUpcoming = new Date(ev.date).getTime() >= cutoffTime;\n      const isActive = ev.isTicketingEnabled;\n      return isUpcoming && isActive;\n    });\n  }, [events, showPastAndInactive, now]);\n\n  useEffect(() => {\n    if (visibleEvents.length > 0) {\n      const alreadySelected = visibleEvents.some(e => e.id === selectedEventId);\n      if (!alreadySelected) {\n        setSelectedEventId(visibleEvents[0].id);\n      }\n    } else {\n      setSelectedEventId('');\n    }\n  }, [visibleEvents, selectedEventId]);\n\n  const activePurchases = purchases.filter(p => p.status === 'paid');\n  const totalTicketsSold = activePurchases.reduce((acc, p) => acc + p.quantity, 0);\n\n  const selectedEvent = events.find(e => e.id === selectedEventId);\n  const eventCapacity = selectedEvent?.ticketCapacity || 0;\n  const showWarning = eventCapacity > 0 && totalTicketsSold >= (eventCapacity * 0.9);\n\n  const handleRefund = async (purchaseId: string) => {\n    const confirmed = await dialog.confirm({\n      title: 'Refund Ticket',\n      message: 'Are you sure you want to refund this ticket? This will void the ticket on Will Call and issue a refund on Stripe.',\n      confirmLabel: 'Refund',\n      variant: 'danger',\n    });\n    \n    if (!confirmed) return;\n\n    try {\n      dialog.showToast('Processing refund...');\n      await ticketService.adminRefundTicket(purchaseId);\n      dialog.showToast('Refund processed successfully.');\n      reloadData();\n    } catch {\n      await dialog.showMessage({\n        title: 'Refund Failed',\n        message: 'Could not process the refund. Please verify the Stripe Dashboard.',\n        variant: 'danger'\n      });\n    }\n  };\n\n  const sortPurchases = (list: TicketPurchase[]) => {\n    return [...list].sort((a, b) => {\n      if (sortBy === 'lastName') {\n        const lastA = getLastName(a.buyerName).toLowerCase();\n        const lastB = getLastName(b.buyerName).toLowerCase();\n        if (lastA !== lastB) return lastA.localeCompare(lastB);\n        const firstA = getFirstName(a.buyerName).toLowerCase();\n        const firstB = getFirstName(b.buyerName).toLowerCase();\n        return firstA.localeCompare(firstB);\n      }\n      if (sortBy === 'firstName') {\n        const firstA = getFirstName(a.buyerName).toLowerCase();\n        const firstB = getFirstName(b.buyerName).toLowerCase();\n        if (firstA !== firstB) return firstA.localeCompare(firstB);\n        const lastA = getLastName(a.buyerName).toLowerCase();\n        const lastB = getLastName(b.buyerName).toLowerCase();\n        return lastA.localeCompare(lastB);\n      }\n      if (sortBy === 'saleDate') {\n        return new Date(b.created).getTime() - new Date(a.created).getTime();\n      }\n      return 0;\n    });\n  };\n\n  const handleExportCSV = () => {\n    const sortedActive = sortPurchases(activePurchases);\n    if (sortedActive.length === 0) {\n      dialog.showToast('No active purchases to export.');\n      return;\n    }\n    const headers = [\"ID\", \"Buyer Name\", \"Buyer Email\", \"Quantity\", \"Paid\", \"Status\", \"Created\", \"Type\"];\n    const rows = sortedActive.map(p => [\n      p.id,\n      p.buyerName,\n      p.buyerEmail,\n      p.quantity,\n      (p.amountPaidCents / 100).toFixed(2),\n      p.status,\n      p.created,\n      p.bundle ? `Season Pass (${p.expand?.bundle?.title || 'Pass'})` : 'Concert Ticket'\n    ]);\n    const csvContent = \"data:text/csv;charset=utf-8,\" \n      + [headers.join(\",\"), ...rows.map(e => e.map(val => `\"${String(val).replace(/\"/g, '\"\"')}\"`).join(\",\"))].join(\"\\n\");\n    const encodedUri = encodeURI(csvContent);\n    const link = document.createElement(\"a\");\n    link.setAttribute(\"href\", encodedUri);\n    link.setAttribute(\"download\", `will_call_${selectedEventId}.csv`);\n    document.body.appendChild(link);\n    link.click();\n    document.body.removeChild(link);\n  };\n\n  const filteredPurchases = sortPurchases(\n    purchases.filter(p =>\n      p.buyerName.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      p.buyerEmail.toLowerCase().includes(searchQuery.toLowerCase())\n    )\n  );\n\n  // Bundle sold quantity helper\n  const getBundleSoldQty = (bundleId: string, bundleEvents: string[]) => {\n    if (!bundleEvents || bundleEvents.length === 0) return 0;\n    const firstEventId = bundleEvents[0];\n    const matched = allPurchases.filter(\n      p => p.bundle === bundleId && p.event === firstEventId && p.status === 'paid'\n    );\n    return matched.reduce((acc, curr) => acc + curr.quantity, 0);\n  };\n\n  // Grouped bundle orders\n  const bundleOrders = useMemo(() => {\n    const map = new Map<string, {\n      stripeSessionId: string;\n      stripePaymentIntentId: string;\n      buyerName: string;\n      buyerEmail: string;\n      quantity: number;\n      amountPaidCents: number;\n      created: string;\n      status: string;\n      bundleTitle: string;\n      bundleId: string;\n    }>();\n\n    allPurchases.forEach(p => {\n      if (p.bundle) {\n        const key = p.stripeSessionId;\n        if (!map.has(key)) {\n          map.set(key, {\n            stripeSessionId: p.stripeSessionId,\n            stripePaymentIntentId: p.stripePaymentIntentId,\n            buyerName: p.buyerName,\n            buyerEmail: p.buyerEmail,\n            quantity: p.quantity,\n            amountPaidCents: p.amountPaidCents,\n            created: p.created,\n            status: p.status,\n            bundleTitle: p.expand?.bundle?.title || 'Unknown Bundle',\n            bundleId: p.bundle\n          });\n        }\n      }\n    });\n\n    return Array.from(map.values()).sort((a, b) => new Date(b.created).getTime() - new Date(a.created).getTime());\n  }, [allPurchases]);\n\n  // Bundle refund handler\n  const handleRefundBundle = async (paymentIntentId: string) => {\n    const confirmed = await dialog.confirm({\n      title: 'Refund Bundle Purchase',\n      message: 'Are you sure you want to refund this bundle purchase? This will issue a full Stripe refund and void all associated individual tickets on the Will Call lists. This action is permanent and cannot be undone.',\n      confirmLabel: 'Refund Bundle',\n      variant: 'danger',\n    });\n\n    if (!confirmed) return;\n\n    try {\n      dialog.showToast('Processing bundle refund...');\n      await ticketService.adminRefundBundle(paymentIntentId);\n      dialog.showToast('Bundle refunded successfully.');\n      reloadData();\n    } catch {\n      await dialog.showMessage({\n        title: 'Refund Failed',\n        message: 'Could not process the bundle refund. Please verify the Stripe Dashboard.',\n        variant: 'danger'\n      });\n    }\n  };\n\n  // Bundle CRUD handlers\n  const handleOpenCreateModal = () => {\n    setEditingBundle(null);\n    setTitle('');\n    setPrice(0);\n    setCapacity(0);\n    setSaleEndDate('');\n    setSelectedEventIds([]);\n    setIsActive(false);\n    setPublicDetails('');\n    setIsModalOpen(true);\n  };\n\n  const handleOpenEditModal = (bundle: TicketBundle) => {\n    setEditingBundle(bundle);\n    setTitle(bundle.title);\n    setPrice(bundle.priceCents / 100);\n    setCapacity(bundle.capacity);\n    \n    // Format timezone date for datetime-local: YYYY-MM-DDTHH:mm\n    if (bundle.saleEndDate) {\n      const dateObj = new Date(bundle.saleEndDate);\n      const year = dateObj.getFullYear();\n      const month = String(dateObj.getMonth() + 1).padStart(2, '0');\n      const day = String(dateObj.getDate()).padStart(2, '0');\n      const hours = String(dateObj.getHours()).padStart(2, '0');\n      const minutes = String(dateObj.getMinutes()).padStart(2, '0');\n      setSaleEndDate(`${year}-${month}-${day}T${hours}:${minutes}`);\n    } else {\n      setSaleEndDate('');\n    }\n\n    setSelectedEventIds(bundle.events || []);\n    setIsActive(bundle.isActive);\n    setPublicDetails(bundle.publicDetails || '');\n    setIsModalOpen(true);\n  };\n\n  const handleSaveBundle = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!title.trim() || price <= 0 || capacity <= 0 || selectedEventIds.length === 0 || !saleEndDate) {\n      dialog.showToast('Please fill out all required fields and select at least one event.');\n      return;\n    }\n\n    setSaving(true);\n    try {\n      const data = {\n        title: title.trim(),\n        priceCents: Math.round(price * 100),\n        capacity: Number(capacity),\n        events: selectedEventIds,\n        saleEndDate: new Date(saleEndDate).toISOString(),\n        isActive,\n        publicDetails: publicDetails.trim()\n      };\n\n      if (editingBundle) {\n        await pb.collection('ticketBundles').update(editingBundle.id, data);\n        dialog.showToast('Bundle updated successfully.');\n      } else {\n        await pb.collection('ticketBundles').create(data);\n        dialog.showToast('Bundle created successfully.');\n      }\n      setIsModalOpen(false);\n      reloadData();\n    } catch (err: unknown) {\n      console.error(err);\n      dialog.showToast('Failed to save bundle.');\n    } finally {\n      setSaving(false);\n    }\n  };\n\n  const handleDeleteBundle = async (bundleId: string, bundleEvents: string[]) => {\n    const soldQty = getBundleSoldQty(bundleId, bundleEvents);\n    if (soldQty > 0) {\n      await dialog.showMessage({\n        title: 'Delete Prevented',\n        message: 'This bundle has active purchases and cannot be deleted.',\n        variant: 'danger'\n      });\n      return;\n    }\n\n    const confirmed = await dialog.confirm({\n      title: 'Delete Bundle',\n      message: 'Are you sure you want to delete this season ticket bundle? This action cannot be undone.',\n      confirmLabel: 'Delete',\n      variant: 'danger'\n    });\n\n    if (!confirmed) return;\n\n    try {\n      await pb.collection('ticketBundles').delete(bundleId);\n      dialog.showToast('Bundle deleted successfully.');\n      reloadData();\n    } catch (err) {\n      console.error(err);\n      dialog.showToast('Failed to delete bundle.');\n    }\n  };\n\n  // Auto-populate saleEndDate to 11:59 PM of the chronologically first event in creation mode\n  useEffect(() => {\n    if (isModalOpen && !editingBundle && selectedEventIds.length > 0) {\n      const selectedConcerts = events.filter(e => selectedEventIdsSet.has(e.id));\n      if (selectedConcerts.length > 0) {\n        selectedConcerts.sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());\n        const firstEventDate = new Date(selectedConcerts[0].date);\n        const year = firstEventDate.getFullYear();\n        const month = String(firstEventDate.getMonth() + 1).padStart(2, '0');\n        const day = String(firstEventDate.getDate()).padStart(2, '0');\n        setSaleEndDate(`${year}-${month}-${day}T23:59`);\n      }\n    }\n  }, [selectedEventIds, selectedEventIdsSet, isModalOpen, editingBundle, events]);\n\n  const hasPurchases = editingBundle ? getBundleSoldQty(editingBundle.id, editingBundle.events) > 0 : false;\n\n  return (\n    <div className=\"flex flex-col gap-8 py-8\">\n      <div className=\"flex flex-wrap justify-between items-center gap-4 mb-6\">\n        <div>\n          <h1 className=\"text-display m-0\">Ticketing Dashboard</h1>\n          <p className=\"text-gray-500 text-sm\">Manage ticket sales, configure season bundles, and view check-in checklists.</p>\n        </div>\n        <div className=\"flex flex-wrap items-center gap-4\">\n          {activeTab === 'bundles' && (\n            <button onClick={handleOpenCreateModal} className=\"btn btn-primary\">\n              Create New Bundle\n            </button>\n          )}\n          {activeTab === 'willcall' && selectedEventId && (\n            <button onClick={handleExportCSV} className=\"btn btn-primary\">\n              Export Will Call CSV\n            </button>\n          )}\n        </div>\n      </div>\n\n      {/* Tab Controls */}\n      <div className=\"flex flex-row gap-2 border-b border-gray-200 pb-1 mb-1\">\n        <button\n          className={`btn px-4 py-2 font-semibold ${activeTab === 'willcall' ? 'btn-primary' : 'btn-ghost'}`}\n          onClick={() => setActiveTab('willcall')}\n        >\n          Concert Will Call\n        </button>\n        <button\n          className={`btn px-4 py-2 font-semibold ${activeTab === 'bundles' ? 'btn-primary' : 'btn-ghost'}`}\n          onClick={() => setActiveTab('bundles')}\n        >\n          Season Bundles\n        </button>\n        <button\n          className={`btn px-4 py-2 font-semibold ${activeTab === 'orders' ? 'btn-primary' : 'btn-ghost'}`}\n          onClick={() => setActiveTab('orders')}\n        >\n          Bundle Orders\n        </button>\n      </div>\n\n      {activeTab === 'willcall' && (\n        <>\n          <div className=\"card p-4 bg-[rgba(74,124,89,0.05)] border-l-4 border-primary rounded-lg m-0\">\n            <h3 className=\"m-0 mb-1 text-base text-primary-deep flex items-center gap-1.5\">\n              ℹ️ Ticketing Instructions & Links\n            </h3>\n            <p className=\"text-gray-500 text-sm m-0 mb-2 leading-relaxed\">\n              Tickets are enabled on a per-performance basis. Go to the <Link to=\"/admin/events\" className=\"font-semibold underline text-primary-deep\">Events Dashboard</Link>, edit or create a Performance event, click the <strong>Tickets</strong> tab, and toggle <strong>Enable Online Ticket Sales</strong>.\n            </p>\n            <div className=\"flex flex-col gap-1.5 text-sm\">\n              <div>\n                <strong>📢 Storefront URL:</strong>{' '}\n                <a href=\"/tickets\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"underline text-primary\">\n                  {window.location.origin}/tickets\n                </a>\n                <span className=\"text-xs text-gray-500 ml-1.5\">(list of all active ticketed concerts & bundles)</span>\n              </div>\n              {selectedEventId && selectedEvent && (\n                <div>\n                  <strong>🔗 Direct Concert Ticket Link:</strong>{' '}\n                  <a href={`/tickets/${selectedEventId}`} target=\"_blank\" rel=\"noopener noreferrer\" className=\"underline text-primary\">\n                    {window.location.origin}/tickets/{selectedEventId}\n                  </a>\n                  <span className=\"text-xs text-gray-500 ml-1.5\">(direct checkout page for {selectedEvent.title})</span>\n                </div>\n              )}\n            </div>\n          </div>\n\n          <div className=\"card flex flex-wrap gap-4 items-center p-4 bg-neutral-bg\">\n            <div className=\"flex-1 flex flex-col gap-1\">\n              <div className=\"flex flex-row justify-between items-center\">\n                <label className=\"text-sm font-semibold\">Select Performance</label>\n                <label className=\"flex flex-row items-center gap-1.5 text-sm cursor-pointer m-0\">\n                  <input\n                    type=\"checkbox\"\n                    checked={showPastAndInactive}\n                    onChange={e => setShowPastAndInactive(e.target.checked)}\n                    className=\"cursor-pointer\"\n                  />\n                  <span>Include past & inactive performances</span>\n                </label>\n              </div>\n              <select\n                className=\"card w-full h-11 px-3 border border-gray-200\"\n                value={selectedEventId}\n                onChange={e => setSelectedEventId(e.target.value)}\n              >\n                {visibleEvents.map(ev => {\n                  const cutoffTime = now - 3 * 60 * 60 * 1000;\n                  const isPast = new Date(ev.date).getTime() < cutoffTime;\n                  const isInactive = !ev.isTicketingEnabled;\n                  const suffix = isInactive ? ' (Inactive)' : isPast ? ' (Past)' : '';\n                  return (\n                    <option key={ev.id} value={ev.id}>\n                      {ev.title} ({formatInTimezone(ev.date, timezone, { month: 'short', day: 'numeric', year: 'numeric' })}){suffix}\n                    </option>\n                  );\n                })}\n                {visibleEvents.length === 0 && (\n                  <option value=\"\">No ticketing-enabled events</option>\n                )}\n              </select>\n            </div>\n\n            {selectedEvent && (\n              <div className=\"flex flex-row flex-wrap gap-6 px-4\">\n                <div className=\"flex flex-col gap-0.5 min-w-[100px]\">\n                  <span className=\"text-xs text-gray-500\">TICKETS SOLD</span>\n                  <span className=\"text-2xl font-bold\">\n                    {totalTicketsSold} {eventCapacity > 0 ? `/ ${eventCapacity}` : ''}\n                  </span>\n                </div>\n                <div className=\"flex flex-col gap-0.5 min-w-[110px]\">\n                  <span className=\"text-xs text-gray-500\">TICKET SALES</span>\n                  <span className=\"text-2xl font-bold\">\n                    ${(activePurchases.reduce((acc, p) => acc + (p.unitPriceCents * p.quantity), 0) / 100).toFixed(2)}\n                  </span>\n                </div>\n                <div className=\"flex flex-col gap-0.5 min-w-[110px]\">\n                  <span className=\"text-xs text-gray-500\">FEES COLLECTED</span>\n                  <span className=\"text-2xl font-bold text-gray-500\">\n                    ${(activePurchases.reduce((acc, p) => acc + p.feeCents, 0) / 100).toFixed(2)}\n                  </span>\n                </div>\n                <div className=\"flex flex-col gap-0.5 min-w-[110px]\">\n                  <span className=\"text-xs text-gray-500\">TOTAL REVENUE</span>\n                  <span className=\"text-2xl font-bold text-primary\">\n                    ${(activePurchases.reduce((acc, p) => acc + p.amountPaidCents, 0) / 100).toFixed(2)}\n                  </span>\n                </div>\n              </div>\n            )}\n          </div>\n\n          {showWarning && (\n            <div className=\"card p-4 border-warning-border bg-warning-bg text-warning-text\">\n              ⚠️ Warning: Sold tickets ({totalTicketsSold}) have reached or exceeded 90% of capacity ({eventCapacity}).\n            </div>\n          )}\n\n          <AppCard title=\"Will Call Checklist\">\n            <div className=\"flex flex-col gap-4\">\n              <div className=\"flex gap-2 w-full items-center\">\n                <div className=\"flex-1 min-w-[200px] w-full\">\n                  <input\n                    type=\"text\"\n                    placeholder=\"Search buyer name or email...\"\n                    className=\"card w-full h-10 px-3 border border-gray-200\"\n                    value={searchQuery}\n                    onChange={e => setSearchQuery(e.target.value)}\n                  />\n                </div>\n                <div className=\"min-w-[200px]\">\n                  <select\n                    className=\"card w-full h-10 px-3 border border-gray-200 cursor-pointer\"\n                    value={sortBy}\n                    onChange={e => setSortBy(e.target.value as 'lastName' | 'firstName' | 'saleDate')}\n                  >\n                    <option value=\"lastName\">Sort by Last Name</option>\n                    <option value=\"firstName\">Sort by First Name</option>\n                    <option value=\"saleDate\">Sort by Sale Date</option>\n                  </select>\n                </div>\n              </div>\n\n              {loading ? (\n                <p className=\"text-gray-500\">Loading registrations...</p>\n              ) : filteredPurchases.length === 0 ? (\n                <p className=\"text-gray-500 p-8 text-center\">No purchase records found.</p>\n              ) : (\n                <div className=\"overflow-x-auto\">\n                  <table className=\"border-collapse w-full min-w-[600px] text-left\">\n                    <thead>\n                      <tr className=\"border-b-2 border-gray-200 text-gray-500 text-sm\">\n                        <th className=\"p-3 px-2 text-left\">Buyer Name</th>\n                        <th className=\"p-3 px-2 text-left\">Email</th>\n                        <th className=\"p-3 px-2 text-left\">Sale Date</th>\n                        <th className=\"p-3 px-2 text-left\">Qty</th>\n                        <th className=\"p-3 px-2 text-left\">Amount Paid</th>\n                        <th className=\"p-3 px-2 text-left\">Status</th>\n                        <th className=\"p-3 px-2 text-right\">Actions</th>\n                      </tr>\n                    </thead>\n                    <tbody>\n                      {filteredPurchases.map(p => {\n                        const isRefunded = p.status === 'refunded';\n                        return (\n                          <tr \n                            key={p.id} \n                            className=\"border-b border-gray-200 text-sm\" \n                            // @allow-inline-style - isRefunded text color/opacity\n                            style={{ color: isRefunded ? 'var(--text-muted)' : 'inherit', opacity: isRefunded ? 0.6 : 1 }}\n                          >\n                            <td className=\"p-3 px-2 font-semibold\">\n                              {p.buyerName}\n                              {p.expand?.bundle && (\n                                <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-success-bg text-success-text ml-2 align-middle\">\n                                  Season Ticket: {p.expand.bundle.title}\n                                </span>\n                              )}\n                            </td>\n                            <td className=\"p-3 px-2\">{p.buyerEmail}</td>\n                            <td className=\"p-3 px-2\">\n                              {formatInTimezone(p.created, timezone, { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' })}\n                            </td>\n                            <td className=\"p-3 px-2\">{p.quantity}</td>\n                            <td className=\"p-3 px-2\">${(p.amountPaidCents / 100).toFixed(2)}</td>\n                            <td className=\"p-3 px-2\">\n                              <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider ${p.status === 'paid' ? 'bg-success-bg text-success-text' : 'bg-danger-bg text-danger-text'}`}>\n                                {p.status}\n                              </span>\n                            </td>\n                            <td className=\"p-3 px-2 text-right\">\n                              {p.status === 'paid' && (\n                                <button\n                                  onClick={() => {\n                                    if (p.bundle) {\n                                      handleRefundBundle(p.stripePaymentIntentId);\n                                    } else {\n                                      handleRefund(p.id);\n                                    }\n                                  }}\n                                  className=\"btn btn-danger btn-sm\"\n                                >\n                                  Refund\n                                </button>\n                              )}\n                            </td>\n                          </tr>\n                        );\n                      })}\n                    </tbody>\n                  </table>\n                </div>\n              )}\n            </div>\n          </AppCard>\n        </>\n      )}\n\n      {activeTab === 'bundles' && (\n        <AppCard title=\"Season Bundles Configuration\">\n          {loading ? (\n            <p className=\"text-gray-500\">Loading bundles...</p>\n          ) : bundles.length === 0 ? (\n            <p className=\"text-gray-500 p-8 text-center\">No season bundles configured.</p>\n          ) : (\n            <div className=\"overflow-x-auto\">\n              <table className=\"border-collapse w-full text-left\">\n                <thead>\n                  <tr className=\"border-b-2 border-gray-200 text-gray-500 text-sm\">\n                    <th className=\"p-3 px-2 text-left\">Bundle Title</th>\n                    <th className=\"p-3 px-2 text-left\">Price</th>\n                    <th className=\"p-3 px-2 text-left\">Active</th>\n                    <th className=\"p-3 px-2 text-left\">Capacity Sold</th>\n                    <th className=\"p-3 px-2 text-left\">Sale End Date</th>\n                    <th className=\"p-3 px-2 text-left\">Included Events</th>\n                    <th className=\"p-3 px-2 text-right\">Actions</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  {bundles.map(b => {\n                    const sold = getBundleSoldQty(b.id, b.events);\n                    return (\n                      <tr key={b.id} className=\"border-b border-gray-200 text-sm\">\n                        <td className=\"p-3 px-2 font-semibold\">{b.title}</td>\n                        <td className=\"p-3 px-2\">${(b.priceCents / 100).toFixed(2)}</td>\n                        <td className=\"p-3 px-2\">\n                          <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider ${b.isActive ? 'bg-success-bg text-success-text' : 'bg-danger-bg text-danger-text'}`}>\n                            {b.isActive ? 'Active' : 'Inactive'}\n                          </span>\n                        </td>\n                        <td className=\"p-3 px-2\">\n                          <div className=\"flex flex-col gap-1\">\n                            <span>{sold} / {b.capacity} sold</span>\n                            <div className=\"w-[100px] h-1.5 bg-gray-200 rounded overflow-hidden\">\n                              <div \n                                className=\"h-full bg-primary\" \n                                // @allow-inline-style - progress bar width\n                                style={{ width: `${Math.min(100, (sold / b.capacity) * 100)}%` }} \n                              />\n                            </div>\n                          </div>\n                        </td>\n                        <td className=\"p-3 px-2\">\n                          {formatInTimezone(b.saleEndDate, timezone, { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' })}\n                        </td>\n                        <td className=\"p-3 px-2 max-w-[240px]\">\n                          <div className=\"flex flex-wrap gap-1\">\n                            {b.expand?.events?.map(ev => (\n                              <span key={ev.id} className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-primary-light text-primary-deep whitespace-nowrap\">\n                                {ev.title}\n                              </span>\n                            ))}\n                          </div>\n                        </td>\n                        <td className=\"p-3 px-2 text-right whitespace-nowrap\">\n                          <button\n                            onClick={() => handleOpenEditModal(b)}\n                            className=\"btn btn-secondary btn-sm mr-2\"\n                          >\n                            Edit\n                          </button>\n                          <button\n                            onClick={() => handleDeleteBundle(b.id, b.events)}\n                            className=\"btn btn-danger btn-sm\"\n                          >\n                            Delete\n                          </button>\n                        </td>\n                      </tr>\n                    );\n                  })}\n                </tbody>\n              </table>\n            </div>\n          )}\n        </AppCard>\n      )}\n\n      {activeTab === 'orders' && (\n        <AppCard title=\"Season Pass Orders\">\n          {loading ? (\n            <p className=\"text-gray-500\">Loading orders...</p>\n          ) : bundleOrders.length === 0 ? (\n            <p className=\"text-gray-500 p-8 text-center\">No season pass orders found.</p>\n          ) : (\n            <div className=\"overflow-x-auto\">\n              <table className=\"border-collapse w-full text-left\">\n                <thead>\n                  <tr className=\"border-b-2 border-gray-200 text-gray-500 text-sm\">\n                    <th className=\"p-3 px-2 text-left\">Buyer Name</th>\n                    <th className=\"p-3 px-2 text-left\">Email</th>\n                    <th className=\"p-3 px-2 text-left\">Purchase Date</th>\n                    <th className=\"p-3 px-2 text-left\">Season Bundle</th>\n                    <th className=\"p-3 px-2 text-left\">Qty</th>\n                    <th className=\"p-3 px-2 text-left\">Amount Paid</th>\n                    <th className=\"p-3 px-2 text-left\">Status</th>\n                    <th className=\"p-3 px-2 text-right\">Actions</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  {bundleOrders.map(order => {\n                    const isRefunded = order.status === 'refunded';\n                    return (\n                      <tr \n                        key={order.stripeSessionId} \n                        className=\"border-b border-gray-200 text-sm\" \n                        // @allow-inline-style - isRefunded text color/opacity\n                        style={{ color: isRefunded ? 'var(--text-muted)' : 'inherit', opacity: isRefunded ? 0.6 : 1 }}\n                      >\n                        <td className=\"p-3 px-2 font-semibold\">{order.buyerName}</td>\n                        <td className=\"p-3 px-2\">{order.buyerEmail}</td>\n                        <td className=\"p-3 px-2\">\n                          {formatInTimezone(order.created, timezone, { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' })}\n                        </td>\n                        <td className=\"p-3 px-2 font-medium\">{order.bundleTitle}</td>\n                        <td className=\"p-3 px-2\">{order.quantity}</td>\n                        <td className=\"p-3 px-2\">${(order.amountPaidCents / 100).toFixed(2)}</td>\n                        <td className=\"p-3 px-2\">\n                          <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider ${order.status === 'paid' ? 'bg-success-bg text-success-text' : 'bg-danger-bg text-danger-text'}`}>\n                            {order.status}\n                          </span>\n                        </td>\n                        <td className=\"p-3 px-2 text-right\">\n                          {order.status === 'paid' && (\n                            <button\n                              onClick={() => handleRefundBundle(order.stripePaymentIntentId)}\n                              className=\"btn btn-danger btn-sm\"\n                            >\n                              Refund Bundle\n                            </button>\n                          )}\n                        </td>\n                      </tr>\n                    );\n                  })}\n                </tbody>\n              </table>\n            </div>\n          )}\n        </AppCard>\n      )}\n\n      {/* CRUD Bundle Modal */}\n      <BaseModal\n        isOpen={isModalOpen}\n        onClose={() => setIsModalOpen(false)}\n        title={editingBundle ? \"Edit Season Bundle\" : \"Create Season Bundle\"}\n        maxWidth=\"600px\"\n        footer={\n          <div className=\"flex flex-row gap-4\">\n            <button\n              type=\"button\"\n              className=\"btn btn-ghost\"\n              onClick={() => setIsModalOpen(false)}\n            >\n              Cancel\n            </button>\n            <button\n              type=\"submit\"\n              form=\"bundle-form\"\n              className=\"btn btn-primary\"\n              disabled={saving}\n            >\n              {saving ? \"Saving...\" : \"Save Bundle\"}\n            </button>\n          </div>\n        }\n      >\n        <form id=\"bundle-form\" onSubmit={handleSaveBundle} className=\"flex flex-col gap-4\">\n          {editingBundle && (\n            <div className=\"card p-2 bg-[rgba(74,124,89,0.05)] border-l-4 border-primary rounded text-sm\">\n              <strong>🔗 Share Season Pass Link:</strong>{' '}\n              <a \n                href={`/tickets/bundle/${editingBundle.id}`} \n                target=\"_blank\" \n                rel=\"noopener noreferrer\" \n                className=\"underline text-primary break-all\"\n              >\n                {window.location.origin}/tickets/bundle/{editingBundle.id}\n              </a>\n            </div>\n          )}\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-sm font-semibold\">Bundle Title</label>\n            <input\n              type=\"text\"\n              required\n              placeholder=\"e.g. 2026-2027 Season Pass\"\n              className=\"card h-10 px-3\"\n              value={title}\n              onChange={e => setTitle(e.target.value)}\n            />\n          </div>\n\n          <div className=\"flex gap-4 flex-wrap\">\n            <div className=\"flex flex-col gap-1 flex-1\">\n              <label className=\"text-sm font-semibold\">Price (USD)</label>\n              <input\n                type=\"number\"\n                required\n                min=\"0.01\"\n                step=\"0.01\"\n                className=\"card h-10 px-3\"\n                value={price || ''}\n                onChange={e => setPrice(Number(e.target.value))}\n              />\n            </div>\n            <div className=\"flex flex-col gap-1 flex-1\">\n              <label className=\"text-sm font-semibold\">Capacity Limit</label>\n              <input\n                type=\"number\"\n                required\n                min=\"1\"\n                className=\"card h-10 px-3\"\n                value={capacity || ''}\n                onChange={e => setCapacity(Number(e.target.value))}\n              />\n            </div>\n          </div>\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-sm font-semibold\">Sale End Date</label>\n            <input\n              type=\"datetime-local\"\n              required\n              className=\"card h-10 px-3\"\n              value={saleEndDate}\n              onChange={e => setSaleEndDate(e.target.value)}\n            />\n          </div>\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-sm font-semibold\">Included Performances</label>\n            {hasPurchases && (\n              <div className=\"card p-2 border-warning-border bg-warning-bg text-warning-text text-sm\">\n                ⚠️ This bundle has active purchases. Included events are locked to prevent data drift.\n              </div>\n            )}\n            <div className=\"card max-h-[200px] overflow-y-auto p-2 border border-gray-200 flex flex-col gap-2\">\n              {events\n                .filter(ev => ev.isTicketingEnabled)\n                .map(ev => {\n                  const isChecked = selectedEventIdsSet.has(ev.id);\n                  return (\n                    <label \n                      key={ev.id} \n                      className=\"flex flex-row items-center gap-2 text-sm\" \n                      // @allow-inline-style - hasPurchases cursor\n                      style={{ cursor: hasPurchases ? 'not-allowed' : 'pointer' }}\n                    >\n                      <input\n                        type=\"checkbox\"\n                        checked={isChecked}\n                        disabled={hasPurchases}\n                        onChange={e => {\n                          if (e.target.checked) {\n                            setSelectedEventIds([...selectedEventIds, ev.id]);\n                          } else {\n                            setSelectedEventIds(selectedEventIds.filter(id => id !== ev.id));\n                          }\n                        }}\n                      />\n                      <span>\n                        {ev.title} ({formatInTimezone(ev.date, timezone, { month: 'short', day: 'numeric', year: 'numeric' })})\n                      </span>\n                    </label>\n                  );\n                })}\n              {events.filter(ev => ev.isTicketingEnabled).length === 0 && (\n                <span className=\"text-gray-500 text-xs\">No ticketing-enabled events found. Please enable ticketing on your events first.</span>\n              )}\n            </div>\n          </div>\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-sm font-semibold\">Public Details / Instructions</label>\n            <textarea\n              placeholder=\"e.g. Please bring a photo ID. This pass is non-transferable.\"\n              className=\"card p-2 min-h-[100px] resize-y border border-gray-200\"\n              value={publicDetails}\n              onChange={e => setPublicDetails(e.target.value)}\n            />\n          </div>\n\n          <label className=\"flex flex-row items-center gap-2 cursor-pointer\">\n            <input\n              type=\"checkbox\"\n              checked={isActive}\n              onChange={e => setIsActive(e.target.checked)}\n            />\n            <span className=\"text-sm font-semibold m-0\">Active and visible to the public</span>\n          </label>\n        </form>\n      </BaseModal>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/admin/VenuesView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":81,"column":31,"messageId":"fix:sort","endLine":81,"endColumn":42,"fix":{"range":[2588,2614],"text":"container pt-8 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":81,"column":43,"messageId":"fix:sort","endLine":81,"endColumn":47},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":88,"column":38,"messageId":"fix:sort","endLine":88,"endColumn":49,"fix":{"range":[2759,2813],"text":"flex flex-col items-center justify-between md:flex-row"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":88,"column":66,"messageId":"fix:sort","endLine":88,"endColumn":78},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-display' is not a Tailwind CSS class","line":89,"column":24,"messageId":"issue:unknown-classname","endLine":89,"endColumn":36,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-display"},"fix":{"range":[2839,2855],"text":"m-0"},"desc":"Remove unknown classname 'text-display'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-label' is not a Tailwind CSS class","line":99,"column":33,"messageId":"issue:unknown-classname","endLine":99,"endColumn":43,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-label"},"fix":{"range":[3254,3264],"text":""},"desc":"Remove unknown classname 'text-label'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":103,"column":28,"messageId":"issue:unknown-classname","endLine":103,"endColumn":32,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[3464,3485],"text":"w-full px-3 h-11"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":103,"column":33,"messageId":"fix:sort","endLine":103,"endColumn":39,"fix":{"range":[3464,3485],"text":"card h-11 w-full px-3"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":103,"column":40,"messageId":"fix:sort","endLine":103,"endColumn":44},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":103,"column":45,"messageId":"fix:sort","endLine":103,"endColumn":49},{"ruleId":"tailwindcss/no-custom-classname","sever