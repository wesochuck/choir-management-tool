der","line":102,"column":51,"messageId":"fix:sort","endLine":102,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":102,"column":60,"messageId":"fix:sort","endLine":102,"endColumn":73},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":102,"column":74,"messageId":"fix:sort","endLine":102,"endColumn":78},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":102,"column":79,"messageId":"fix:sort","endLine":102,"endColumn":82},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":102,"column":83,"messageId":"fix:sort","endLine":102,"endColumn":94},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":107,"column":27,"messageId":"fix:sort","endLine":107,"endColumn":33,"fix":{"range":[5028,5063],"text":"bg-neutral-bg w-full rounded-lg p-4"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":107,"column":34,"messageId":"fix:sort","endLine":107,"endColumn":37},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":107,"column":38,"messageId":"fix:sort","endLine":107,"endColumn":51},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'bg-neutral-bg' is not a Tailwind CSS class","line":107,"column":38,"messageId":"issue:unknown-classname","endLine":107,"endColumn":51,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"bg-neutral-bg"},"fix":{"range":[5028,5063],"text":"w-full p-4 rounded-lg"},"desc":"Remove unknown classname 'bg-neutral-bg'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":107,"column":52,"messageId":"fix:sort","endLine":107,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":108,"column":27,"messageId":"fix:sort","endLine":108,"endColumn":42,"fix":{"range":[5092,5119],"text":"m-0 text-sm text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":108,"column":51,"messageId":"fix:sort","endLine":108,"endColumn":54},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":114,"column":70,"messageId":"fix:sort","endLine":114,"endColumn":82,"fix":{"range":[5361,5380],"text":"w-full no-underline"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":114,"column":83,"messageId":"fix:sort","endLine":114,"endColumn":89}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":73,"fixableErrorCount":0,"fixableWarningCount":20,"source":"import { useEffect, useState } from 'react';\nimport { useSearchParams, Link } from 'react-router-dom';\nimport { ticketService, type TicketPurchase } from '../services/ticketService';\nimport { AppCard } from '../components/common/AppCard';\nimport { Button } from '../components/ui/Button/Button';\nimport { Spinner } from '../components/ui/Spinner/Spinner';\nimport { useDocumentTitle } from '../hooks/useDocumentTitle';\nimport { pb } from '../lib/pocketbase';\n\nexport default function PublicTicketSuccessView() {\n  useDocumentTitle('Order Confirmation');\n  const [searchParams] = useSearchParams();\n  const sessionId = searchParams.get('session_id') || '';\n  const [loading, setLoading] = useState(true);\n  const [purchase, setPurchase] = useState<TicketPurchase | null>(null);\n\n  useEffect(() => {\n    async function verifyOrder() {\n      if (!sessionId) {\n        setLoading(false);\n        return;\n      }\n      try {\n        const record = await ticketService.pollForPurchaseRecord(sessionId);\n        setPurchase(record);\n      } catch (err) {\n        console.error(\"Verification failed\", err);\n      } finally {\n        setLoading(false);\n      }\n    }\n    verifyOrder();\n  }, [sessionId]);\n\n  if (loading) {\n    return (\n      <div className=\"flex flex-col min-h-screen justify-center items-center w-screen\">\n        <AppCard className=\"w-full max-w-[480px] text-center items-center\">\n          <h2 className=\"m-0\">Verifying Order...</h2>\n          <Spinner size=\"medium\" />\n          <p className=\"text-text-muted text-sm\">Please wait while we confirm your transaction.</p>\n          <div className=\"w-10 h-10 border-4 border-border border-t-primary rounded-full animate-spin\" />\n        </AppCard>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"flex flex-col min-h-screen justify-center items-center w-screen p-4\">\n      <AppCard className=\"w-full max-w-[480px] text-center items-center gap-4\">\n        <div className=\"text-6xl text-success-text\">✓</div>\n        <h1 className=\"text-display m-0\">Thank You!</h1>\n        <p className=\"text-text-muted m-0\">\n          Your purchase has been successfully processed.\n        </p>\n\n        {purchase ? (\n          <div className=\"card w-full p-4 flex flex-col gap-1 bg-neutral-bg text-left\">\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span className=\"text-text-muted\">Order ID:</span>\n              <strong>{purchase.id}</strong>\n            </div>\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span className=\"text-text-muted\">Will Call Name:</span>\n              <strong>{purchase.buyerName}</strong>\n            </div>\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span className=\"text-text-muted\">Buyer Email:</span>\n              <strong>{purchase.buyerEmail}</strong>\n            </div>\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span className=\"text-text-muted\">Quantity:</span>\n              <strong>{purchase.quantity} {purchase.expand?.bundle ? 'Season Pass' : 'ticket'}{purchase.quantity > 1 ? (purchase.expand?.bundle ? 'es' : 's') : ''}</strong>\n            </div>\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span className=\"text-text-muted\">Amount Paid:</span>\n              <strong>${(purchase.amountPaidCents / 100).toFixed(2)}</strong>\n            </div>\n            {purchase.expand?.bundle ? (\n              <div className=\"border-t border-border pt-1 mt-1 flex flex-col gap-1\">\n                <span className=\"text-text-muted text-xs\">Season Ticket Pass</span>\n                <strong>{purchase.expand.bundle.title}</strong>\n                <p className=\"text-xs text-text-muted m-0\">\n                  This pass grants Will Call admission to all performances included in this package.\n                </p>\n              </div>\n            ) : purchase.expand?.event ? (\n              <div className=\"border-t border-border pt-1 mt-1 flex flex-col gap-1\">\n                <span className=\"text-text-muted text-xs\">Event Details</span>\n                <strong>{purchase.expand.event.title}</strong>\n                <span className=\"text-xs text-text-muted\">\n                  {new Date(purchase.expand.event.date).toLocaleString()}\n                </span>\n                {purchase.expand.event.eventGraphic && (\n                  <img\n                    src={pb.files.getURL(purchase.expand.event, purchase.expand.event.eventGraphic)}\n                    alt={purchase.expand.event.title} className=\"w-full max-h-30 object-cover rounded-sm mt-1\"\n                  />\n                )}\n              </div>\n            ) : null}\n            <p className=\"text-xs text-text-muted border-t border-border pt-1 m-0 text-center\">\n              A confirmation email has been sent. Your tickets will be held at Will Call on show day. Please bring a photo ID matching the buyer's name.\n            </p>\n          </div>\n        ) : (\n          <div className=\"w-full p-4 bg-neutral-bg rounded-lg\">\n            <p className=\"text-text-muted text-sm m-0\">\n              We're finishing up enqueuing your confirmation email. You can safely navigate away. Your tickets are secured.\n            </p>\n          </div>\n        )}\n\n        <Button as={Link} to=\"/tickets\" variant=\"primary\" className=\"no-underline w-full\">\n          Back to Events\n        </Button>\n      </AppCard>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/PublicUnsubscribeView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":50,"column":21,"messageId":"fix:sort","endLine":50,"endColumn":34,"fix":{"range":[1667,1694],"text":"mx-auto max-w-[500px] pt-20"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":50,"column":35,"messageId":"fix:sort","endLine":50,"endColumn":40},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":50,"column":41,"messageId":"fix:sort","endLine":50,"endColumn":48},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":54,"column":29,"messageId":"fix:sort","endLine":54,"endColumn":44,"fix":{"range":[1868,1916],"text":"flex flex-row items-center gap-2 text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":54,"column":45,"messageId":"fix:sort","endLine":54,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":54,"column":50,"messageId":"fix:sort","endLine":54,"endColumn":58},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":54,"column":59,"messageId":"fix:sort","endLine":54,"endColumn":71},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":54,"column":72,"messageId":"fix:sort","endLine":54,"endColumn":77},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-headline' is not a Tailwind CSS class","line":60,"column":30,"messageId":"issue:unknown-classname","endLine":60,"endColumn":43,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-headline"},"fix":{"range":[2119,2132],"text":""},"desc":"Remove unknown classname 'text-headline'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-headline' is not a Tailwind CSS class","line":73,"column":30,"messageId":"issue:unknown-classname","endLine":73,"endColumn":43,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-headline"},"fix":{"range":[2614,2644],"text":"text-danger-text"},"desc":"Remove unknown classname 'text-headline'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":10,"fixableErrorCount":0,"fixableWarningCount":2,"source":"import { useEffect, useState } from 'react';\nimport { useSearchParams, Link } from 'react-router-dom';\nimport { AppCard } from '../components/common/AppCard';\nimport { Button } from '../components/ui/Button/Button';\nimport { Spinner } from '../components/ui/Spinner/Spinner';\nimport { pb } from '../lib/pocketbase';\nimport { useDocumentTitle } from '../hooks/useDocumentTitle';\n\nexport default function PublicUnsubscribeView() {\n  useDocumentTitle('Unsubscribe');\n  const [searchParams] = useSearchParams();\n  let token = searchParams.get('token') || '';\n  const pParam = searchParams.get('p');\n  const sParam = searchParams.get('s');\n\n  if (!token && pParam && sParam) {\n    token = `p=${pParam}&s=${sParam}`;\n  } else if (token && sParam && !token.includes('&s=')) {\n    token = `${token}&s=${sParam}`;\n  }\n  \n  const [status, setStatus] = useState<'loading' | 'success' | 'error'>('loading');\n  const [errorMessage, setErrorMessage] = useState('');\n\n  useEffect(() => {\n    if (!token) {\n      setStatus('error');\n      setErrorMessage('Invalid unsubscribe link. Missing secure verification token.');\n      return;\n    }\n\n    const process = async () => {\n      try {\n        await pb.send('/api/unsubscribe', {\n          method: 'POST',\n          body: { token }\n        });\n        setStatus('success');\n      } catch (err: unknown) {\n        console.error('Unsubscribe error:', err);\n        setStatus('error');\n        setErrorMessage('This unsubscribe link is invalid or has expired. Please contact a choir administrator if you need help updating your message preferences.');\n      }\n    };\n\n    void process();\n  }, [token]);\n\n  return (\n    <div className=\"max-w-[500px] pt-20 mx-auto\">\n      <AppCard title=\"Unsubscribe from Emails\">\n        <div className=\"flex flex-col gap-4 text-center\">\n          {status === 'loading' && (\n            <div className=\"text-text-muted flex flex-row items-center gap-2\"><Spinner size=\"small\" /> Processing your request...</div>\n          )}\n\n          {status === 'success' && (\n            <>\n              <div className=\"text-4xl\">✅</div>\n              <h3 className=\"text-headline\">Unsubscribed Successfully</h3>\n              <p className=\"text-text-muted\">\n                You have been unsubscribed from all future choir management emails.\n              </p>\n              <div className=\"mt-4\">\n                <Button as={Link} to=\"/login\" variant=\"primary\">Go to Login</Button>\n              </div>\n            </>\n          )}\n\n          {status === 'error' && (\n            <>\n              <div className=\"text-4xl\">❌</div>\n              <h3 className=\"text-headline text-danger-text\">Unsubscribe Failed</h3>\n              <p className=\"text-text-muted\">\n                {errorMessage}\n              </p>\n              <div className=\"mt-4\">\n                <Button as={Link} to=\"/login\" variant=\"ghost\">Return to Site</Button>\n              </div>\n            </>\n          )}\n        </div>\n      </AppCard>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/ResetPasswordView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":58,"column":26,"messageId":"fix:sort","endLine":58,"endColumn":34,"fix":{"range":[1929,2002],"text":"flex min-h-screen w-screen flex-col items-center justify-center bg-bg p-4"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":58,"column":35,"messageId":"fix:sort","endLine":58,"endColumn":47},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":58,"column":48,"messageId":"fix:sort","endLine":58,"endColumn":56},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":58,"column":85,"messageId":"fix:sort","endLine":58,"endColumn":88},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":58,"column":89,"messageId":"fix:sort","endLine":58,"endColumn":94},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-display' is not a Tailwind CSS class","line":60,"column":24,"messageId":"issue:unknown-classname","endLine":60,"endColumn":36,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-display"},"fix":{"range":[2099,2128],"text":"text-center mb-8"},"desc":"Remove unknown classname 'text-display'"}]},{"ruleId":"tailwindcss/classnames-order