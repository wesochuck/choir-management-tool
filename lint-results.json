min-h-auto items-center justify-center !p-[0_8px]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":165,"column":58,"messageId":"fix:sort","endLine":165,"endColumn":68},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":165,"column":69,"messageId":"fix:sort","endLine":165,"endColumn":73},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":165,"column":74,"messageId":"fix:sort","endLine":165,"endColumn":78},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":165,"column":79,"messageId":"fix:sort","endLine":165,"endColumn":91},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":165,"column":92,"messageId":"fix:sort","endLine":165,"endColumn":106},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":171,"column":60,"messageId":"issue:unknown-classname","endLine":171,"endColumn":63,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[6726,6747],"text":"btn-danger btn-sm"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-danger' is not a Tailwind CSS class","line":171,"column":64,"messageId":"issue:unknown-classname","endLine":171,"endColumn":74,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-danger"},"fix":{"range":[6726,6747],"text":"btn btn-sm"},"desc":"Remove unknown classname 'btn-danger'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-sm' is not a Tailwind CSS class","line":171,"column":75,"messageId":"issue:unknown-classname","endLine":171,"endColumn":81,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-sm"},"fix":{"range":[6726,6747],"text":"btn btn-danger"},"desc":"Remove unknown classname 'btn-sm'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":117,"fixableErrorCount":0,"fixableWarningCount":19,"source":"import React from 'react';\nimport { useSortable } from '@dnd-kit/sortable';\nimport { CSS } from '@dnd-kit/utilities';\nimport type { SetListItem } from '../../services/eventService';\nimport type { MusicPiece } from '../../types/musicLibrary';\nimport { getDefaultPlayableTrackKey } from '../../lib/setList/setListItems';\nimport type { MusicGenreDef } from '../../services/settingsService';\n\ninterface Props {\n  item: SetListItem;\n  linkedPiece?: MusicPiece;\n  onEdit: (item: SetListItem) => void;\n  onDelete: (id: string) => void;\n  onPieceClick?: (pieceId: string) => void;\n  onPlayTrack?: (piece: MusicPiece) => void;\n  displayTitle?: string;\n  displayComposer?: string;\n  displayDuration?: string;\n  cumulativeStart?: string;\n  cumulativeEnd?: string;\n  genres?: MusicGenreDef[];\n}\n\nexport const SortableSetListItem: React.FC<Props> = ({\n  item,\n  linkedPiece,\n  onEdit,\n  onDelete,\n  onPieceClick,\n  onPlayTrack,\n  displayTitle,\n  displayComposer,\n  displayDuration,\n  cumulativeStart,\n  cumulativeEnd,\n  genres\n}) => {\n  const {\n    attributes,\n    listeners,\n    setNodeRef,\n    transform,\n    transition,\n    isDragging,\n  } = useSortable({ id: item.id });\n\n  const style = {\n    transform: CSS.Transform.toString(transform),\n    transition: isDragging ? 'none' : (transition || 'none'),\n    opacity: isDragging ? 0.5 : 1,\n    zIndex: isDragging ? 100 : 0,\n    position: 'relative' as const,\n  };\n\n  const titleText = displayTitle || item.title;\n  const hasAudio = linkedPiece ? !!getDefaultPlayableTrackKey(linkedPiece) : false;\n\n  return (\n    <div \n      ref={setNodeRef} \n      className={`card flex-row sl-item-card ${item.type === 'intermission' ? 'sl-item-card-intermission' : 'sl-item-card-song'}`}\n      // @allow-inline-style - dnd-kit sortable transform and transition\n      style={{ \n        ...style \n      }}\n    >\n      <div {...attributes} {...listeners} className=\"cursor-grab flex items-center p-2 text-[var(--text-muted)]\">\n        <span className=\"text-[1.2rem]\">⣿</span>\n      </div>\n      \n      <div className=\"flex-col flex-1 gap-[2px]\">\n        {item.type === 'intermission' ? (\n          <div className=\"flex-row items-center gap-2 flex-wrap\">\n            <span className=\"font-semibold text-[var(--primary-deep)] text-[0.95rem]\">⏸️ {titleText}</span>\n            {displayDuration && (\n              <span className=\"inline-flex items-center px-[8px] py-[2px] rounded text-[0.75rem] font-semibold uppercase tracking-wider bg-[var(--surface)] text-primary-deep\">\n                {displayDuration}\n              </span>\n            )}\n            {cumulativeStart && cumulativeEnd && (\n              <span className=\"text-xs text-muted italic\">\n                ({cumulativeStart} - {cumulativeEnd})\n              </span>\n            )}\n          </div>\n        ) : (\n          <div className=\"text-label flex-row m-0 gap-[6px] items-center flex-wrap\">\n            {(item.pieceId || linkedPiece?.id) && onPieceClick ? (\n              <button\n                type=\"button\"\n                onClick={() => onPieceClick((item.pieceId || linkedPiece?.id)!)}\n                className=\"bg-none border-none p-0 text-left font-inherit cursor-pointer text-[var(--primary)] underline inline-flex items-center gap-[6px]\"\n              >\n                {titleText}\n                <span title=\"Linked to Music Library\" className=\"text-[0.85rem] no-underline inline-block\">🎼</span>\n              </button>\n            ) : (\n              <span className=\"inline-flex items-center gap-[6px]\">\n                {onEdit ? (\n                    <button\n                        type=\"button\"\n                        onClick={() => onEdit(item)}\n                        className=\"bg-none border-none p-0 text-left text-inherit font-inherit font-semibold cursor-pointer underline decoration-dotted decoration-[var(--primary)] underline-offset-[3px]\"\n                    >\n                        {titleText}\n                    </button>\n                ) : (\n                    <span className=\"font-semibold\">{titleText}</span>\n                )}\n                {(item.pieceId || linkedPiece?.id) && <span title=\"Linked to Music Library\" className=\"text-[0.85rem]\">🎼</span>}\n              </span>\n            )}\n            {item.soloSmallGroup && (\n              <span className=\"text-[0.75rem] px-[8px] py-[2px] bg-[rgb(74_124_89_/_8%)] text-[var(--primary-deep)] border border-[rgb(74_124_89_/_15%)] rounded-full font-semibold inline-flex items-center gap-1\">\n                🎤 Solo / Small Group\n              </span>\n            )}\n            {cumulativeStart && cumulativeEnd && (\n              <span className=\"text-xs text-muted font-normal ml-1\">\n                ({cumulativeStart} - {cumulativeEnd})\n              </span>\n            )}\n          </div>\n        )}\n        {item.type !== 'intermission' && (displayComposer || displayDuration || (linkedPiece?.genres && linkedPiece.genres.length > 0)) && (\n          <div className=\"text-xs text-muted flex-row gap-1\">\n            {displayComposer && (\n              <span className=\"text-xs text-muted\">\n                {displayComposer}\n              </span>\n            )}\n            {displayComposer && displayDuration && <span>•</span>}\n            {displayDuration && <span>{displayDuration}</span>}\n            {linkedPiece?.genres && linkedPiece.genres.length > 0 && genres && (\n              <div className=\"flex-row gap-1 inline-flex flex-wrap items-center\">\n                {linkedPiece.genres.map(id => {\n                  const found = genres.find(g => g.id === id);\n                  return (\n                    <span \n                      key={id}\n                      className=\"inline-flex px-[5px] py-[1px] rounded bg-[rgb(74_124_89_/_8%)] border border-[rgb(74_124_89_/_15%)] text-[9px] font-semibold text-[var(--primary-deep)] leading-none\"\n                    >\n                      {found ? found.label : id}\n                    </span>\n                  );\n                })}\n              </div>\n            )}\n          </div>\n        )}\n        {item.notes && (\n          <div className=\"text-xs text-muted italic mt-[2px]\">\n            {item.notes}\n          </div>\n        )}\n      </div>\n\n      <button onClick={() => onEdit(item)} className=\"btn btn-ghost btn-sm\">Edit</button>\n      {hasAudio && onPlayTrack && (\n        <button \n          onClick={(e) => {\n            e.stopPropagation();\n            if (linkedPiece) onPlayTrack(linkedPiece);\n          }} \n          className=\"btn btn-secondary btn-sm !p-[0_8px] min-h-auto !h-6 flex items-center justify-center\"\n          title=\"Play default track\"\n        >\n          🎵\n        </button>\n      )}\n      <button onClick={() => onDelete(item.id)} className=\"btn btn-danger btn-sm\">X</button>\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/StatusAutomationSettings.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'admin-settings-group' is not a Tailwind CSS class","line":26,"column":23,"messageId":"issue:unknown-classname","endLine":26,"endColumn":43,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"admin-settings-group"},"fix":{"range":[910,930],"text":""},"desc":"Remove unknown classname 'admin-settings-group'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":27,"column":32,"messageId":"fix:sort","en