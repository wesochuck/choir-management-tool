ount":39,"fixableErrorCount":0,"fixableWarningCount":9,"source":"import { AppCard } from '../common/AppCard';\n\ninterface StatusAutomationSettingsProps {\n  configAutomationEnabled: boolean;\n  setConfigAutomationEnabled: (value: boolean) => void;\n  configAutomationMissThreshold: number;\n  setConfigAutomationMissThreshold: (value: number) => void;\n  configAutomationRecoveryEnabled: boolean;\n  setConfigAutomationRecoveryEnabled: (value: boolean) => void;\n  configMaxRehearsalMisses: number;\n  setConfigMaxRehearsalMisses: (value: number) => void;\n}\n\nexport function StatusAutomationSettings({\n  configAutomationEnabled,\n  setConfigAutomationEnabled,\n  configAutomationMissThreshold,\n  setConfigAutomationMissThreshold,\n  configAutomationRecoveryEnabled,\n  setConfigAutomationRecoveryEnabled,\n  configMaxRehearsalMisses,\n  setConfigMaxRehearsalMisses,\n}: StatusAutomationSettingsProps) {\n  return (\n    <AppCard title=\"Singer Status & Rehearsal Limits\">\n      <div className=\"admin-settings-group\">\n        <label className=\"flex flex-row items-center gap-2 cursor-pointer\">\n          <input\n            type=\"checkbox\"\n            checked={configAutomationEnabled}\n            onChange={(e) => setConfigAutomationEnabled(e.target.checked)}\n            className=\"accent-[var(--primary)] w-4 h-4\"\n          />\n          <span className=\"text-label font-semibold\">Enable Automated Status Changes</span>\n        </label>\n        <p className=\"text-muted admin-checkbox-description\">\n          Automatically mark singers as Active/Inactive based on their attendance and RSVP history.\n        </p>\n\n        {configAutomationEnabled && (\n          <div className=\"admin-settings-nested-group\">\n            <div className=\"admin-settings-field\">\n              <label className=\"text-label\">Consecutive Misses Threshold</label>\n              <input\n                type=\"number\"\n                min={1}\n                max={10}\n                value={configAutomationMissThreshold}\n                onChange={(e) => setConfigAutomationMissThreshold(Math.max(1, parseInt(e.target.value) || 1))}\n                className=\"card admin-settings-input-sm\"\n              />\n              <p className=\"text-muted admin-settings-description\">\n                Mark a singer as Inactive after this many consecutive absences or 'No' RSVPs.\n              </p>\n            </div>\n\n            {/* @allow-inline-style - spacing override */}\n            <label className=\"flex flex-row items-center gap-2 cursor-pointer\" style={{ marginTop: 'var(--space-xs)' }}>\n              <input\n                type=\"checkbox\"\n                checked={configAutomationRecoveryEnabled}\n                onChange={(e) => setConfigAutomationRecoveryEnabled(e.target.checked)}\n                className=\"accent-[var(--primary)] w-4 h-4\"\n              />\n              <span className=\"text-label font-semibold\">Enable Automated Status Recovery</span>\n            </label>\n            <p className=\"text-muted admin-checkbox-description\">\n              Automatically mark inactive singers as \"Idle\" when they RSVP 'Yes' to a future Performance.\n            </p>\n          </div>\n        )}\n\n        <hr className=\"border-none border-t border-border my-2\" />\n\n        <div className=\"admin-settings-field\">\n          <label className=\"text-label font-semibold\">Maximum Rehearsal Miss Limit</label>\n          <input\n            type=\"number\"\n            min={0}\n            max={20}\n            value={configMaxRehearsalMisses}\n            onChange={(e) => setConfigMaxRehearsalMisses(Math.max(0, parseInt(e.target.value) || 0))}\n            className=\"card admin-settings-input-sm\"\n          />\n          <p className=\"text-muted admin-settings-description\">\n            The maximum number of rehearsal misses (declined RSVPs or marked absences) allowed for a concert cycle before warnings are shown to singers and admins.\n          </p>\n        </div>\n      </div>\n    </AppCard>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/UnassignedPrintSection.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":18,"column":21,"messageId":"fix:sort","endLine":18,"endColumn":27,"fix":{"range":[493,536],"text":"unassigned-print-section hidden print:block"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":18,"column":28,"messageId":"fix:sort","endLine":18,"endColumn":39},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":18,"column":40,"messageId":"fix:sort","endLine":18,"endColumn":64},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'unassigned-print-section' is not a Tailwind CSS class","line":18,"column":40,"messageId":"issue:unknown-classname","endLine":18,"endColumn":64,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"unassigned-print-section"},"fix":{"range":[493,536],"text":"hidden print:block"},"desc":"Remove unknown classname 'unassigned-print-section'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":19,"column":48,"messageId":"fix:sort","endLine":19,"endColumn":52,"fix":{"range":[561,678],"text":"inline-flex items-center rounded bg-gray-200 px-2 py-0.5 text-xs font-semibold tracking-wider text-gray-700 uppercase"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":19,"column":53,"messageId":"fix:sort","endLine":19,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":19,"column":60,"messageId":"fix:sort","endLine":19,"endColumn":67},{"ruleId":"ta