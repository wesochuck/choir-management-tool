 '../../../lib/communicationUtils';\nimport { useDialog } from '../../../contexts/DialogContext';\n\nexport interface TemplatesPanelProps {\n  templates: TemplateRecord[];\n  setTemplates: React.Dispatch<React.SetStateAction<TemplateRecord[]>>;\n  editingTemplate: Partial<TemplateRecord> | null;\n  setEditingTemplate: React.Dispatch<\n    React.SetStateAction<Partial<TemplateRecord> | null>\n  >;\n  onUseTemplate?: (template: TemplateRecord) => void;\n  dialog: ReturnType<typeof useDialog>;\n  previewHtml: string;\n  onInsertPlaceholder: (tag: string) => void;\n  editorRef: React.MutableRefObject<EasyMDE | null>;\n  choirName: string;\n  senderEmail: string;\n}\n\nexport function TemplatesPanel({\n  templates,\n  setTemplates,\n  editingTemplate,\n  setEditingTemplate,\n  onUseTemplate,\n  dialog,\n  previewHtml,\n  onInsertPlaceholder,\n  editorRef,\n  choirName,\n  senderEmail,\n}: TemplatesPanelProps) {\n  const [previewDevice, setPreviewDevice] = useState<'desktop' | 'mobile'>('desktop');\n\n  if (editingTemplate) {\n    return (\n      <div className=\"flex flex-col lg:grid lg:grid-cols-[1fr_300px] gap-6 items-start\">\n        <div className=\"flex flex-col gap-4\">\n          <AppCard title={editingTemplate.id ? 'Edit Template' : 'New Template'}>\n            <div className=\"flex flex-col gap-4\">\n              <div className=\"flex gap-4 flex-wrap\">\n                <div className=\"flex flex-col gap-1 flex-1\">\n                  <label className=\"text-label\">Template Title</label>\n                  <input\n                    className=\"card h-10 px-3 w-full border border-border\"\n                    value={editingTemplate.title || ''}\n                    onChange={(e) =>\n                      setEditingTemplate({ ...editingTemplate, title: e.target.value })\n                    }\n                    placeholder=\"e.g. Performance Call Time\"\n                    required\n                  />\n                </div>\n                <div className=\"flex flex-col gap-1 flex-[0_0_150px]\">\n                  <label className=\"text-label\">Channel</label>\n                  <select\n                    className=\"card h-10 px-3 w-full border border-border\"\n                    value={editingTemplate.type || 'Email'}\n                    onChange={(e) =>\n                      setEditingTemplate({\n                        ...editingTemplate,\n                        type: e.target.value as MessageType,\n                        subject: e.target.value === 'SMS' ? '' : editingTemplate.subject,\n                      })\n                    }\n                  >\n                    <option value=\"Email\">Email</option>\n                    <option value=\"SMS\">SMS</option>\n                    <option value=\"Both\">Both</option>\n                  </select>\n                </div>\n              </div>\n\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-label\">Subject</label>\n                <input\n                  className=\"card h-10 px-3 w-full border border-border\"\n                  value={editingTemplate.subject || ''}\n                  onChange={(e) =>\n                    setEditingTemplate({ ...editingTemplate, subject: e.target.value })\n                  }\n                  placeholder=\"e.g. Schedule for {eventTitle}\"\n                  disabled={editingTemplate.type === 'SMS'}\n                  required={editingTemplate.type !== 'SMS'}\n                />\n              </div>\n\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-label\">Template Body (Markdown Supported)</label>\n                <MarkdownEditor\n                  instanceRef={editorRef}\n                  value={editingTemplate.content || ''}\n                  onChange={(val) =>\n                    setEditingTemplate({ ...editingTemplate, content: val })\n                  }\n                  placeholder=\"Hello {singerName},&#10;&#10;Details: {eventDetails}\"\n                  minHeight=\"250px\"\n                />\n              </div>\n            </div>\n          </AppCard>\n\n          <AppCard\n            title=\"Template Preview\"\n            actions={\n              <div className=\"flex gap-4 p-4 border-t border-border bg-[#f8fafc] rounded-b-lg\">\n                <button\n                  type=\"button\"\n                  className={`btn btn-sm ${previewDevice === 'desktop' ? 'btn-secondary' : 'btn-ghost'} px-2.5 py-1 h-[30px]`}\n                  onClick={() => setPreviewDevice('desktop')}\n                >\n                  🖥️ Desktop\n                </button>\n                <button\n                  type=\"button\"\n                  className={`btn btn-sm ${previewDevice === 'mobile' ? 'btn-secondary' : 'btn-ghost'} px-2.5 py-1 h-[30px]`}\n                  onClick={() => setPreviewDevice('mobile')}\n                >\n                  📱 Mobile\n                </button>\n              </div>\n            }\n          >\n            <div\n              className={`border border-border rounded-lg overflow-hidden bg-slate-100 flex justify-center transition-all duration-300 ${previewDevice === 'mobile' ? 'px-[15px] py-[30px]' : 'p-0'}`}\n            >\n              <div\n                className={`w-full bg-surface shadow-md flex flex-col transition-all duration-300 min-h-[400px] ${previewDevice === 'mobile' ? 'max-w-[375px] rounded-[20px] border-8 border-slate-800' : 'max-w-full rounded-none border-0'}`}\n              >\n                <div className=\"p-4 border-b border-border bg-[#f8fafc] text-xs flex flex-col gap-1.5\">\n                  <div className=\"flex text-text-muted\">\n                    <span className=\"w-[60px] font-semibold\">From:</span>\n                    <span className=\"text-slate-800\">\n                      {choirName} &lt;{senderEmail}&gt;\n                    </span>\n                  </div>\n                  <div className=\"flex text-text-muted\">\n                    <span className=\"w-[60px] font-semibold\">Subject:</span>\n                    <strong className=\"text-slate-900\">\n                      {resolvePreviewContent(editingTemplate.subject || '', null, null)}\n                    </strong>\n                  </div>\n                </div>\n                <div\n                  className={`overflow-y-auto flex-1 text-sm leading-relaxed text-slate-600 break-words ${previewDevice === 'mobile' ? 'p-4' : 'p-6'}`}\n                >\n                  <div\n                    className=\"text-body message-preview-content\"\n                    // @allow-dangerouslySetInnerHTML - previewHtml is pre-escaped by renderMarkdown/resolvePreviewContent (use with caution)\n                    dangerouslySetInnerHTML={{\n                      __html:\n                        previewHtml ||\n                        '<p class=\"text-muted\" style=\"text-align:center;padding:2rem 0\">No template content yet.</p>',\n                    }}\n                  />\n                </div>\n              </div>\n            </div>\n          </AppCard>\n\n          <div className=\"flex justify-end gap-2\">\n            <button\n              type=\"button\"\n              className=\"btn btn-ghost\"\n              onClick={() => setEditingTemplate(null)}\n            >\n              Cancel\n            </button>\n            <button\n              type=\"button\"\n              className=\"btn btn-primary\"\n              onClick={async () => {\n                if (!editingTemplate.title || !editingTemplate.content) {\n                  dialog.showToast('Title and content are required.');\n                  return;\n                }\n                try {\n                  await communicationService.saveTemplate(editingTemplate);\n                  setTemplates(await communicationService.getTemplates());\n                  setEditingTemplate(null);\n                  dialog.showToast('Template saved successfully.');\n                } catch (err: unknown) {\n                  const msg = err instanceof Error ? err.message : String(err);\n                  await dialog.showMessage({\n                    title: 'Error',\n                    message: 'Failed to save template: ' + msg,\n                    variant: 'danger',\n                  });\n                }\n              }}\n            >\n              Save Template\n            </button>\n          </div>\n        </div>\n        <PlaceholderPanel onInsert={onInsertPlaceholder} />\n      </div>\n    );\n  }\n\n  return (\n    <AppCard\n      title=\"Message Templates\"\n      actions={\n        <button\n          type=\"button\"\n          className=\"btn btn-primary btn-sm h-8 inline-flex items-center gap-1 px-2 text-xs rounded bg-slate-100 text-slate-600 border border-border\"\n          onClick={() =>\n            setEditingTemplate({\n              title: '',\n              subject: '',\n              content: '',\n              type: 'Email',\n              isSystemTemplate: false,\n            })\n          }\n        >\n          ➕ Add Custom Template\n        </button>\n      }\n    >\n      <div className=\"flex flex-col gap-4\">\n        <p className=\"text-muted text-sm\">\n          Manage message templates. Custom templates can be added, edited, or deleted. System-defined templates cannot be deleted.\n        </p>\n        <div className=\"overflow-x-auto\">\n          <table className=\"border-collapse w-full min-w-[700px] text-left\">\n            <thead>\n              <tr className=\"border-b-2 border-gray-200 text-gray-500 text-sm\">\n                <th className=\"p-3 px-4 text-left\">Title</th>\n                <th className=\"p-3 px-4 text-left\">Type</th>\n                <th className=\"p-3 px-4 text-left\">Subject</th>\n                <th className=\"p-3 px-4 text-left\">Content</th>\n                <th className=\"p-3 px-4 text-right\">Actions</th>\n              </tr>\n            </thead>\n            <tbody>\n              {templates.length === 0 ? (\n                <tr>\n                  <td colSpan={5} className=\"text-center p-8 text-gray-500\">\n                    No templates found.\n                  </td>\n                </tr>\n              ) : (\n                templates.map((tpl) => (\n                  <tr key={tpl.id} className=\"border-b border-gray-200 text-sm\">\n                    <td className=\"p-3 px-4 font-semibold\">\n                      <div className=\"flex items-center gap-1.5\">\n                        <span>{tpl.title}</span>\n                        {tpl.isSystemTemplate && (\n                          <span className=\"inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider bg-performance-bg text-performance-text opacity-80\">\n                            System\n                          </span>\n                        )}\n                      </div>\n                    </td>\n                    <td className=\"p-3 px-4\">\n                      <span className=\"inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider bg-primary-light text-primary-deep w-fit\">\n                        {tpl.type}\n                      </span>\n                    </td>\n                    <td className=\"p-3 px-4 max-w-[250px] truncate text-muted\">\n                      {tpl.subject || 'No Subject'}\n                    </td>\n                    <td className=\"p-3 px-4 max-w-[300px] truncate text-muted\">\n                      {tpl.content.substring(0, 60)}...\n                    </td>\n                    <td className=\"p-3 px-4 text-right whitespace-nowrap\">\n                      <div className=\"flex gap-1.5 justify-end\">\n                        <button\n                          type=\"button\"\n                          className=\"btn btn-ghost btn-sm\"\n                          onClick={() => setEditingTemplate(tpl)}\n                        >\n                          Edit\n                        </button>\n                        {onUseTemplate && (\n                          <button\n                            type=\"button\"\n                            className=\"btn btn-ghost btn-sm\"\n                            onClick={() => onUseTemplate(tpl)}\n                          >\n                            Use\n                          </button>\n                        )}\n                        {!tpl.isSystemTemplate && (\n                          <button\n                            type=\"button\"\n                            className=\"btn btn-ghost btn-sm text-red-500\"\n                            onClick={async () => {\n                              if (\n                                await dialog.confirm({\n                                  title: 'Delete Template',\n                                  message: `Are you sure you want to delete the template \"${tpl.title}\"?`,\n                                  variant: 'danger',\n                                })\n                              ) {\n                                try {\n                                  await communicationService.deleteTemplate(tpl.id!);\n                                  setTemplates(await communicationService.getTemplates());\n                                } catch (e: unknown) {\n                                  const msg = e instanceof Error ? e.message : String(e);\n                                  await dialog.showMessage({\n                                    title: 'Error',\n                                    message: 'Failed to delete template: ' + msg,\n                                    variant: 'danger',\n                                  });\n                                }\n                              }\n                            }}\n                          >\n                            Delete\n                          </button>\n                        )}\n                      </div>\n                    </td>\n                  </tr>\n                ))\n              )}\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </AppCard>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/admin/communications/templateMapping.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/admin/communications/types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/admin/communications/useAutomatedCommunicationTasks.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/admin/communications/useCommunicationDraft.ts","messages":[],"suppressedMessages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'recipients.length'. Either include it or remove the dependency array.","line":129,"column":6,"endLine":129,"endColumn":43,"suggestions":[{"desc":"Update the dependencies array to be: [filters, tab, lockInitialRecipients, recipients.length]","fix":{"range":[4471,4508],"text":"[filters, tab, lockInitialRecipients, recipients.length]"}}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/admin/communications/useC