":438,"endColumn":65},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":438,"column":66,"messageId":"fix:sort","endLine":438,"endColumn":78},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":439,"column":28,"messageId":"fix:sort","endLine":439,"endColumn":39,"fix":{"range":[16814,16859],"text":"animate-[spin_2s_linear_infinite] text-[3rem]"}},{"ruleId":"tailwindcss/no-unnecessary-arbitrary-value","severity":1,"message":"No need for arbitrary 'text-[3rem]', use 'text-5xl' instead","line":439,"column":28,"messageId":"issue:unnecessary-arbitrary","endLine":439,"endColumn":39,"suggestions":[{"messageId":"fix:unnecessary-arbitrary","data":{"arbitraryClass":"text-[3rem]","presetClass":"text-5xl"},"fix":{"range":[16814,16859],"text":"text-5xl animate-[spin_2s_linear_infinite]"},"desc":"Replace 'text-[3rem]' by 'text-5xl'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":439,"column":40,"messageId":"fix:sort","endLine":439,"endColumn":73},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":441,"column":32,"messageId":"fix:sort","endLine":441,"endColumn":40,"fix":{"range":[16908,16951],"text":"flex w-full flex-col items-center gap-[6px]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":441,"column":41,"messageId":"fix:sort","endLine":441,"endColumn":50},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":441,"column":51,"messageId":"fix:sort","endLine":441,"endColumn":57},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":441,"column":58,"messageId":"fix:sort","endLine":441,"endColumn":70},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":445,"column":30,"messageId":"issue:unknown-classname","endLine":445,"endColumn":40,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[17150,17168],"text":"text-sm"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":450,"column":27,"messageId":"fix:sort","endLine":450,"endColumn":33,"fix":{"range":[17306,17375],"text":"mt-[10px] h-3 w-full overflow-hidden rounded-[6px] bg-[var(--border)]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":450,"column":38,"messageId":"fix:sort","endLine":450,"endColumn":56},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":450,"column":57,"messageId":"fix:sort","endLine":450,"endColumn":70},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":450,"column":71,"messageId":"fix:sort","endLine":450,"endColumn":86},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":450,"column":87,"messageId":"fix:sort","endLine":450,"endColumn":96},{"ruleId":"tailwindcss/no-unnecessary-arbitrary-value","severity":1,"message":"No need for arbitrary 'text-[#991b1b]', use 'text-danger-text' or 'text-performance-text' instead","line":462,"column":73,"messageId":"issue:unnecessary-arbitrary","endLine":462,"endColumn":87,"suggestions":[{"messageId":"fix:unnecessary-arbitrary","data":{"arbitraryClass":"text-[#991b1b]","presetClass":"text-danger-text"},"fix":{"range":[17924,17938],"text":"text-danger-text"},"desc":"Replace 'text-[#991b1b]' by 'text-danger-text'"},{"messageId":"fix:unnecessary-arbitrary","data":{"arbitraryClass":"text-[#991b1b]","presetClass":"text-performance-text"},"fix":{"range":[17924,17938],"text":"text-performance-text"},"desc":"Replace 'text-[#991b1b]' by 'text-performance-text'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":473,"column":27,"messageId":"issue:unknown-classname","endLine":473,"endColumn":37,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[18417,18440],"text":"text-sm !m-0"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":473,"column":38,"messageId":"fix:sort","endLine":473,"endColumn":45,"fix":{"range":[18417,18440],"text":"text-muted !m-0 text-sm"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":473,"column":46,"messageId":"fix:sort","endLine":473,"endColumn":50},{"ruleId":"tailwindcss/no-unnecessary-arbitrary-value","severity":1,"message":"No need for arbitrary 'text-[#991b1b]', use 'text-danger-text' or 'text-performance-text' instead","line":480,"column":48,"messageId":"issue:unnecessary-arbitrary","endLine":480,"endColumn":62,"suggestions":[{"messageId":"fix:unnecessary-arbitrary","data":{"arbitraryClass":"text-[#991b1b]","presetClass":"text-danger-text"},"fix":{"range":[18715,18743],"text":"text-[0.9rem] text-danger-text"},"desc":"Replace 'text-[#991b1b]' by 'text-danger-text'"},{"messageId":"fix:unnecessary-arbitrary","data":{"arbitraryClass":"text-[#991b1b]","presetClass":"text-performance-text"},"fix":{"range":[18715,18743],"text":"text-[0.9rem] text-performance-text"},"desc":"Replace 'text-[#991b1b]' by 'text-performance-text'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":483,"column":61,"messageId":"fix:sort","endLine":483,"endColumn":67,"fix":{"range":[18868,18994],"text":"max-h-[150px] overflow-y-auto rounded-[var(--radius-md)] border border-[var(--border)] bg-[#fafafa] p-[8px_12px] text-[0.8rem]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":483,"column":68,"messageId":"fix:sort","endLine":483,"endColumn":90},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":483,"column":91,"messageId":"fix:sort","endLine":483,"endColumn":117},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":483,"column":118,"messageId":"fix:sort","endLine":483,"endColumn":130},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":483,"column":131,"messageId":"fix:sort","endLine":483,"endColumn":143},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":485,"column":43,"messageId":"fix:sort","endLine":485,"endColumn":47,"fix":{"range":[19085,19149],"text":"border-b border-[var(--border)] py-1 text-[#444] last:border-b-0"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":485,"column":48,"messageId":"fix:sort","endLine":485,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":485,"column":60,"messageId":"fix:sort","endLine":485,"endColumn":68},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":485,"column":69,"messageId":"fix:sort","endLine":485,"endColumn":91},{"ruleId":"tailwindcss/no-unnecessary-arbitrary-value","severity":1,"message":"No need for arbitrary 'text-[#991b1b]', use 'text-danger-text' or 'text-performance-text' instead","line":486,"column":84,"messageId":"issue:unnecessary-arbitrary","endLine":486,"endColumn":98,"suggestions":[{"messageId":"fix:unnecessary-arbitrary","data":{"arbitraryClass":"text-[#991b1b]","presetClass":"text-danger-text"},"fix":{"range":[19235,19249],"text":"text-danger-text"},"desc":"Replace 'text-[#991b1b]' by 'text-danger-text'"},{"messageId":"fix:unnecessary-arbitrary","data":{"arbitraryClass":"text-[#991b1b]","presetClass":"text-performance-text"},"fix":{"range":[19235,19249],"text":"text-performance-text"},"desc":"Replace 'text-[#991b1b]' by 'text-performance-text'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":152,"fixableErrorCount":0,"fixableWarningCount":32,"source":"import React, { useState, useRef } from 'react';\nimport { BaseModal } from '../common/BaseModal';\nimport { useDialog } from '../../contexts/DialogContext';\nimport { musicLibraryService, type MusicPieceInput } from '../../services/musicLibraryService';\nimport { parseCSV, type CSVData } from '../../lib/rosterImportUtils';\nimport {\n  suggestMusicFieldMapping,\n  validateAndMapMusicPieces,\n  type MappedMusicPiece,\n  type MusicField,\n  type MusicFieldMapping,\n} from '../../lib/musicImportUtils';\n\n\ninterface MusicImportModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  onSuccess: () => Promise<void>;\n}\n\ntype ImportStep = 'UPLOAD' | 'MAP' | 'PREVIEW' | 'IMPORTING' | 'COMPLETE';\n\nexport const MusicImportModal: React.FC<MusicImportModalProps> = ({\n  isOpen,\n  onClose,\n  onSuccess,\n}) => {\n  const dialog = useDialog();\n  const fileInputRef = useRef<HTMLInputElement>(null);\n\n  // Wizard state\n  const [step, setStep] = useState<ImportStep>('UPLOAD');\n  const [csvData, setCsvData] = useState<CSVData | null>(null);\n  const [mapping, setMapping] = useState<MusicFieldMapping>({\n    title: -1,\n    composer: -1,\n    arranger: -1,\n    copies: -1,\n    catalogId: -1,\n    duration: -1,\n    notes: -1,\n    purchaseDate: -1,\n  });\n  const [mappedPieces, setMappedPieces] = useState<MappedMusicPiece[]>([]);\n  \n  // Execution progress\n  const [importProgress, setImportProgress] = useState(0);\n  const [importingIndex, setImportingIndex] = useState(0);\n  const [successCount, setSuccessCount] = useState(0);\n  const [errorsList, setErrorsList] = useState<{ row: number; title: string; error: string }[]>([]);\n\n  // 1. Handlers for Upload Step\n  const handleFileUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0];\n    if (!file) return;\n\n    try {\n      const text = await file.text();\n      const parsed = parseCSV(text);\n\n      if (parsed.headers.length === 0 || parsed.rows.length === 0) {\n        throw new Error('The CSV file appears to be empty.');\n      }\n\n      setCsvData(parsed);\n      \n      // Auto-suggest mapping based on headers\n      const suggested = suggestMusicFieldMapping(parsed.headers);\n      setMapping(suggested);\n\n      setStep('MAP');\n    } catch (err: unknown) {\n      await dialog.showMessage({\n        title: 'Upload Error',\n        message: err instanceof Error ? err.message : 'Could not parse the CSV file.',\n        variant: 'danger',\n      });\n    } finally {\n      if (fileInputRef.current) fileInputRef.current.value = '';\n    }\n  };\n\n  // 2. Handlers for Mapping Step\n  const handleMappingChange = (field: MusicField, index: number) => {\n    setMapping(prev => ({ ...prev, [field]: index }));\n  };\n\n  const handleApplyMapping = () => {\n    if (!csvData) return;\n\n    // Verify Title is mapped as it is required\n    if (mapping.title === -1) {\n      dialog.showMessage({\n        title: 'Mapping Required',\n        message: 'You must map a column to the \"Title\" field as it is required to create a music piece.',\n        variant: 'danger',\n      });\n      return;\n    }\n\n    const pieces = validateAndMapMusicPieces(csvData, mapping);\n    setMappedPieces(pieces);\n    setStep('PREVIEW');\n  };\n\n  // 3. Handlers for Preview Step\n  const handleStartImport = async () => {\n    if (!csvData) return;\n\n    const validPieces = mappedPieces.filter(p => p.isValid);\n    if (validPieces.length === 0) {\n      await dialog.showMessage({\n        title: 'No Valid Records',\n        message: 'There are no valid records to import. Please check your field mapping or fix errors.',\n        variant: 'danger',\n      });\n      return;\n    }\n\n    const confirmed = await dialog.confirm({\n      title: 'Confirm Import',\n      message: `Ready to import ${validPieces.length} music pieces? ${\n        mappedPieces.length - validPieces.length > 0 \n          ? `${mappedPieces.length - validPieces.length} invalid rows will be skipped.` \n          : ''\n      }`,\n      confirmLabel: 'Import Now',\n    });\n\n    if (!confirmed) return;\n\n    setStep('IMPORTING');\n    setImportProgress(0);\n    setImportingIndex(0);\n    setSuccessCount(0);\n    setErrorsList([]);\n\n    // Run import sequentially to show live progress and handle partial success robustly\n    let successes = 0;\n    const errors: typeof errorsList = [];\n\n    // @allow-sequential-await - Import runs sequentially to show live progress and handle partial success robustly.\n    for (let i = 0; i < mappedPieces.length; i++) {\n      const piece = mappedPieces[i];\n      if (!piece.isValid) continue;\n\n      setImportingIndex(i + 1);\n      \n      try {\n        const payload: Partial<MusicPieceInput> = {\n          title: piece.data.title,\n          composer: piece.data.composer || undefined,\n          arranger: piece.data.arranger || undefined,\n          purchaseDate: piece.data.purchaseDate || undefined,\n          copies: piece.data.copies || undefined,\n          catalogId: piece.data.catalogId || undefined,\n          duration: piece.data.duration || undefined,\n          notes: piece.data.notes || undefined,\n        };\n\n        await musicLibraryService.createPiece(payload);\n        successes++;\n        setSuccessCount(successes);\n      } catch (err: unknown) {\n        console.error(`Import failed for row ${piece.rowNumber}:`, err);\n        errors.push({\n          row: piece.rowNumber,\n          title: piece.data.title || 'Unknown Title',\n          error: err instanceof Error ? err.message : 'Unknown database error',\n        });\n        setErrorsList([...errors]);\n      }\n\n      setImportProgress(Math.round(((i + 1) / mappedPieces.length) * 100));\n    }\n\n    setStep('COMPLETE');\n    dialog.showToast(`Music library import finished: ${successes} items added.`);\n    await onSuccess();\n  };\n\n  // Helper for resetting modal states\n  const handleReset = () => {\n    setStep('UPLOAD');\n    setCsvData(null);\n    setMapping({\n      title: -1,\n      composer: -1,\n      arranger: -1,\n      copies: -1,\n      catalogId: -1,\n      duration: -1,\n      notes: -1,\n      purchaseDate: -1,\n    });\n    setMappedPieces([]);\n    setErrorsList([]);\n  };\n\n  const handleModalClose = () => {\n    handleReset();\n    onClose();\n  };\n\n  // Renders different footer buttons based on step\n  const renderFooter = () => {\n    switch (step) {\n      case 'UPLOAD':\n        return (\n          <>\n            <button onClick={handleModalClose} className=\"btn btn-ghost\">Cancel</button>\n          </>\n        );\n      case 'MAP':\n        return (\n          <>\n            <button onClick={handleReset} className=\"btn btn-ghost mr-auto\">Restart</button>\n            <button onClick={() => setStep('UPLOAD')} className=\"btn btn-ghost\">Back</button>\n            <button onClick={handleApplyMapping} className=\"btn btn-primary\">Preview & Validate</button>\n          </>\n        );\n      case 'PREVIEW':\n        return (\n          <>\n            <button onClick={() => setStep('MAP')} className=\"btn btn-ghost\">Back</button>\n            <button onClick={handleStartImport} className=\"btn btn-primary\">Confirm & Import</button>\n          </>\n        );\n      case 'IMPORTING':\n        return null; // Don't allow closing/modifying during live import\n      case 'COMPLETE':\n        return (\n          <>\n            <button onClick={handleModalClose} className=\"btn btn-primary\">Done</button>\n          </>\n        );\n    }\n  };\n\n  const fieldsConfig: { key: MusicField; label: string; desc: string; required?: boolean }[] = [\n    { key: 'title', label: 'Title', desc: 'Title of the piece', required: true },\n    { key: 'composer', label: 'Composer', desc: 'Who composed the piece (can also parse combined composer/arranger if arranger column skipped)' },\n    { key: 'arranger', label: 'Arranger', desc: 'Who arranged the piece (if separate column)' },\n    { key: 'copies', label: 'Copies count', desc: 'Number of copies in the library' },\n    { key: 'catalogId', label: 'Catalog ID', desc: 'Library unique identifier' },\n    { key: 'duration', label: 'Duration', desc: 'e.g. 3:30 or 15m' },\n    { key: 'notes', label: 'Notes', desc: 'Additional details or performances info' },\n    { key: 'purchaseDate', label: 'Purchase Date', desc: 'e.g. 2026-05, MM/YYYY, or May 2026' },\n  ];\n\n  return (\n    <BaseModal\n      isOpen={isOpen}\n      onClose={step === 'IMPORTING' ? () => undefined : handleModalClose}\n      title={\n        step === 'UPLOAD' ? 'Import Music Pieces via CSV' :\n        step === 'MAP' ? 'Map CSV Columns' :\n        step === 'PREVIEW' ? 'Preview & Validation' :\n        step === 'IMPORTING' ? 'Importing Music...' :\n        'Import Completed'\n      }\n      footer={renderFooter()}\n      maxWidth={step === 'PREVIEW' || step === 'COMPLETE' ? '800px' : '520px'}\n    >\n      {/* STEP 1: UPLOAD */}\n      {step === 'UPLOAD' && (\n        <div className=\"flex flex-col gap-[var(--space-md)] text-center py-5\">\n          <p className=\"text-muted text-sm !m-0\">\n            Upload a CSV file containing your music repertoire to bootstrap the process.\n          </p>\n\n          <div \n            onClick={() => fileInputRef.current?.click()}\n            className=\"border-2 border-dashed border-[var(--border)] rounded-[var(--radius-lg)] py-10 px-5 cursor-pointer bg-[rgb(74_124_89_/_2%)] hover:border-[var(--primary)] hover:bg-[rgb(74_124_89_/_5%)] flex flex-col items-center justify-center gap-3\"\n          >\n            <span className=\"text-[3rem]\">🎼</span>\n            <div>\n              <strong className=\"text-[var(--primary-deep)] block text-base font-bold\">\n                Select a CSV file to upload\n              </strong>\n              <span className=\"text-muted text-xs block mt-1\">\n                or drag & drop it here\n              </span>\n            </div>\n            <input \n              type=\"file\" \n              accept=\".csv\" \n              ref={fileInputRef} \n              onChange={handleFileUpload} \n              className=\"hidden\" \n            />\n          </div>\n\n          <div className=\"flex gap-2 items-center justify-center text-[0.8rem] text-[var(--text-muted)]\">\n            <span>💡</span>\n            <span>The importer will automatically try to match column headers for you!</span>\n          </div>\n        </div>\n      )}\n\n      {/* STEP 2: FIELD MAPPING */}\n      {step === 'MAP' && csvData && (\n        <div className=\"flex flex-col gap-[var(--space-md)]\">\n          <p className=\"text-muted text-sm !m-0\">\n            Align the columns in your CSV with our music library database fields. Smart auto-matches have been pre-selected.\n          </p>\n\n          <div className=\"flex flex-col gap-[var(--space-sm)] max-h-[350px] overflow-y-auto pr-1\">\n            {fieldsConfig.map(field => {\n              const selectedIndex = mapping[field.key];\n              const isRequiredMissing = field.required && selectedIndex === -1;\n              \n              return (\n                <div \n                  key={field.key} \n                  className={`card !p-[12px_16px] flex flex-row items-center justify-between gap-3 ${isRequiredMissing ? 'border-[var(--red-light)]' : ''}`}\n                >\n                  <div className=\"flex flex-col gap-[2px] flex-1\">\n                    <div className=\"flex items-center gap-[6px]\">\n                      <strong className=\"text-[0.9rem] text-[var(--text)]\">{field.label}</strong>\n                      {field.required && (\n                        <span className=\"text-[0.7rem] bg-[rgb(153_27_27_/_10%)] text-[#991b1b] px-[6px] py-[1px] rounded font-semibold\">\n                          Required\n                        </span>\n                      )}\n                    </div>\n                    <span className=\"text-muted text-xs\">{field.desc}</span>\n                  </div>\n\n                  <select\n                    value={selectedIndex}\n                    onChange={(e) => handleMappingChange(field.key, parseInt(e.target.value))}\n                    className={`card w-[200px] h-[38px] px-[10px] text-[0.85rem] shadow-none ${selectedIndex !== -1 ? '!border-[var(--primary)]' : ''}`}\n                  >\n                    <option value={-1}>-- Skip / Do Not Map --</option>\n                    {csvData.headers.map((hdr: string, idx: number) => (\n                      <option key={idx} value={idx}>\n                        Column: \"{hdr}\"\n                      </option>\n                    ))}\n                  </select>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n      )}\n\n      {/* STEP 3: PREVIEW & VALIDATION */}\n      {step === 'PREVIEW' && (\n        <div className=\"flex flex-col gap-[var(--space-md)]\">\n          <div className=\"flex justify-between items-center\">\n            <p className=\"text-muted text-sm !m-0\">\n              Verify parsed music piece details and resolve validation warnings or errors before importing.\n            </p>\n            <div className=\"flex gap-3\">\n              <span className=\"text-xs card !p-[4px_8px] bg-[rgb(74_124_89_/_5%)] text-[var(--primary-deep)] font-semibold\">\n                Total Mapped: {mappedPieces.length}\n              </span>\n              <span className=\"text-xs card !p-[4px_8px] bg-[rgb(153_27_27_/_5%)] text-[#991b1b] font-semibold\">\n                Errors: {mappedPieces.filter(p => !p.isValid).length}\n              </span>\n            </div>\n          </div>\n\n          <div className=\"overflow-x-auto border border-[var(--border)] rounded-[var(--radius-md)] max-h-[350px]\">\n            <table className=\"table w-full min-w-[600px] !m-0\">\n              <thead className=\"sticky top-0 bg-[var(--bg)] z-[1] shadow-[0_1px_0_var(--border)]\">\n                <tr>\n                  <th className=\"w-[60px] text-center text-[var(--text-muted)] text-[0.8rem]\">Row</th>\n                  <th>Title</th>\n                  <th>Composer</th>\n                  <th>Arranger</th>\n                  <th className=\"w-20 text-center\">Copies</th>\n                  <th className=\"w-[100px]\">Catalog ID</th>\n                  <th>Status / Errors</th>\n                </tr>\n              </thead>\n              <tbody>\n                {mappedPieces.map((piece, idx) => {\n                  const hasErrors = !piece.isValid;\n                  const hasWarnings = piece.warnings.length > 0;\n                  \n                  return (\n                    <tr \n                      key={idx} \n                      // @allow-inline-style - conditional error/warning background\n                      style={{ \n                        backgroundColor: hasErrors ? 'rgba(239, 83, 80, 0.05)' : hasWarnings ? 'rgba(255, 202, 40, 0.04)' : undefined \n                      }}\n                    >\n                      <td className=\"w-[60px] text-center text-[var(--text-muted)] text-[0.8rem]\">\n                        {piece.rowNumber}\n                      </td>\n                      <td>\n                        <strong className={hasErrors ? 'text-[#c62828]' : ''}>\n                          {piece.data.title || '(Empty Title)'}\n                        </strong>\n                      </td>\n                      <td className=\"text-[0.85rem]\">{piece.data.composer || '-'}</td>\n                      <td className=\"text-[0.85rem]\">{piece.data.arranger || '-'}</td>\n                      <td className=\"w-20 text-center\">\n                        <span className=\"text-xs font-semibold\">\n                          {piece.data.copies !== undefined ? piece.data.copies : '-'}\n                        </span>\n                      </td>\n                      <td>\n                        <span className=\"text-xs card !p-[2px_6px] inline-block\">\n                          {piece.data.catalogId || '-'}\n                        </span>\n                      </td>\n                      <td>\n                        {hasErrors && (\n                          <div className=\"text-[#c62828] text-[0.8rem] flex flex-col gap-[2px]\">\n                            {piece.errors.map((e, i) => <span key={i}>❌ {e}</span>)}\n                          </div>\n                        )}\n                        {hasWarnings && (\n                          <div className=\"text-[#b78103] text-[0.8rem] flex flex-col gap-[2px]\">\n                            {piece.warnings.map((w, i) => <span key={i}>⚠️ {w}</span>)}\n                          </div>\n                        )}\n                        {!hasErrors && !hasWarnings && (\n                          <span className=\"text-[var(--primary-deep)] text-[0.8rem]\">Ready</span>\n                        )}\n                      </td>\n                    </tr>\n                  );\n                })}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n\n      {/* STEP 4: IMPORTING PROGRESS */}\n      {step === 'IMPORTING' && (\n        <div className=\"flex flex-col gap-[var(--space-md)] py-5 items-center\">\n          <span className=\"text-[3rem] animate-[spin_2s_linear_infinite]\">⚙️</span>\n          \n          <div className=\"flex flex-col gap-[6px] w-full items-center\">\n            <strong className=\"text-[1.1rem] text-[var(--text)]\">\n              Importing {mappedPieces.filter(p => p.isValid).length} Pieces...\n            </strong>\n            <span className=\"text-muted text-sm\">\n              Processing row {importingIndex} of {mappedPieces.length}\n            </span>\n          </div>\n\n          <div className=\"w-full h-3 bg-[var(--border)] rounded-[6px] overflow-hidden mt-[10px]\">\n            <div \n              className=\"h-full bg-[var(--primary)] transition-[width_0.1s_ease-out]\"\n              // @allow-inline-style - dynamic progress bar width\n              style={{ \n                width: `${importProgress}%`,\n              }}\n            />\n          </div>\n\n          <div className=\"flex gap-5 text-[0.9rem] text-[var(--text-muted)]\">\n            <span>Successes: <strong className=\"text-[var(--primary-deep)]\">{successCount}</strong></span>\n            <span>Failures: <strong className={errorsList.length > 0 ? 'text-[#991b1b]' : ''}>{errorsList.length}</strong></span>\n          </div>\n        </div>\n      )}\n\n      {/* STEP 5: IMPORT COMPLETE */}\n      {step === 'COMPLETE' && (\n        <div className=\"flex flex-col gap-[var(--space-lg)] py-[10px_0]\">\n          <div className=\"flex flex-col items-center gap-2 text-center\">\n            <span className=\"text-[3.5rem]\">🎉</span>\n            <h3 className=\"!m-0 text-[1.3rem] text-[var(--primary-deep)]\">Import Finished!</h3>\n            <p className=\"text-muted text-sm !m-0\">\n              Successfully imported <strong>{successCount}</strong> music pieces into your library.\n            </p>\n          </div>\n\n          {errorsList.length > 0 && (\n            <div className=\"flex flex-col gap-[var(--space-xs)]\">\n              <strong className=\"text-[0.9rem] text-[#991b1b]\">\n                ⚠️ Some rows failed to import ({errorsList.length})\n              </strong>\n              <div className=\"max-h-[150px] overflow-y-auto border border-[var(--border)] rounded-[var(--radius-md)] p-[8px_12px] bg-[#fafafa] text-[0.8rem]\">\n                {errorsList.map((err, i) => (\n                  <div key={i} className=\"py-1 text-[#444] border-b border-[var(--border)] last:border-b-0\">\n                    Row {err.row} (<strong>{err.title}</strong>): <span className=\"text-[#991b1b]\">{err.error}</span>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n        </div>\n      )}\n    </BaseModal>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/PlaceholderPanel.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":50,"column":21,"messageId":"issue:unknown-classname","endLine":50,"endColumn":25,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[2859,2979],"text":"p-4 bg-surface border border-border rounded-xl sticky top-6 max-h-[calc(100vh-120px)] flex flex-col gap-4 shadow-sm"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":50,"column":26,"messageId":"fix:sort","endLine":50,"endColumn":29,"fix":{"range":[2859,2979],"text":"card sticky top-6 flex max-h-[calc(100vh-120px)] flex-col gap-4 rounded-xl border border-border bg-surface p-4 shadow-sm"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":50,"column":30,"messageId":"fix:sort","endLine":50,"endColumn":40},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":50,"column":41,"messageId":"fix:sort","endLine":50,"endColumn":47},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line"