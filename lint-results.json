assnames order","line":253,"column":118,"messageId":"fix:sort","endLine":253,"endColumn":128},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":253,"column":129,"messageId":"fix:sort","endLine":253,"endColumn":144},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":253,"column":163,"messageId":"fix:sort","endLine":253,"endColumn":172},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":253,"column":173,"messageId":"fix:sort","endLine":253,"endColumn":187},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":253,"column":188,"messageId":"fix:sort","endLine":253,"endColumn":202},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":26,"messageId":"fix:sort","endLine":273,"endColumn":30,"fix":{"range":[11791,11885],"text":"`mt-0 grid grid-cols-3 gap-4 overflow-hidden transition-all duration-300 max-sm:grid-cols-1 ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":31,"messageId":"fix:sort","endLine":273,"endColumn":42},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":43,"messageId":"fix:sort","endLine":273,"endColumn":48},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":49,"messageId":"fix:sort","endLine":273,"endColumn":64},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":65,"messageId":"fix:sort","endLine":273,"endColumn":79},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":80,"messageId":"fix:sort","endLine":273,"endColumn":92},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":93,"messageId":"fix:sort","endLine":273,"endColumn":97},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":132,"messageId":"fix:sort","endLine":273,"endColumn":145,"fix":{"range":[11898,11981],"text":"mt-3 max-h-[200px] rounded-lg border border-border bg-primary-light p-4 opacity-100"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":146,"messageId":"fix:sort","endLine":273,"endColumn":157},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":158,"messageId":"fix:sort","endLine":273,"endColumn":162},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":163,"messageId":"fix:sort","endLine":273,"endColumn":166},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":167,"messageId":"fix:sort","endLine":273,"endColumn":183},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":184,"messageId":"fix:sort","endLine":273,"endColumn":194},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":195,"messageId":"fix:sort","endLine":273,"endColumn":201},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":202,"messageId":"fix:sort","endLine":273,"endColumn":215},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":275,"column":48,"messageId":"fix:sort","endLine":275,"endColumn":57,"fix":{"range":[12086,12138],"text":"text-xs font-bold tracking-wider text-text uppercase"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":275,"column":58,"messageId":"fix:sort","endLine":275,"endColumn":72},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":275,"column":73,"messageId":"fix:sort","endLine":275,"endColumn":82},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":276,"column":38,"messageId":"fix:sort","endLine":276,"endColumn":53,"fix":{"range":[12185,12224],"text":"text-xs leading-relaxed text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":276,"column":54,"messageId":"fix:sort","endLine":276,"endColumn":69},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":279,"column":48,"messageId":"fix:sort","endLine":279,"endColumn":57,"fix":{"range":[12395,12447],"text":"text-xs font-bold tracking-wider text-text uppercase"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":279,"column":58,"messageId":"fix:sort","endLine":279,"endColumn":72},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":279,"column":73,"messageId":"fix:sort","endLine":279,"endColumn":82},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":280,"column":38,"messageId":"fix:sort","endLine":280,"endColumn":53,"fix":{"range":[12489,12528],"text":"text-xs leading-relaxed text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":280,"column":54,"messageId":"fix:sort","endLine":280,"endColumn":69},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":283,"column":48,"messageId":"fix:sort","endLine":283,"endColumn":57,"fix":{"range":[12679,12731],"text":"text-xs font-bold tracking-wider text-text uppercase"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":283,"column":58,"messageId":"fix:sort","endLine":283,"endColumn":72},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":283,"column":73,"messageId":"fix:sort","endLine":283,"endColumn":82},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":284,"column":38,"messageId":"fix:sort","endLine":284,"endColumn":53,"fix":{"range":[12776,12815],"text":"text-xs leading-relaxed text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":284,"column":54,"messageId":"fix:sort","endLine":284,"endColumn":69}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":251,"fixableErrorCount":0,"fixableWarningCount":45,"source":"import React from 'react';\nimport type { PlayerMediaFile } from '../../services/playerService';\nimport { useAudioPlayback } from '../../hooks/useAudioPlayback';\nimport {\n  PlayIcon,\n  PauseIcon,\n  SkipNextIcon,\n  SkipPreviousIcon,\n  RepeatIcon,\n  RepeatOneIcon,\n} from './PlayerIcons';\n\ninterface PlayerProps {\n  playlist: PlayerMediaFile[];\n  currentIndex: number;\n  onTrackChange: (index: number) => void;\n  isPlaying: boolean;\n  setIsPlaying: (playing: boolean) => void;\n  offlineMode?: boolean;\n  selectedVoicePart?: string;\n}\n\nexport const Player: React.FC<PlayerProps> = ({ \n  playlist, \n  currentIndex, \n  onTrackChange,\n  isPlaying,\n  setIsPlaying,\n  offlineMode = false,\n  selectedVoicePart,\n}) => {\n  const {\n    loopMode,\n    currentTime,\n    duration,\n    volume,\n    audioRef,\n    playError,\n    delaySetting,\n    countdown,\n    skipStart,\n    showSkipNotify,\n    showHints,\n    currentTrack,\n    isDownloadNeeded,\n    togglePlay,\n    handleEnded,\n    handleTimeUpdate,\n    handleLoadedMetadata,\n    handleSeekStart,\n    handleSeekChange,\n    handleSeekEnd,\n    handleVolumeChange,\n    handleSkipStartChange,\n    toggleHints,\n    setDelaySetting,\n    setShowSkipNotify,\n    handleAudioError,\n    cycleLoopMode,\n    getRepeatLabel,\n    handlePrev,\n    handleNext,\n    firstAudioIndex,\n  } = useAudioPlayback({\n    playlist,\n    currentIndex,\n    onTrackChange,\n    isPlaying,\n    setIsPlaying,\n    offlineMode,\n  });\n\n  const formatTime = (time: number) => {\n    const mins = Math.floor(time / 60);\n    const secs = Math.floor(time % 60);\n    return `${mins}:${secs.toString().padStart(2, '0')}`;\n  };\n\n  if (!currentTrack) return <div className=\"text-center py-12 px-4 text-text-muted text-base\">No track selected</div>;\n\n  // Voice part badge logic\n  const activeKey = currentTrack.trackKey || 'tutti';\n  const isFallback = selectedVoicePart && selectedVoicePart !== 'tutti' && activeKey === 'tutti';\n  const badgeLabel = activeKey.toUpperCase();\n\n  // Inline gradient fill for sliders (cross-browser filled-track)\n  const seekPct = duration > 0 ? (currentTime / duration) * 100 : 0;\n  const seekStyle = {\n    background: `linear-gradient(to right, var(--accent-color) ${seekPct}%, var(--border-color) ${seekPct}%)`\n  };\n  const volPct = volume * 100;\n  const volStyle = {\n    background: `linear-gradient(to right, var(--accent-color) ${volPct}%, var(--border-color) ${volPct}%)`\n  };\n\n  const ctrlBtnBase = 'bg-primary-light border border-border text-text w-12 h-12 p-0 rounded-lg cursor-pointer transition-all flex items-center justify-center shadow-sm hover:bg-border hover:shadow-md hover:-translate-y-0.5 disabled:opacity-35 disabled:cursor-default active:opacity-35 max-sm:w-10 max-sm:h-10';\n\n  return (\n    <div className=\"bg-surface border border-border rounded-xl shadow-md p-6 mb-6 transition-all duration-300 max-sm:p-5 max-sm:px-4 max-sm:rounded-lg\">\n      <div className=\"flex flex-col\">\n        {currentTrack.parentTitle && (\n          <span className=\"text-xs text-text-muted uppercase tracking-wider font-bold mb-1 block\">\n            From: {currentTrack.parentTitle}\n          </span>\n        )}\n        <div className=\"flex items-center gap-2 mb-5 min-w-0\">\n          <h2 className=\"text-xl font-bold m-0 text-text truncate flex-1 min-w-0 tracking-tight\">{currentTrack.name}</h2>\n          <span className={`shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold tracking-wide uppercase ${isFallback ? 'bg-amber-50 text-amber-600 border border-amber-300' : 'bg-primary-light text-primary border border-primary'}`}>\n            {badgeLabel}\n          </span>\n        </div>\n        <audio \n          ref={audioRef} \n          src={currentTrack.offlineUrl || currentTrack.streamUrl} \n          preload=\"auto\"\n          autoPlay={isPlaying && !isDownloadNeeded}\n          onEnded={handleEnded}\n          onTimeUpdate={handleTimeUpdate}\n          onLoadedMetadata={handleLoadedMetadata}\n          onError={handleAudioError}\n        />\n        \n        {playError && <div className=\"bg-danger-bg border border-red-200 text-danger-text rounded-lg p-3 px-4 text-sm mb-4\">{playError}</div>}\n        \n        {/* COUNTDOWN OVERLAY */}\n        {countdown !== null && (\n          <div className=\"flex items-center justify-center gap-3 p-3 px-4 mb-4 rounded-lg bg-primary-light border border-primary text-primary text-sm font-semibold animate-pulse\">\n            <span>Next track starting in {countdown}s...</span>\n            <button \n              onClick={togglePlay} \n              className=\"px-3 py-1.5 rounded-lg border-none bg-primary text-surface text-xs font-semibold cursor-pointer uppercase tracking-wider transition-colors hover:bg-primary-deep\"\n            >\n              Skip Wait\n            </button>\n          </div>\n        )}\n\n        {/* SKIP NOTIFICATION */}\n        {showSkipNotify && (\n          // @allow-inline-style - active part badge state\n          <div className=\"flex items-center justify-center gap-3 p-3 px-4 mb-4 rounded-lg text-sm font-semibold\" style={{ background: 'var(--hover-bg)', borderColor: 'var(--border-color)', color: 'var(--text-secondary)' }}>\n            <span>Skipped first {skipStart}s of track</span>\n            {/* @allow-inline-style - inactive part badge state */}\n            <button onClick={() => setShowSkipNotify(false)} className=\"px-3 py-1.5 rounded-lg border-none text-xs font-semibold cursor-pointer uppercase tracking-wider transition-colors\" style={{ background: 'var(--border-color)', color: 'var(--text-primary)' }}>Dismiss</button>\n          </div>\n        )}\n\n        <div className=\"flex items-center gap-4 mb-6 text-sm text-text-muted tabular-nums\">\n          <span>{formatTime(currentTime)}</span>\n          <input \n            type=\"range\" \n            min=\"0\" \n            max={duration || 0} \n            step=\"0.1\"\n            value={currentTime} \n            onMouseDown={handleSeekStart}\n            onTouchStart={handleSeekStart}\n            onChange={handleSeekChange} \n            onMouseUp={handleSeekEnd}\n            onTouchEnd={handleSeekEnd}\n            className=\"flex-1 h-1.5 appearance-none rounded-full outline-none cursor-pointer bg-border\"\n            style={seekStyle}\n          />\n          <span>{formatTime(duration)}</span>\n        </div>\n\n        <div className=\"grid grid-cols-[1fr_auto_1fr] items-center mb-6 w-full\">\n          <div className=\"min-w-0\"></div>\n          <div className=\"flex justify-center items-center gap-4\">\n            <button \n              onClick={handlePrev} \n              disabled={currentIndex === firstAudioIndex && loopMode !== 'all'}\n              aria-label=\"Previous\"\n              className={ctrlBtnBase}\n            >\n              <SkipPreviousIcon />\n            </button>\n            <button \n              className=\"bg-text text-surface w-[72px] h-[72px] shadow-md border-none rounded-xl flex items-center justify-center hover:opacity-95 hover:shadow-lg hover:-translate-y-0.5 disabled:opacity-35 disabled:cursor-default transition-all max-sm:w-[60px] max-sm:h-[60px]\"\n              onClick={togglePlay}\n              disabled={isDownloadNeeded}\n              aria-label={isPlaying ? 'Pause' : 'Play'}\n            >\n              {isPlaying ? <PauseIcon /> : <PlayIcon />}\n            </button>\n            <button \n              onClick={handleNext} \n              disabled={currentIndex >= playlist.length - 1 && loopMode !== 'all'}\n              aria-label=\"Next\"\n              className={ctrlBtnBase}\n            >\n              <SkipNextIcon />\n            </button>\n          </div>\n          <div className=\"flex justify-end\">\n            <button onClick={cycleLoopMode} className={`flex items-center gap-1.5 text-xs font-bold whitespace-nowrap uppercase tracking-wider rounded-full transition-all h-11 px-3.5 max-sm:w-10 max-sm:h-10 max-sm:p-0 max-sm:rounded-full max-sm:justify-center ${loopMode === 'all' || loopMode === 'one' ? 'bg-primary border-primary text-surface hover:bg-primary-deep hover:border-primary-deep' : 'bg-primary-light border border-border text-text-muted hover:bg-border hover:text-text'} max-sm:[&_span]:hidden`}>\n              {loopMode === 'one' ? <RepeatOneIcon /> : <RepeatIcon />}\n              <span>{getRepeatLabel()}</span>\n            </button>\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-4 flex-wrap py-4 border-t border-border mb-2 max-sm:flex-wrap max-sm:justify-between max-sm:items-center max-sm:gap-3\">\n          {/* START AT SETTING */}\n          <div className=\"flex items-center gap-1.5\">\n            <label htmlFor=\"skip-input\" className=\"text-xs font-bold uppercase tracking-wider text-text-muted whitespace-nowrap\">Start At:</label>\n            <input \n              id=\"skip-input\"\n              type=\"number\" \n              min=\"0\"\n              step=\"0.1\"\n              value={skipStart || ''} \n              onChange={handleSkipStartChange}\n              placeholder=\"0\"\n              className=\"w-14 px-2 py-1.5 rounded-lg border border-border bg-primary-light text-text text-sm font-semibold text-center tabular-nums outline-none focus:border-primary appearance-none [-moz-appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none\"\n            />\n            <span className=\"text-xs font-bold uppercase tracking-wider text-text-muted\">s</span>\n          </div>\n\n          <div className=\"flex items-center gap-4 flex-1 min-w-[120px] max-sm:hidden touch:hidden\">\n            <label htmlFor=\"volume-input\" className=\"text-xs font-bold uppercase tracking-wider text-text-muted whitespace-nowrap\">Volume</label>\n            <input \n              id=\"volume-input\"\n              type=\"range\" \n              min=\"0\" \n              max=\"1\" \n              step=\"0.01\" \n              value={volume} \n              onChange={handleVolumeChange}\n              className=\"flex-1 min-w-[80px] h-1 appearance-none rounded-full outline-none cursor-pointer bg-border\"\n              style={volStyle}\n            />\n          </div>\n          \n          {/* INTER-TRACK GAP SETTING */}\n          <div className=\"flex items-center gap-1.5\">\n            <label htmlFor=\"delay-select\" className=\"text-xs font-bold uppercase tracking-wider text-text-muted whitespace-nowrap\">Gap:</label>\n            <select \n              id=\"delay-select\"\n              value={delaySetting} \n              onChange={(e) => setDelaySetting(Number(e.target.value))}\n              className=\"px-2 py-1.5 rounded-lg border border-border bg-primary-light text-text text-sm font-semibold cursor-pointer outline-none focus:border-primary\"\n            >\n              <option value={0}>None</option>\n              <option value={2}>2s</option>\n              <option value={5}>5s</option>\n              <option value={10}>10s</option>\n            </select>\n          </div>\n        </div>\n\n        <button \n          className=\"inline-flex items-center justify-center gap-1.5 w-full py-2 bg-transparent border border-border rounded-lg text-text-muted text-xs font-bold uppercase tracking-wider cursor-pointer transition-all hover:bg-primary-light hover:text-text\"\n          onClick={toggleHints}\n          aria-expanded={showHints}\n        >\n          <svg \n            width=\"12\" \n            height=\"12\" \n            viewBox=\"0 0 24 24\" \n            fill=\"none\" \n            stroke=\"currentColor\" \n            strokeWidth=\"2.5\" \n            strokeLinecap=\"round\" \n            strokeLinejoin=\"round\"\n            className={`transition-transform duration-300 ${showHints ? 'rotate-180' : ''}`}\n          >\n            <polyline points=\"6 9 12 15 18 9\"></polyline>\n          </svg>\n          <span>{showHints ? 'Hide Control Guide' : 'Control Guide'}</span>\n        </button>\n\n        <div className={`grid grid-cols-3 gap-4 overflow-hidden transition-all duration-300 mt-0 max-sm:grid-cols-1 ${showHints ? 'max-h-[200px] opacity-100 mt-3 p-4 bg-primary-light rounded-lg border border-border' : 'max-h-0 opacity-0'}`}>\n          <div className=\"flex flex-col gap-1\">\n            <span className=\"text-xs font-bold uppercase tracking-wider text-text\">Start At</span>\n            <span className=\"text-xs text-text-muted leading-relaxed\">Skips the intro for this specific track; saved for future sessions.</span>\n          </div>\n          <div className=\"flex flex-col gap-1\">\n            <span className=\"text-xs font-bold uppercase tracking-wider text-text\">Gap</span>\n            <span className=\"text-xs text-text-muted leading-relaxed\">Adds a timed silence between consecutive songs.</span>\n          </div>\n          <div className=\"flex flex-col gap-1\">\n            <span className=\"text-xs font-bold uppercase tracking-wider text-text\">Repeat</span>\n            <span className=\"text-xs text-text-muted leading-relaxed\">Controls if the playlist stops, loops, or restarts.</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/player/PlayerIcons.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/player/Playlist.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":51,"column":31,"messageId":"fix:sort","endLine":51,"endColumn":43,"fix":{"range":[1459,1491],"text":"flex shrink-0 items-center gap-1"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":51,"column":44,"messageId":"fix:sort","endLine":51,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":51,"column":50,"messageId":"fix:sort","endLine":51,"endColumn":58},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'progress-ring__circle-bg' is not a Tailwind CSS class","line":54,"column":26,"messageId":"issue:unknown-classname","endLine":54,"endColumn":50,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"progress-ring__circle-bg"},"fix":{"range":[1652,1676],"text":""},"desc":"Remove unknown classname 'progress-ring__circle-bg'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity"