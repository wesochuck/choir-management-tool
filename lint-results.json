essageId":"fix:sort","endLine":80,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":80,"column":60,"messageId":"fix:sort","endLine":80,"endColumn":73},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":80,"column":74,"messageId":"fix:sort","endLine":80,"endColumn":78},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":80,"column":79,"messageId":"fix:sort","endLine":80,"endColumn":82},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":80,"column":83,"messageId":"fix:sort","endLine":80,"endColumn":94},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":85,"column":27,"messageId":"fix:sort","endLine":85,"endColumn":33,"fix":{"range":[3722,3757],"text":"bg-neutral-bg w-full rounded-lg p-4"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":85,"column":34,"messageId":"fix:sort","endLine":85,"endColumn":37},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":85,"column":38,"messageId":"fix:sort","endLine":85,"endColumn":51},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'bg-neutral-bg' is not a Tailwind CSS class","line":85,"column":38,"messageId":"issue:unknown-classname","endLine":85,"endColumn":51,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"bg-neutral-bg"},"fix":{"range":[3722,3757],"text":"w-full p-4 rounded-lg"},"desc":"Remove unknown classname 'bg-neutral-bg'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":85,"column":52,"messageId":"fix:sort","endLine":85,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":86,"column":27,"messageId":"fix:sort","endLine":86,"endColumn":42,"fix":{"range":[3786,3813],"text":"m-0 text-sm text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":86,"column":51,"messageId":"fix:sort","endLine":86,"endColumn":54},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":92,"column":70,"messageId":"fix:sort","endLine":92,"endColumn":82,"fix":{"range":[4024,4043],"text":"w-full no-underline"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":92,"column":83,"messageId":"fix:sort","endLine":92,"endColumn":89}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":58,"fixableErrorCount":0,"fixableWarningCount":16,"source":"import { useEffect, useState } from 'react';\nimport { useSearchParams, Link } from 'react-router-dom';\nimport { donationService, type DonationRecord } from '../services/donationService';\nimport { AppCard } from '../components/common/AppCard';\nimport { Button } from '../components/ui/Button/Button';\nimport { Spinner } from '../components/ui/Spinner/Spinner';\nimport { useDocumentTitle } from '../hooks/useDocumentTitle';\n\nexport default function PublicDonationSuccessView() {\n  useDocumentTitle('Donation Confirmation');\n  const [searchParams] = useSearchParams();\n  const sessionId = searchParams.get('session_id') || '';\n  const [loading, setLoading] = useState(true);\n  const [donation, setDonation] = useState<DonationRecord | null>(null);\n\n  useEffect(() => {\n    async function verifyDonation() {\n      if (!sessionId) {\n        setLoading(false);\n        return;\n      }\n      try {\n        const record = await donationService.pollForDonationRecord(sessionId);\n        setDonation(record);\n      } catch (err) {\n        console.error(\"Verification failed\", err);\n      } finally {\n        setLoading(false);\n      }\n    }\n    verifyDonation();\n  }, [sessionId]);\n\n  if (loading) {\n    return (\n      <div className=\"flex flex-col min-h-screen justify-center items-center w-screen\">\n        <AppCard className=\"w-full max-w-[480px] text-center items-center\">\n          <h2 className=\"m-0\">Verifying Donation...</h2>\n          <Spinner size=\"medium\" />\n          <p className=\"text-text-muted text-sm\">Please wait while we confirm your contribution.</p>\n          <div className=\"w-10 h-10 border-4 border-border border-t-primary rounded-full animate-spin\" />\n        </AppCard>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"flex flex-col min-h-screen justify-center items-center w-screen p-4\">\n      <AppCard className=\"w-full max-w-[480px] text-center items-center gap-4\">\n        <div className=\"text-6xl text-success-text\">♥</div>\n        <h1 className=\"text-display m-0\">Thank You!</h1>\n        <p className=\"text-text-muted m-0\">\n          We have successfully processed your donation.\n        </p>\n\n        {donation ? (\n          <div className=\"card w-full p-4 flex flex-col gap-1 bg-neutral-bg text-left\">\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span className=\"text-text-muted\">Transaction ID:</span>\n              <strong>{donation.id}</strong>\n            </div>\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span className=\"text-text-muted\">Donor Name:</span>\n              <strong>{donation.donorName}</strong>\n            </div>\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span className=\"text-text-muted\">Donor Email:</span>\n              <strong>{donation.donorEmail}</strong>\n            </div>\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span className=\"text-text-muted\">Amount Contributed:</span>\n              <strong>${(donation.amountPaidCents / 100).toFixed(2)}</strong>\n            </div>\n            {donation.tributeType !== 'none' && (\n              <div className=\"border-t border-border pt-1 mt-1 flex flex-col gap-1\">\n                <span className=\"text-text-muted text-xs\">Tribute</span>\n                <strong>{donation.tributeType === 'memory' ? 'In Memory of' : 'In Honor of'} {donation.tributeName}</strong>\n              </div>\n            )}\n            <p className=\"text-xs text-text-muted border-t border-border pt-1 m-0 text-center\">\n              We are sending your receipt to your email now. You can safely close this page.\n            </p>\n          </div>\n        ) : (\n          <div className=\"w-full p-4 bg-neutral-bg rounded-lg\">\n            <p className=\"text-text-muted text-sm m-0\">\n              We are sending your receipt to your email now. You can safely close this page.\n            </p>\n          </div>\n        )}\n\n        <Button as={Link} to=\"/tickets\" variant=\"primary\" className=\"no-underline w-full\">\n          Back to Concerts\n        </Button>\n      </AppCard>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/PublicDonationView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":93,"column":28,"messageId":"fix:sort","endLine":93,"endColumn":36,"fix":{"range":[2962,3025],"text":"flex min-h-screen w-screen flex-col items-center justify-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":93,"column":37,"messageId":"fix:sort","endLine":93,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":93,"column":50,"messageId":"fix:sort","endLine":93,"endColumn":64},{"ruleId":"t