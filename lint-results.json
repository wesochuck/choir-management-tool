69,"column":107,"messageId":"fix:sort","endLine":269,"endColumn":114},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":269,"column":115,"messageId":"fix:sort","endLine":269,"endColumn":122},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":269,"column":123,"messageId":"fix:sort","endLine":269,"endColumn":136},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":269,"column":137,"messageId":"fix:sort","endLine":269,"endColumn":146},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":269,"column":162,"messageId":"fix:sort","endLine":269,"endColumn":174},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":269,"column":175,"messageId":"fix:sort","endLine":269,"endColumn":191},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":42,"messageId":"fix:sort","endLine":273,"endColumn":45,"fix":{"range":[11294,11332],"text":"border-b border-border p-4 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":46,"messageId":"fix:sort","endLine":273,"endColumn":54},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":273,"column":55,"messageId":"fix:sort","endLine":273,"endColumn":68},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":274,"column":42,"messageId":"fix:sort","endLine":274,"endColumn":45,"fix":{"range":[11426,11464],"text":"border-b border-border p-4 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":274,"column":46,"messageId":"fix: