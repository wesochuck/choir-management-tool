:1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":57,"messageId":"fix:sort","endLine":201,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":202,"column":33,"messageId":"fix:sort","endLine":202,"endColumn":39,"fix":{"range":[9102,9128],"text":"flex flex-1 flex-col gap-1"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":202,"column":33,"messageId":"fix:sort","endLine":202,"endColumn":37},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-label' is not a Tailwind CSS class","line":203,"column":37,"messageId":"issue:unknown-classname","endLine":203,"endColumn":47,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-label"},"fix":{"range":[9167,9177],"text":""},"desc":"Remove unknown classname 'text-label'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":204,"column":38,"messageId":"issue:unknown-classname","endLine":204,"endColumn":42,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[9235,9249],"text":"px-3 h-11"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":204,"column":43,"messageId":"fix:sort","endLine":204,"endColumn":47,"fix":{"range":[9235,9249],"text":"card h-11 px-3"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":204,"column":48,"messageId":"fix:sort","endLine":204,"endColumn":52},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-label' is not a Tailwind CSS class","line":213,"column":35,"messageId":"issue:unknown-classname","endLine":213,"endColumn":45,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-label"},"fix":{"range":[9681,9691],"text":""},"desc":"Remove unknown classname 'text-label'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":214,"column":33,"messageId":"fix:sort","endLine":214,"endColumn":37,"fix":{"range":[9782,9890],"text":"bg-neutral-bg grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-3 rounded-lg border border-border p-4"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":214,"column":38,"messageId":"fix:sort","endLine":214,"endColumn":85},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":214,"column":86,"messageId":"fix:sort","endLine":214,"endColumn":91},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":214,"column":92,"messageId":"fix:sort","endLine":214,"endColumn":105},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'bg-neutral-bg' is not a Tailwind CSS class","line":214,"column":92,"messageId":"issue:unknown-classname","endLine":214,"endColumn":105,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"bg-neutral-bg"},"fix":{"range":[9782,9890],"text":"grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-3 p-4 rounded-lg border border-border"},"desc":"Remove unknown classname 'bg-neutral-bg'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":214,"column":106,"messageId":"fix:sort","endLine":214,"endColumn":109},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":214,"column":110,"messageId":"fix:sort","endLine":214,"endColumn":120},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":214,"column":121,"messageId":"fix:sort","endLine":214,"endColumn":127},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":214,"column":128,"messageId":"fix:sort","endLine":214,"endColumn":141},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":220,"column":42,"messageId":"fix:sort","endLine":220,"endColumn":54,"fix":{"range":[10150,10243],"text":"`flex cursor-pointer items-center gap-2.5 rounded-sm border p-3 transition-all select-none ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":220,"column":55,"messageId":"fix:sort","endLine":220,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":220,"column":63,"messageId":"fix:sort","endLine":220,"endColumn":66},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":220,"column":85,"messageId":"fix:sort","endLine":220,"endColumn":99},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":220,"column":100,"messageId":"fix:sort","endLine":220,"endColumn":111},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":220,"column":112,"messageId":"fix:sort","endLine":220,"endColumn":126},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":224,"column":38,"messageId":"fix:sort","endLine":224,"endColumn":46,"fix":{"range":[10466,10513],"text":"h-[18px] w-[18px] cursor-pointer accent-primary"}},{"ruleId":"tailwindcss/enforces-shorthand","severity":1,"message":"'w-[18px]' can be merged with 'h-[18px]' into 'size-[18px]'","line":224,"column":38,"messageId":"fix:use-shorthand","endLine":224,"endColumn":46,"fix":{"range":[10466,10513],"text":"accent-primary cursor-pointer size-[18px]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":224,"column":47,"messageId":"fix:sort","endLine":224,"endColumn":55},{"ruleId":"tailwindcss/enforces-shorthand","severity":1,"message":"'h-[18px]' can be merged with 'w-[18px]' into 'size-[18px]'","line":224,"column":47,"messageId":"fix:use-shorthand","endLine":224,"endColumn":55,"fix":{"range":[10466,10513],"text":"accent-primary cursor-pointer size-[18px]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":224,"column":56,"messageId":"fix:sort","endLine":224,"endColumn":70},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":224,"column":71,"messageId":"fix:sort","endLine":224,"endColumn":85},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":242,"column":38,"messageId":"fix:sort","endLine":242,"endColumn":53,"fix":{"range":[11526,11580],"text":"col-span-full py-3 text-center text-sm text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":242,"column":54,"messageId":"fix:sort","endLine":242,"endColumn":61},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":242,"column":62,"messageId":"fix:sort","endLine":242,"endColumn":75},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":242,"column":76,"messageId":"fix:sort","endLine":242,"endColumn":87},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":242,"column":88,"messageId":"fix:sort","endLine":242,"endColumn":92},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-label' is not a Tailwind CSS class","line":249,"column":35,"messageId":"issue:unknown-classname","endLine":249,"endColumn":45,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-label"},"fix":{"range":[11858,11868],"text":""},"desc":"Remove unknown classname 'text-label'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":251,"column":30,"messageId":"issue:unknown-classname","endLine":251,"endColumn":34,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[11965,11996],"text":"min-h-[120px] p-3 resize-y"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":251,"column":49,"messageId":"fix:sort","endLine":251,"endColumn":52,"fix":{"range":[11965,11996],"text":"card min-h-[120px] resize-y p-3"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":251,"column":53,"messageId":"fix:sort","endLine":251,"endColumn":61},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":256,"column":39,"messageId":"fix:sort","endLine":256,"endColumn":55,"fix":{"range":[12179,12199],"text":"m-0 text-danger-text"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":256,"column":56,"messageId":"fix:sort","endLine":256,"endColumn":59},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":257,"column":34,"messageId":"issue:unknown-classname","endLine":257,"endColumn":37,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[12247,12262],"text":"btn-primary"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-primary' is not a Tailwind CSS class","line":257,"column":38,"messageId":"issue:unknown-classname","endLine":257,"endColumn":49,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-primary"},"fix":{"range":[12247,12262],"text":"btn"},"desc":"Remove unknown classname 'btn-primary'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":107,"fixableErrorCount":0,"fixableWarningCount":23,"source":"import { useEffect, useState } from 'react';\nimport { Link } from 'react-router-dom';\nimport { AppCard } from '../components/common/AppCard';\nimport PublicLogo from '../components/common/PublicLogo';\nimport { auditionService, type Audition } from '../services/auditionService';\nimport { DEFAULT_AUDITION_SETTINGS, settingsService, type AuditionSettings } from '../services/settingsService';\nimport { eventService, type Event } from '../services/eventService';\nimport { useDocumentTitle } from '../hooks/useDocumentTitle';\nimport { useVoiceParts } from '../hooks/useVoiceParts';\nimport { fetchChoirTimezone, formatInTimezone } from '../lib/timezone';\n\nexport default function PublicAuditionView() {\n  useDocumentTitle('Auditions');\n  const [settings, setSettings] = useState<AuditionSettings>(DEFAULT_AUDITION_SETTINGS);\n  const [timezone, setTimezone] = useState('America/New_York');\n  const [homepageUrl, setHomepageUrl] = useState('');\n  const [targetPerformance, setTargetPerformance] = useState<Event | null>(null);\n  const [rehearsals, setRehearsals] = useState<Event[]>([]);\n  const [isScheduleExpanded, setIsScheduleExpanded] = useState(window.innerWidth > 640);\n  const [name, setName] = useState('');\n  const [contact, setContact] = useState('');\n  const [requestedSlots, setRequestedSlots] = useState<string[]>([]);\n  const [voicePart, setVoicePart] = useState('');\n  const [experience, setExperience] = useState('');\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [isLoading, setIsLoading] = useState(true);\n  const [submitted, setSubmitted] = useState(false);\n  const [error, setError] = useState('');\n  const { labels: voicePartLabels } = useVoiceParts();\n \n  useEffect(() => {\n    const init = async () => {\n      try {\n        const [loaded, tz, loadedHomepage] = await Promise.all([\n          settingsService.getAuditionSettings(),\n          fetchChoirTimezone().catch(() => 'America/New_York'),\n          settingsService.getHomepageUrl().catch(() => ''),\n        ]);\n        setSettings(loaded);\n        setTimezone(tz);\n        setHomepageUrl(loadedHomepage);\n\n        if (loaded.defaultPerformanceId) {\n          try {\n            const performance = await eventService.getPublicEventById(loaded.defaultPerformanceId);\n            setTargetPerformance(performance);\n\n            const rehearsalList = await eventService.getPublicRehearsalsForPerformance(performance.id);\n            setRehearsals(rehearsalList);\n          } catch (e) {\n            console.error('Failed to load performance details', e);\n          }\n        }\n      } catch (e) {\n        console.error('Failed to load settings', e);\n      } finally {\n        setIsLoading(false);\n      }\n    };\n\n    init();\n  }, []);\n\n  const handleSubmit = async (event: React.FormEvent) => {\n    event.preventDefault();\n    setIsSubmitting(true);\n    setError('');\n\n    if (requestedSlots.length === 0) {\n      setError('Please select at least one available audition time slot.');\n      setIsSubmitting(false);\n      return;\n    }\n\n    try {\n      if (contact.includes('@') && !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(contact.trim())) {\n        setError('Enter a valid email address or use a phone number.');\n        setIsSubmitting(false);\n        return;\n      }\n\n      await auditionService.createAudition({\n        name,\n        contact,\n        requestedSlots,\n        ...(voicePart ? { voicePart: voicePart as Audition['voicePart'] } : {}),\n        experience,\n        performance: settings.defaultPerformanceId || undefined,\n      });\n      setSubmitted(true);\n    } catch {\n      setError('We could not submit your audition request. Please try again.');\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const isFormActive = settings.enabled && targetPerformance;\n\n  if (isLoading) {\n    return (\n      <div className=\"flex flex-col min-h-screen justify-center items-center w-screen\">\n        <p className=\"text-text-muted\">Loading...</p>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"flex flex-col min-h-screen justify-start items-center w-screen p-4\">\n      <PublicLogo />\n      <AppCard className=\"w-full max-w-[720px]\">\n        <div className=\"flex flex-col gap-2\">\n          <Link to=\"/login\" className=\"btn btn-ghost btn-sm self-start\">Admin Login</Link>\n          <h1 className=\"text-display m-0\">Choir Auditions</h1>\n          {!submitted && (\n            <p className=\"text-text-muted m-0\">\n              Choose an audition time and share the best way to reach you.\n            </p>\n          )}\n        </div>\n\n        {!isFormActive ? (\n          <div className=\"flex flex-col gap-4 py-8 text-center\">\n            <div className=\"text-5xl\">📅</div>\n            <p className=\"text-body m-0 font-medium\">\n              {settings.enabled \n                ? \"Auditions are not currently scheduled for an upcoming performance.\"\n                : \"Audition requests are closed right now. Please check back later.\"}\n            </p>\n            <p className=\"text-text-muted text-sm\">Please check our social media or website for the next audition announcement.</p>\n          </div>\n        ) : submitted ? (\n          <div className=\"flex flex-col gap-4 py-4\">\n            <div className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-success-bg text-success-text self-start\">Request Sent</div>\n            <p className=\"text-body m-0\">\n              {settings.confirmationMessage}\n            </p>\n            {homepageUrl && (\n              <a \n                href={homepageUrl} \n                className=\"btn btn-primary self-start mt-4 no-underline inline-flex items-center gap-1.5\"\n              >\n                🏠 Visit our Homepage\n              </a>\n            )}\n          </div>\n        ) : (\n          <div className=\"flex flex-col gap-8\">\n            <div className=\"card p-0 overflow-hidden bg-primary-light\">\n              <button \n                onClick={() => setIsScheduleExpanded(!isScheduleExpanded)}\n                className=\"w-full px-6 py-4 flex flex-row justify-between border-none bg-none cursor-pointer text-left\"\n              >\n                <div className=\"flex flex-col gap-0.5\">\n                  <span className=\"text-label text-primary-deep\">CONCERT DETAILS & SCHEDULE</span>\n                  <span className=\"text-xs text-text-muted\">Please review the commitment for this concert series</span>\n                </div>\n                {/* @allow-inline-style - dynamic transform based on expansion state */}\n                <span style={{ fontSize: '1.2rem', transform: isScheduleExpanded ? 'rotate(180deg)' : 'rotate(0deg)', transition: 'transform 0.2s' }}>\n                  ▼\n                </span>\n              </button>\n\n              {isScheduleExpanded && (\n                <div className=\"px-6 pb-6\">\n                  <div className=\"flex flex-col gap-4 p-4 bg-surface rounded-lg\">\n                    <div>\n                      <h3 className=\"m-0 text-primary-deep\">{targetPerformance.title}</h3>\n                      <p className=\"text-sm m-0\">\n                        Performance: <strong>{formatInTimezone(targetPerformance.date, timezone, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: 'numeric', minute: '2-digit' })}</strong>\n                      </p>\n                    </div>\n\n                    <div className=\"flex flex-col gap-1\">\n                      <span className=\"text-xs text-text-muted font-bold uppercase\">Rehearsal Schedule</span>\n                      <div className=\"flex flex-col gap-1\">\n                        {rehearsals.length > 0 ? rehearsals.map((rehearsal) => (\n                          <div key={rehearsal.id} className=\"flex flex-col md:flex-row text-xs justify-between py-1 border-b border-border\">\n                            <span>{formatInTimezone(rehearsal.date, timezone, { month: 'short', day: 'numeric', weekday: 'short' })} - {formatInTimezone(rehearsal.date, timezone, { hour: 'numeric', minute: '2-digit' })}</span>\n                            <span className=\"text-text-muted\">{rehearsal.title}</span>\n                          </div>\n                        )) : (\n                          <p className=\"text-xs text-text-muted\">Detailed schedule pending.</p>\n                        )}\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              )}\n            </div>\n\n            <form onSubmit={handleSubmit} className=\"flex flex-col gap-6\">\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-label\">Name</label>\n                <input className=\"card px-3\" value={name} onChange={(e) => setName(e.target.value)} required />\n              </div>\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-label\">Email or Phone</label>\n                <input className=\"card px-3\" value={contact} onChange={(e) => setContact(e.target.value)} required />\n              </div>\n              <div className=\"flex flex-col md:flex-row gap-4\">\n                <div className=\"flex-1 flex flex-col gap-1\">\n                  <label className=\"text-label\">Voice Part</label>\n                  <select className=\"card px-3 h-11\" value={voicePart} onChange={(e) => setVoicePart(e.target.value)}>\n                    <option value=\"\">Not sure yet</option>\n                    {voicePartLabels.map((part) => (\n                      <option key={part} value={part}>{part}</option>\n                    ))}\n                  </select>\n                </div>\n              </div>\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-label\">Available Audition Times (Select all that apply)</label>\n                <div className=\"grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-3 bg-neutral-bg p-4 rounded-lg border border-border\">\n                  {(settings.slots || []).map((slot) => {\n                    const isChecked = requestedSlots.includes(slot);\n                    return (\n                      <label \n                        key={slot} \n                        className={`flex items-center gap-2.5 p-3 rounded-sm border cursor-pointer select-none transition-all ${isChecked ? 'border-primary bg-[rgba(74,117,89,0.05)]' : 'border-border bg-surface'}`}\n                      >\n                        <input \n                          type=\"checkbox\" \n                          className=\"w-[18px] h-[18px] accent-primary cursor-pointer\"\n                          checked={isChecked}\n                          onChange={(e) => {\n                            if (e.target.checked) {\n                              setRequestedSlots([...requestedSlots, slot]);\n                            } else {\n                              setRequestedSlots(requestedSlots.filter(s => s !== slot));\n                            }\n                          }}\n                        />\n                        {/* @allow-inline-style - dynamic font weight based on check state */}\n                        <span style={{ fontSize: '0.875rem', fontWeight: isChecked ? 600 : 400 }}>\n                          {formatInTimezone(slot, timezone, { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' })}\n                        </span>\n                      </label>\n                    );\n                  })}\n                  {(!settings.slots || settings.slots.length === 0) && (\n                    <span className=\"text-text-muted text-sm col-span-full text-center py-3\">\n                      No time slots are currently configured. Please contact the administrator.\n                    </span>\n                  )}\n                </div>\n              </div>\n              <div className=\"flex flex-col gap-1\">\n                <label className=\"text-label\">Experience / Musical Background</label>\n                <textarea\n                  className=\"card min-h-[120px] p-3 resize-y\"\n                  value={experience}\n                  onChange={(e) => setExperience(e.target.value)}\n                />\n              </div>\n              {error && <p className=\"text-danger-text m-0\">{error}</p>}\n              <button className=\"btn btn-primary\" type=\"submit\" disabled={isSubmitting}>\n                {isSubmitting ? 'Submitting...' : 'Request Audition'}\n              </button>\n            </form>\n          </div>\n        )}\n      </AppCard>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/PublicBundlePurchaseView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":46,"column":28,"messageId":"fix:sort","endLine":46,"endColumn":36,"fix":{"range":[1775,1838],"text":"flex min-h-screen w-screen flex-col items-center justify-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":46,"column":37,"messageId":"fix:sort","endLine":46,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":46,"column":50,"messageId":"fix:sort