","severity":1,"message":"Invalid Tailwind CSS classnames order","line":106,"column":38,"messageId":"fix:sort","endLine":106,"endColumn":45,"fix":{"range":[3762,3780],"text":"text-muted text-xs"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":106,"column":46,"messageId":"fix:sort","endLine":106,"endColumn":56},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":106,"column":46,"messageId":"issue:unknown-classname","endLine":106,"endColumn":56,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[3762,3780],"text":"text-xs"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":110,"column":44,"messageId":"fix:sort","endLine":110,"endColumn":54,"fix":{"range":[3995,4024],"text":"flex-col items-end text-right"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":110,"column":55,"messageId":"fix:sort","endLine":110,"endColumn":64},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":112,"column":47,"messageId":"fix:sort","endLine":112,"endColumn":56,"fix":{"range":[4215,4246],"text":"`text-xs font-bold uppercase ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":112,"column":57,"messageId":"fix:sort","endLine":112,"endColumn":66},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-success' is not a Tailwind CSS class","line":112,"column":95,"messageId":"issue:unknown-classname","endLine":112,"endColumn":107,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-success"},"fix":{"range":[4272,4284],"text":""},"desc":"Remove unknown classname 'text-success'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-danger' is not a Tailwind CSS class","line":112,"column":112,"messageId":"issue:unknown-classname","endLine":112,"endColumn":123,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-danger"},"fix":{"range":[4289,4300],"text":""},"desc":"Remove unknown classname 'text-danger'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":42,"fixableErrorCount":0,"fixableWarningCount":10,"source":"import React, { useEffect, useState, useMemo } from 'react';\nimport { ticketService } from '../../services/ticketService';\nimport { donationService } from '../../services/donationService';\nimport { formatInTimezone } from '../../lib/timezone';\nimport { pb } from '../../lib/pocketbase';\n\ninterface SingerPatronageHistoryTabProps {\n  profileId: string;\n  isOpen: boolean;\n  isActive: boolean;\n}\n\ninterface PatronageHistoryItem {\n  type: 'ticket' | 'donation';\n  id: string;\n  amountPaidCents: number;\n  date: string;\n  description: string;\n  status: string;\n}\n\nexport const SingerPatronageHistoryTab: React.FC<SingerPatronageHistoryTabProps> = ({ profileId, isOpen, isActive }) => {\n  const [loading, setLoading] = useState(true);\n  const [items, setItems] = useState<PatronageHistoryItem[]>([]);\n\n  useEffect(() => {\n    if (isOpen && isActive) {\n      const fetchData = async () => {\n        setLoading(true);\n        try {\n          const [purchases, donations] = await Promise.all([\n            ticketService.getPurchasesForProfile(profileId),\n            donationService.getDonations(pb.filter('profile = {:profileId}', { profileId }))\n          ]);\n\n          const ticketItems: PatronageHistoryItem[] = purchases.map(p => ({\n            type: 'ticket',\n            id: p.id,\n            amountPaidCents: p.amountPaidCents,\n            date: p.created,\n            description: `Purchased ${p.quantity} ticket${p.quantity > 1 ? 's' : ''} for ${p.expand?.event?.title || 'Unknown Event'}`,\n            status: p.status\n          }));\n\n          const donationItems: PatronageHistoryItem[] = donations.map(d => ({\n            type: 'donation',\n            id: d.id,\n            amountPaidCents: d.amountPaidCents,\n            date: d.created,\n            description: `Donated $${(d.amountPaidCents / 100).toLocaleString()}`,\n            status: d.status\n          }));\n\n          const combined = [...ticketItems, ...donationItems].sort((a, b) => \n            new Date(b.date).getTime() - new Date(a.date).getTime()\n          );\n\n          setItems(combined);\n        } catch (err) {\n          console.error('Failed to fetch patronage history:', err);\n        } finally {\n          setLoading(false);\n        }\n      };\n\n      fetchData();\n    }\n  }, [profileId, isOpen, isActive]);\n\n  const ltvCents = useMemo(() => {\n    return items\n      .filter(item => item.status === 'paid')\n      .reduce((sum, item) => sum + item.amountPaidCents, 0);\n  }, [items]);\n\n  if (loading) {\n    return (\n      <div className=\"text-sm text-muted p-4\">\n        Loading patronage history...\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"flex-col gap-4\">\n      <div className=\"card p-4 bg-primary-light border border-[rgb(74_117_89_/_20%)] flex flex-col gap-1\">\n        <div className=\"text-xs uppercase tracking-wider font-semibold text-primary-deep\">Lifetime Value</div>\n        <div className=\"text-2xl font-extrabold text-primary\">\n          ${(ltvCents / 100).toLocaleString(undefined, { minimumFractionDigits: 2 })}\n        </div>\n      </div>\n\n      <div>\n        <h4 className=\"m-0 mb-2 text-xs uppercase tracking-wider text-text-muted\">\n          Transaction History ({items.length})\n        </h4>\n        <div className=\"flex-col gap-2\">\n          {items.length === 0 ? (\n            <p className=\"text-sm text-muted m-0\">No patronage history found.</p>\n          ) : (\n            items.map((item) => (\n              <div key={`${item.type}-${item.id}`} className=\"card p-3 px-4 shadow-none border border-border m-0\">\n                <div className=\"flex-row justify-between align-center\">\n                  <div className=\"flex-col\">\n                    <span className=\"text-sm font-medium\">{item.description}</span>\n                    <span className=\"text-xs text-muted\">\n                      {formatInTimezone(item.date, 'America/New_York', { month: 'short', day: 'numeric', year: 'numeric' })}\n                    </span>\n                  </div>\n                  <div className=\"flex-col text-right items-end\">\n                    <span className=\"text-sm font-bold\">${(item.amountPaidCents / 100).toLocaleString(undefined, { minimumFractionDigits: 2 })}</span>\n                    <span className={`text-xs uppercase font-bold ${item.status === 'paid' ? 'text-success' : 'text-danger'}`}>\n                      {item.status}\n                    </span>\n                  </div>\n                </div>\n              </div>\n            ))\n          )}\n        </div>\n      </div>\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/SingerPerformanceRsvpRow.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":41,"column":21,"messageId":"issue:unknown-classname","endLine":41,"endColumn":25,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[1491,1668],"text":"p-4 flex items-center justify-between gap-4 border border-border bg-bg transition-colors duration-200 hover:border-primary max-sm:flex-col max-sm:items-stretch max-sm:gap-2"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tai