ableWarningCount":5,"source":"import React from 'react';\nimport { SingerPerformanceRsvpRow } from './SingerPerformanceRsvpRow';\nimport { useSingerRsvpHistory } from '../../hooks/useSingerRsvpHistory';\n\ninterface SingerRsvpHistoryTabProps {\n  singerId: string;\n  isOpen: boolean;\n  isActive: boolean;\n}\n\nexport const SingerRsvpHistoryTab: React.FC<SingerRsvpHistoryTabProps> = ({ singerId, isOpen, isActive }) => {\n  const {\n    loadingRsvps,\n    savingRsvpId,\n    rsvpSaveErrors,\n    rosters,\n    upcomingPerformances,\n    pastPerformances,\n    onRsvpChange,\n  } = useSingerRsvpHistory({ isOpen, singerId, isActive });\n\n  if (loadingRsvps) {\n    return (\n      <div className=\"text-sm text-muted p-4\">\n        Loading RSVP history...\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"flex-col gap-4\">\n      <div>\n        <h4 className=\"m-0 mb-2 text-xs uppercase tracking-wider text-text-muted\">\n          Upcoming Performances ({upcomingPerformances.length})\n        </h4>\n        <div className=\"flex-col gap-2\">\n          {upcomingPerformances.length === 0 ? (\n            <p className=\"text-sm text-muted m-0\">No upcoming performances.</p>\n          ) : (\n            upcomingPerformances.map((performance) => {\n              const rosterEntry = rosters.find((roster) => roster.event === performance.id);\n              return (\n                <SingerPerformanceRsvpRow\n                  key={performance.id}\n                  performance={performance}\n                  rosterEntry={rosterEntry}\n                  isPast={false}\n                  isSaving={savingRsvpId === performance.id}\n                  saveError={rsvpSaveErrors[performance.id]}\n                  onRsvpChange={onRsvpChange}\n                />\n              );\n            })\n          )}\n        </div>\n      </div>\n\n      <div>\n        <h4 className=\"m-0 mb-2 text-xs uppercase tracking-wider text-text-muted\">\n          Past Performances ({pastPerformances.length})\n        </h4>\n        <div className=\"flex-col gap-2\">\n          {pastPerformances.length === 0 ? (\n            <p className=\"text-sm text-muted m-0\">No past performances.</p>\n          ) : (\n            pastPerformances.map((performance) => {\n              const rosterEntry = rosters.find((roster) => roster.event === performance.id);\n              return (\n                <SingerPerformanceRsvpRow\n                  key={performance.id}\n                  performance={performance}\n                  rosterEntry={rosterEntry}\n                  isPast={true}\n                  isSaving={savingRsvpId === performance.id}\n                  saveError={rsvpSaveErrors[performance.id]}\n                  onRsvpChange={onRsvpChange}\n                />\n              );\n            })\n          )}\n        </div>\n      </div>\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/SortableSetListItem.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":61,"column":19,"messageId":"issue:unknown-classname","endLine":61,"endColumn":23,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[1598,1628],"text":"`flex-row sl-item-card ${"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":61,"column":24,"messageId":"fix:sort","endLine":61,"endColumn":32,"fix":{"range":[1598,1628],"text":"`card sl-item-card flex-row ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":61,"column":33,"messageId":"fix:sort","endLine":61,"endColumn":45},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'sl-item-card' is not a Tailwind CSS class","line":61,"column