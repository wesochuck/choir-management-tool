items-center justify-between"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":355,"column":44,"messageId":"fix:sort","endLine":355,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":355,"column":73,"messageId":"fix:sort","endLine":355,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":356,"column":42,"messageId":"fix:sort","endLine":356,"endColumn":51,"fix":{"range":[15583,15633],"text":"max-w-[180px] truncate text-sm font-bold text-text"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":356,"column":52,"messageId":"fix:sort","endLine":356,"endColumn":61},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":356,"column":70,"messageId":"fix:sort","endLine":356,"endColumn":78},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":356,"column":79,"messageId":"fix:sort","endLine":356,"endColumn":92},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":360,"column":36,"messageId":"fix:sort","endLine":360,"endColumn":43,"fix":{"range":[15871,15907],"text":"line-clamp-2 text-xs text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":360,"column":44,"messageId":"fix:sort","endLine":360,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":360,"column":60,"messageId":"fix:sort","endLine":360,"endColumn":72},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":369,"column":33,"messageId":"issue:unknown-classname","endLine":369,"endColumn":43,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[16245,16271],"text":"text-center p-4"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":369,"column":44,"messageId":"fix:sort","endLine":369,"endColumn":55,"fix":{"range":[16245,16271],"text":"text-muted p-4 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":369,"column":56,"messageId":"fix:sort","endLine":369,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":374,"column":33,"messageId":"fix:sort","endLine":374,"endColumn":46,"fix":{"range":[16408,16463],"text":"rounded-lg bg-surface/80 p-6 shadow-sm backdrop-blur-sm"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":374,"column":47,"messageId":"fix:sort","endLine":374,"endColumn":63},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":374,"column":64,"messageId":"fix:sort","endLine":374,"endColumn":74},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":374,"column":85,"messageId":"fix:sort","endLine":374,"endColumn":88},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":376,"column":33,"messageId":"issue:unknown-classname","endLine":376,"endColumn":43,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[16557,16583],"text":"text-center p-4"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":376,"column":44,"messageId":"fix:sort","endLine":376,"endColumn":55,"fix":{"range":[16557,16583],"text":"text-muted p-4 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":376,"column":56,"messageId":"fix:sort","endLine":376,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":60,"messageId":"fix:sort","endLine":387,"endColumn":73,"fix":{"range":[17121,17381],"text":"flex items-center gap-2 rounded-md border border-border bg-[rgba(74,124,89,0.02)] p-[10px_12px] text-sm font-semibold text-text no-underline transition-all duration-200 hover:translate-x-[2px] hover:border-primary hover:bg-primary-light hover:text-primary-deep"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":74,"messageId":"fix:sort","endLine":387,"endColumn":99},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":100,"messageId":"fix:sort","endLine":387,"endColumn":106},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":107,"messageId":"fix:sort","endLine":387,"endColumn":120},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":121,"messageId":"fix:sort","endLine":387,"endColumn":131},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":132,"messageId":"fix:sort","endLine":387,"endColumn":141},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":156,"messageId":"fix:sort","endLine":387,"endColumn":163},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":164,"messageId":"fix:sort","endLine":387,"endColumn":178},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":179,"messageId":"fix:sort","endLine":387,"endColumn":191},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":192,"messageId":"fix:sort","endLine":387,"endColumn":204},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":205,"messageId":"fix:sort","endLine":387,"endColumn":227},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":249,"messageId":"fix:sort","endLine":387,"endColumn":272},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":387,"column":273,"messageId":"fix:sort","endLine":387,"endColumn":296},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":395,"column":33,"messageId":"issue:unknown-classname","endLine":395,"endColumn":43,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[17647,17673],"text":"text-center p-4"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":395,"column":44,"messageId":"fix:sort","endLine":395,"endColumn":55,"fix":{"range":[17647,17673],"text":"text-muted p-4 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":395,"column":56,"messageId":"fix:sort","endLine":395,"endColumn":59},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":414,"column":24,"messageId":"issue:unknown-classname","endLine":414,"endColumn":27,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[18175,18199],"text":"btn-secondary btn-sm"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-secondary' is not a Tailwind CSS class","line":414,"column":28,"messageId":"issue:unknown-classname","endLine":414,"endColumn":41,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-secondary"},"fix":{"range":[18175,18199],"text":"btn btn-sm"},"desc":"Remove unknown classname 'btn-secondary'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-sm' is not a Tailwind CSS class","line":414,"column":42,"messageId":"issue:unknown-classname","endLine":414,"endColumn":48,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-sm"},"fix":{"range":[18175,18199],"text":"btn btn-secondary"},"desc":"Remove unknown classname 'btn-sm'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":422,"column":29,"messageId":"fix:sort","endLine":422,"endColumn":36,"fix":{"range":[18375,18399],"text":"text-muted -mt-2 text-xs"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":422,"column":37,"messageId":"fix:sort","endLine":422,"endColumn":47},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":422,"column":37,"messageId":"issue:unknown-classname","endLine":422,"endColumn":47,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[18375,18399],"text":"text-xs -mt-2"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":422,"column":48,"messageId":"fix:sort","endLine":422,"endColumn":53},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'message-preview-content' is not a Tailwind CSS class","line":425,"column":29,"messageId":"issue:unknown-classname","endLine":425,"endColumn":52,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"message-preview-content"},"fix":{"range":[18526,18578],"text":"max-h-[60vh] overflow-y-auto"},"desc":"Remove unknown classname 'message-preview-content'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":162,"fixableErrorCount":0,"fixableWarningCount":29,"source":"import { useEffect, useState } from 'react';\nimport { useMyEvents } from '../../hooks/useMyEvents';\nimport { EventCard } from '../../components/singer/EventCard';\nimport PublicLogo from '../../components/common/PublicLogo';\nimport { pb } from '../../lib/pocketbase';\nimport { PageLayout } from '../../components/common/PageLayout';\nimport { Link } from 'react-router-dom';\nimport { pollService, type SingerPoll } from '../../services/pollService';\nimport { AppCard } from '../../components/common/AppCard';\nimport { communicationService, type MessageRecord } from '../../services/communicationService';\nimport { sanitizeHtml } from '../../lib/textSafety';\nimport { useDialog } from '../../contexts/DialogContext';\nimport { resourceService, type SingerResource } from '../../services/resourceService';\nimport { settingsService } from '../../services/settingsService';\nimport { BaseModal } from '../../components/common/BaseModal';\n\n\nexport default function DashboardView() {\n  const dialog = useDialog();\n  const { events, myRosters, myProfile, isLoading, error, updateRSVP } = useMyEvents();\n  const [activePolls, setActivePolls] = useState<SingerPoll[]>([]);\n  const [announcements, setAnnouncements] = useState<MessageRecord[]>([]);\n  const [isAnnouncementsLoading, setIsAnnouncementsLoading] = useState(false);\n  const [selectedAnnouncement, setSelectedAnnouncement] = useState<MessageRecord | null>(null);\n  const [currentTime, setCurrentTime] = useState(() => Date.now());\n  const [resources, setResources] = useState<SingerResource[]>([]);\n  const [isResourcesLoading, setIsResourcesLoading] = useState(false);\n  const [submittingRsvpStatus, setSubmittingRsvpStatus] = useState<'Yes' | 'No' | null>(null);\n  const [maxRehearsalMisses, setMaxRehearsalMisses] = useState(3);\n\n  useEffect(() => {\n    if (myProfile?.id) {\n      const now = new Date();\n      pollService.getActivePollsForSinger(myProfile.id)\n        .then(list => {\n          // Client-side filter for active polls\n          const filtered = list.filter(poll => {\n            // Filter by archiveAt expiration\n            const isExpired = poll.archiveAt ? new Date(poll.archiveAt.replace(\" \", \"T\")) < now : false;\n            if (isExpired) return false;\n\n            if (!poll.eventId) return true;\n            const event = events.find(e => e.id === poll.eventId);\n            if (!event) return true;\n            return new Date(event.date) > now;\n          });\n          setActivePolls(filtered);\n        });\n    }\n  }, [myProfile?.id, events]);\n\n  useEffect(() => {\n    if (myProfile?.id) {\n      setIsAnnouncementsLoading(true);\n      communicationService.getMessages()\n        .then(async list => {\n          // Client-side filter to only show messages where the user is a recipient\n          const filtered = list.filter(msg => \n            msg.recipients?.some(r => r.id === myProfile.id)\n          );\n\n          const recent = filtered.slice(0, 5);\n          const resolved = await Promise.all(\n            recent.map(async (msg) => {\n              let content = msg.content;\n              const eventId = msg.filters?.eventId as string | undefined;\n\n              try {\n                content = await communicationService.resolveSingerPlaceholders(content, eventId);\n              } catch (err) {\n                console.error('Failed to resolve placeholders for message', msg.id, err);\n              }\n\n              return {\n                ...msg,\n                content,\n              };\n            })\n          );\n\n          setAnnouncements(resolved);\n        })\n        .catch(err => console.error('Failed to load announcements', err))\n        .finally(() => setIsAnnouncementsLoading(false));\n    }\n  }, [myProfile?.id]);\n\n  useEffect(() => {\n    setCurrentTime(Date.now());\n  }, [events]);\n\n  useEffect(() => {\n    setIsResourcesLoading(true);\n    resourceService.getResources()\n      .then(list => setResources(list))\n      .catch(err => console.error('Failed to load resources', err))\n      .finally(() => setIsResourcesLoading(false));\n\n    settingsService.getRosterSettings()\n      .then(settings => {\n        if (settings?.maxRehearsalMisses !== undefined) {\n          setMaxRehearsalMisses(settings.maxRehearsalMisses);\n        }\n      })\n      .catch(err => console.error('Failed to load roster settings:', err));\n  }, []);\n\n  const handlePollResponse = async (pollId: string, status: 'Yes' | 'No') => {\n    if (!myProfile?.id) return;\n    \n    // Optimistic update\n    setActivePolls(prev => prev.map(p => p.id === pollId ? { ...p, status } : p));\n    \n    try {\n      await pollService.submitResponseLoggedIn(pollId, myProfile.id, status);\n    } catch (err) {\n      console.error('Failed to submit poll response', err);\n      // Revert on error\n      const list = await pollService.getActivePollsForSinger(myProfile.id);\n      setActivePolls(list);\n    }\n  };\n\n  const handleUpdateRSVP = async (eventId: string, rsvp: 'Yes' | 'No') => {\n    const event = events.find(e => e.id === eventId);\n    if (!event) return;\n\n    setSubmittingRsvpStatus(rsvp);\n    try {\n      if (event.type === 'Rehearsal' && rsvp === 'No') {\n        const note = await dialog.prompt({\n          title: 'RSVP Note Required',\n          message: 'Please provide a brief reason for your absence from this rehearsal.',\n          placeholder: 'e.g. Family emergency, work travel, illness...',\n          confirmLabel: 'Submit RSVP',\n          required: true,\n          maxLength: 1000\n        });\n\n        if (note === null) return; // User cancelled prompt\n\n        await updateRSVP(eventId, rsvp, note);\n      } else {\n        await updateRSVP(eventId, rsvp);\n      }\n    } finally {\n      setSubmittingRsvpStatus(null);\n    }\n  };\n\n  if (isLoading && events.length === 0) return <div className=\"container text-center pt-8\">Loading your events...</div>;\n  if (error) return <div className=\"container p-5 text-red-600\">Error: {error}</div>;\n\n  const upcomingEvents = events.filter(e => new Date(e.date) >= new Date());\n  \n  const nextEvent = upcomingEvents[0] ?? null;\n  const nextRoster = nextEvent ? myRosters[nextEvent.id] : undefined;\n  const hasPerformanceSeatLink = nextEvent?.type === 'Performance';\n  const isNextEventParentPerformanceDeclined = nextEvent?.type === 'Rehearsal' && nextEvent.parentPerformanceId && myRosters[nextEvent.parentPerformanceId]?.rsvp === 'No';\n  const latestAnnouncement = announcements[0] ?? null;\n\n  const getFormattedDate = (dateStr: string) => {\n    try {\n      return new Date(dateStr).toLocaleDateString(undefined, {\n        month: 'short',\n        day: 'numeric',\n        year: 'numeric',\n      });\n    } catch {\n      return '';\n    }\n  };\n\n  const isNextEventClosed = nextEvent ? (\n    nextEvent.type === 'Performance' \n      ? !nextEvent.isOpenForRSVP \n      : new Date(nextEvent.date).getTime() < currentTime\n  ) : false;\n\n  const nextEventLabels = nextEvent?.type === 'Rehearsal' ? {\n    yes: nextRoster?.rsvp === 'Yes' ? '✓ Attending' : \"I'll be there\",\n    no: nextRoster?.rsvp === 'No' ? '✗ Absence Reported' : 'Report absence'\n  } : {\n    yes: nextRoster?.rsvp === 'Yes' ? '✓ Attending' : 'Attend',\n    no: nextRoster?.rsvp === 'No' ? '✗ Declining' : 'Decline'\n  };\n\n  return (\n    <PageLayout \n      title=\"Singer Dashboard\" \n      actions={\n        <div className=\"flex-row gap-2\">\n          <Link to=\"/profile\" className=\"btn btn-ghost\">My Profile</Link>\n          <button onClick={() => pb.authStore.clear()} className=\"btn btn-ghost\">Logout</button>\n        </div>\n      }\n      maxWidth=\"1200px\"\n    >\n      <PublicLogo />\n      <div className=\"py-4\">\n        {nextEvent && (\n          <section className=\"hidden max-md:block max-md:mb-6\" aria-label=\"Singer quick actions\">\n            <AppCard className=\"bg-surface/80 backdrop-blur-sm rounded-lg shadow-sm p-6\">\n              <div className=\"flex flex-col gap-2\">\n                <div className=\"text-[0.72rem] font-extrabold tracking-widest uppercase text-text-muted\">Next up</div>\n                <div className=\"text-lg font-extrabold text-text leading-tight\">{nextEvent.title || nextEvent.type}</div>\n                <div className=\"text-sm text-text-muted\">\n                  {getFormattedDate(nextEvent.date)}\n                  {nextEvent.expand?.venue?.name ? ` • ${nextEvent.expand.venue.name}` : ''}\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-2\">\n                  <Link to={`/player?eventId=${nextEvent.id}`} className=\"btn btn-primary\">\n                    🎵 Practice\n                  </Link>\n\n                  {hasPerformanceSeatLink && (\n                    <Link to={`/seating/${nextEvent.id}`} className=\"btn btn-secondary\">\n                      🪑 Seat\n                    </Link>\n                  )}\n                </div>\n\n                {isNextEventParentPerformanceDeclined ? (\n                  <div className=\"text-center text-xs text-muted mt-4 w-full p-2 border border-dashed border-white/30 rounded\">\n                    🚫 Excused (Parent Performance Declined)\n                  </div>\n                ) : (\n                  <>\n                    <div className=\"grid grid-cols-2 gap-2\">\n                      <button\n                        type=\"button\"\n                        onClick={() => handleUpdateRSVP(nextEvent.id, 'Yes')}\n                        className={`btn btn-sm ${nextRoster?.rsvp === 'Yes' ? 'btn-primary' : 'btn-ghost'}`}\n                        disabled={isNextEventClosed || submittingRsvpStatus !== null}\n                      >\n                        {submittingRsvpStatus === 'Yes' ? 'Processing...' : nextEventLabels.yes}\n                      </button>\n                      <button\n                        type=\"button\"\n                        onClick={() => handleUpdateRSVP(nextEvent.id, 'No')}\n                        className={`btn btn-sm ${nextRoster?.rsvp === 'No' ? 'btn-danger' : 'btn-ghost'}`}\n                        disabled={isNextEventClosed || submittingRsvpStatus !== null}\n                      >\n                        {submittingRsvpStatus === 'No' ? 'Processing...' : nextEventLabels.no}\n                      </button>\n                    </div>\n                    {isNextEventClosed && (\n                      <div className=\"text-xs text-muted text-center mt-1\">\n                        {nextEvent.type === 'Performance' \n                          ? 'The RSVP window for this performance is closed.' \n                          : 'This rehearsal has already passed.'}\n                      </div>\n                    )}\n                  </>\n                )}\n\n                {(activePolls.length > 0 || latestAnnouncement) && (\n                  <div className=\"flex flex-col gap-1 text-xs text-text-muted pt-1 border-t border-border\">\n                    {activePolls.length > 0 && (\n                      <span>{activePolls.length} active poll{activePolls.length === 1 ? '' : 's'}</span>\n                    )}\n                    {latestAnnouncement && (\n                      <button\n                        type=\"button\"\n                        className=\"border-0 p-0 bg-transparent text-primary font-inherit font-bold text-left cursor-pointer\"\n                        onClick={() => setSelectedAnnouncement(latestAnnouncement)}\n                      >\n                        Latest bulletin: {latestAnnouncement.subject || 'Choir Update'}\n                      </button>\n                    )}\n                  </div>\n                )}\n              </div>\n            </AppCard>\n          </section>\n        )}\n\n        <div className=\"grid grid-cols-[1fr_340px] gap-8 items-start max-md:grid-cols-1 max-md:gap-6\">\n          \n          {/* Main timeline panel: Events */}\n          <div className=\"flex-col gap-6\">\n            <h2 className=\"text-2xl font-bold text-text m-0 mb-1\">Upcoming Events</h2>\n            {upcomingEvents.map((e) => (\n              <EventCard \n                key={e.id} \n                event={e} \n                rsvp={myRosters[e.id]?.rsvp} \n                onRSVP={(rsvp) => handleUpdateRSVP(e.id, rsvp)} \n                allEvents={events}\n                myRosters={myRosters}\n                maxRehearsalMisses={maxRehearsalMisses}\n              />\n            ))}\n\n            {upcomingEvents.length === 0 && (\n              <div className=\"card bg-surface/80 backdrop-blur-sm rounded-lg shadow-sm p-6 flex flex-col items-center justify-center py-12 text-text-muted\">\n                <p className=\"text-muted\">No upcoming events at this time.</p>\n              </div>\n            )}\n          </div>\n\n          {/* Right sidebar: Quick widgets */}\n          <div className=\"flex-col gap-6\">\n            \n            {/* Quick Polls Widget */}\n            {activePolls.length > 0 && (\n              <AppCard className=\"bg-surface/80 backdrop-blur-sm rounded-lg shadow-sm p-6\" title=\"📊 Quick Polls\">\n                <div className=\"flex-col gap-2\">\n                  {activePolls.map(poll => (\n                    <div key={poll.id} className=\"card p-2 flex flex-col gap-1 shadow-none border border-border\">\n                      <div className=\"font-bold text-sm\">{poll.question}</div>\n                      <div className=\"flex-row gap-1\">\n                        <button \n                          className=\"btn btn-sm flex-1 border border-border font-bold\" \n                          // @allow-inline-style - Dynamic color based on poll status\n                          style={{ \n                            backgroundColor: poll.status === 'Yes' ? 'var(--primary)' : 'white',\n                            color: poll.status === 'Yes' ? 'white' : 'var(--neutral-text)',\n                          }}\n                          onClick={() => handlePollResponse(poll.id, 'Yes')}\n                        >\n                          {poll.status === 'Yes' ? '✓ Yes' : 'Yes'}\n                        </button>\n                        <button \n                          className=\"btn btn-sm flex-1 border border-border font-bold\" \n                          // @allow-inline-style - Dynamic color based on poll status\n                          style={{ \n                            backgroundColor: poll.status === 'No' ? '#ef4444' : 'white',\n                            color: poll.status === 'No' ? 'white' : 'var(--neutral-text)',\n                          }}\n                          onClick={() => handlePollResponse(poll.id, 'No')}\n                        >\n                          {poll.status === 'No' ? '✗ No' : 'No'}\n                        </button>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </AppCard>\n            )}\n\n            {/* Recent Announcements Widget */}\n            <AppCard className=\"bg-surface/80 backdrop-blur-sm rounded-lg shadow-sm p-6\" title=\"✉️ Bulletins\">\n              {isAnnouncementsLoading ? (\n                <div className=\"text-muted text-center p-4\">Loading bulletins...</div>\n              ) : announcements.length > 0 ? (\n                <div className=\"flex flex-col gap-4\">\n                  {announcements.map(ann => (\n                    <div \n                      key={ann.id} \n                      className=\"border-l-[3px] border-l-primary bg-surface rounded-r-md p-4 transition-all duration-200 cursor-pointer border-t border-r border-b border-border hover:bg-primary-light hover:translate-x-[3px]\"\n                      onClick={() => setSelectedAnnouncement(ann)}\n                    >\n                      <div className=\"flex justify-between items-center mb-1\">\n                        <span className=\"font-bold text-text text-sm truncate max-w-[180px]\">{ann.subject || 'Choir Update'}</span>\n                        <span className=\"text-xs text-text-muted\">{getFormattedDate(ann.created)}</span>\n                      </div>\n                      <div \n                        className=\"text-xs text-text-muted line-clamp-2\"\n                        dangerouslySetInnerHTML={{ \n                          __html: sanitizeHtml(ann.content).replace(/<[^>]*>/g, '').slice(0, 100) + '...' \n                        }} \n                      />\n                    </div>\n                  ))}\n                </div>\n              ) : (\n                <div className=\"text-muted text-center p-4\">No recent updates.</div>\n              )}\n            </AppCard>\n\n            {/* Resources Widget */}\n            <AppCard className=\"bg-surface/80 backdrop-blur-sm rounded-lg shadow-sm p-6\" title=\"📂 Resources\">\n              {isResourcesLoading ? (\n                <div className=\"text-muted text-center p-4\">Loading resources...</div>\n              ) : resources.length > 0 ? (\n                <div className=\"flex flex-col gap-2\">\n                  {resources.map(res => {\n                    const href = res.url || (res.file ? resourceService.getResourceFileUrl(res, res.file) : '#');\n                    return (\n                      <a \n                        key={res.id}\n                        href={href} \n                        target=\"_blank\" \n                        rel=\"noopener noreferrer\" \n                        className=\"flex items-center gap-2 p-[10px_12px] bg-[rgba(74,124,89,0.02)] border border-border rounded-md text-text font-semibold text-sm transition-all duration-200 no-underline hover:bg-primary-light hover:border-primary hover:text-primary-deep hover:translate-x-[2px]\"\n                      >\n                        <span className=\"text-xl\">{res.url ? '🔗' : '📄'}</span> {res.title}\n                      </a>\n                    );\n                  })}\n                </div>\n              ) : (\n                <div className=\"text-muted text-center p-4\">No resources available.</div>\n              )}\n            </AppCard>\n\n          </div>\n\n        </div>\n      </div>\n\n      {/* Announcement modal */}\n      <BaseModal\n        isOpen={!!selectedAnnouncement}\n        onClose={() => setSelectedAnnouncement(null)}\n        title={selectedAnnouncement?.subject || 'Bulletin details'}\n        maxWidth=\"600px\"\n        footer={\n          <button \n            type=\"button\" \n            onClick={() => setSelectedAnnouncement(null)} \n            className=\"btn btn-secondary btn-sm\"\n          >\n            Close\n          </button>\n        }\n      >\n        {selectedAnnouncement && (\n          <div className=\"flex-col gap-4\">\n            <div className=\"text-xs text-muted -mt-2\">\n              Dispatched on {getFormattedDate(selectedAnnouncement.created)}\n            </div>\n            <div className=\"message-preview-content max-h-[60vh] overflow-y-auto\">\n              {/* Secure content rendering */}\n              <div dangerouslySetInnerHTML={{ __html: sanitizeHtml(selectedAnnouncement.content) }} />\n            </div>\n          </div>\n        )}\n      </BaseModal>\n    </PageLayout>\n  );\n}\n","usedD