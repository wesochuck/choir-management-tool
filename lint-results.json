rd h-10 w-full cursor-pointer border border-border px-3"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":241,"column":40,"messageId":"fix:sort","endLine":241,"endColumn":44},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":241,"column":45,"messageId":"fix:sort","endLine":241,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":241,"column":71,"messageId":"fix:sort","endLine":241,"endColumn":85},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":249,"column":28,"messageId":"issue:unknown-classname","endLine":249,"endColumn":32,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[9050,9107],"text":"w-full px-3 h-10 border border-border cursor-pointer"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":249,"column":33,"messageId":"fix:sort","endLine":249,"endColumn":39,"fix":{"range":[9050,9107],"text":"card h-10 w-full cursor-pointer border border-border px-3"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":249,"column":40,"messageId":"fix:sort","endLine":249,"endColumn":44},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":249,"column":45,"messageId":"fix:sort","endLine":249,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":249,"column":71,"messageId":"fix:sort","endLine":249,"endColumn":85},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":258,"column":32,"messageId":"issue:unknown-classname","endLine":258,"endColumn":35,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[9521,9548],"text":"btn-ghost h-10 min-h-10"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-ghost' is not a Tailwind CSS class","line":258,"column":36,"messageId":"issue:unknown-classname","endLine":258,"endColumn":45,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-ghost"},"fix":{"range":[9521,9548],"text":"btn h-10 min-h-10"},"desc":"Remove unknown classname 'btn-ghost'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":263,"column":31,"messageId":"fix:sort","endLine":263,"endColumn":46,"fix":{"range":[9713,9759],"text":"w-full min-w-[600px] border-collapse text-left"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":263,"column":47,"messageId":"fix:sort","endLine":263,"endColumn":53},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":263,"column":54,"messageId":"fix:sort","endLine":263,"endColumn":67},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":265,"column":55,"messageId":"fix:sort","endLine":265,"endColumn":70,"fix":{"range":[9811,9859],"text":"border-b-2 border-border text-sm text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":265,"column":71,"messageId":"fix:sort","endLine":265,"endColumn":78},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":266,"column":32,"messageId":"fix:sort","endLine":266,"endColumn":35,"fix":{"range":[9893,9913],"text":"w-12 p-3 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":266,"column":36,"messageId":"fix:sort","endLine":266,"endColumn":40},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":283,"column":48,"messageId":"fix:sort","endLine":283,"endColumn":59,"fix":{"range":[10660,10675],"text":"p-8 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":283,"column":60,"messageId":"fix:sort","endLine":283,"endColumn":63},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":285,"column":48,"messageId":"fix:sort","endLine":285,"endColumn":59,"fix":{"range":[10804,10883],"text":"flex flex-col items-center justify-center p-8 py-12 text-center text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":285,"column":60,"messageId":"fix:sort","endLine":285,"endColumn":63},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":285,"column":64,"messageId":"fix:sort","endLine":285,"endColumn":68},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":285,"column":69,"messageId":"fix:sort","endLine":285,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":285,"column":78,"messageId":"fix:sort","endLine":285,"endColumn":90},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":285,"column":91,"messageId":"fix:sort","endLine":285,"endColumn":105},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":285,"column":106,"messageId":"fix:sort","endLine":285,"endColumn":111},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":287,"column":51,"messageId":"fix:sort","endLine":287,"endColumn":59,"fix":{"range":[11029,11097],"text":"cursor-pointer border-b border-border text-sm hover:bg-primary-light"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":287,"column":60,"messageId":"fix:sort","endLine":287,"endColumn":73},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":287,"column":74,"messageId":"fix:sort","endLine":287,"endColumn":81},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":287,"column":82,"messageId":"fix:sort","endLine":287,"endColumn":96},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":288,"column":34,"messageId":"fix:sort","endLine":288,"endColumn":37,"fix":{"range":[11178,11198],"text":"w-12 p-3 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":288,"column":38,"messageId":"fix:sort","endLine":288,"endColumn":42},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":296,"column":34,"messageId":"fix:sort","endLine":296,"endColumn":37,"fix":{"range":[11585,11607],"text":"text-muted p-3 text-sm"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":296,"column":38,"messageId":"fix:sort","endLine":296,"endColumn":45},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":296,"column":46,"messageId":"fix:sort","endLine":296,"endColumn":56},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":296,"column":46,"messageId":"issue:unknown-classname","endLine":296,"endColumn":56,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[11585,11607],"text":"p-3 text-sm"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":300,"column":64,"messageId":"fix:sort","endLine":300,"endColumn":68,"fix":{"range":[11776,11871],"text":"`inline-flex items-center rounded px-2 py-0.5 text-xs font-semibold tracking-wider uppercase ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":300,"column":69,"messageId":"fix:sort","endLine":300,"endColumn":75},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":300,"column":76,"messageId":"fix:sort","endLine":300,"endColumn":83},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":300,"column":106,"messageId":"fix:sort","endLine":300,"endColumn":115},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":300,"column":116,"messageId":"fix:sort","endLine":300,"endColumn":130},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":310,"column":34,"messageId":"fix:sort","endLine":310,"endColumn":37,"fix":{"range":[12496,12521],"text":"text-muted p-3 text-right"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":310,"column":38,"messageId":"fix:sort","endLine":310,"endColumn":48},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":310,"column":49,"messageId":"fix:sort","endLine":310,"endColumn":59},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":310,"column":49,"messageId":"issue:unknown-classname","endLine":310,"endColumn":59,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[12496,12521],"text":"p-3 text-right"},"desc":"Remove unknown classname 'text-muted'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":99,"fixableErrorCount":0,"fixableWarningCount":24,"source":"import { useCallback, useEffect, useMemo, useState } from 'react';\nimport { useNavigate } from 'react-router-dom';\nimport { profileService, type Profile, type ProfileInput } from '../../services/profileService';\nimport { donationService } from '../../services/donationService';\nimport { ticketService } from '../../services/ticketService';\nimport { AppCard } from '../../components/common/AppCard';\nimport { useDocumentTitle } from '../../hooks/useDocumentTitle';\nimport { formatInTimezone } from '../../lib/timezone';\nimport { getFirstName, getLastName } from '../../lib/stringUtils';\nimport { safeLocalStorage } from '../../lib/storage';\nimport { SingerModal } from '../../components/admin/SingerModal';\n\nconst STORAGE_KEY_START_DATE = 'patrons_view_filter_start_date';\n\ninterface PatronData {\n  profile: Profile;\n  ltvCents: number;\n  lastTransactionDate: string;\n  transactionCount: number;\n  isSinger: boolean;\n}\n\nexport default function PatronsView() {\n  useDocumentTitle('Patrons');\n  const navigate = useNavigate();\n  const [loading, setLoading] = useState(true);\n  const [patrons, setPatrons] = useState<PatronData[]>([]);\n  const [searchQuery, setSearchQuery] = useState('');\n  const [selectedIds, setSelectedIds] = useState<Set<string>>(new Set());\n  const [sortBy, setSortBy] = useState<'ltv' | 'name' | 'lastDate'>('ltv');\n  const [startDate, setStartDate] = useState(safeLocalStorage.getItem(STORAGE_KEY_START_DATE) || '');\n  const [endDate, setEndDate] = useState('');\n\n  const handleSetStartDate = (val: string) => {\n    setStartDate(val);\n    if (val) {\n      safeLocalStorage.setItem(STORAGE_KEY_START_DATE, val);\n    } else {\n      safeLocalStorage.removeItem(STORAGE_KEY_START_DATE);\n    }\n  };\n\n  const handleClearFilters = () => {\n    setSearchQuery('');\n    setStartDate('');\n    setEndDate('');\n    safeLocalStorage.removeItem(STORAGE_KEY_START_DATE);\n  };\n\n  // Modal State\n  const [isModalOpen, setIsModalOpen] = useState(false);\n  const [selectedPatron, setSelectedPatron] = useState<Profile | null>(null);\n\n  const fetchData = useCallback(async () => {\n    setLoading(true);\n    try {\n      const [profiles, donations, purchases] = await Promise.all([\n        profileService.getProfiles(),\n        donationService.getDonations('status = \"paid\"'),\n        ticketService.getAllPurchases()\n      ]);\n\n      const paidPurchases = purchases.filter(p => p.status === 'paid');\n\n      // Map profiles to their transactions\n      const patronMap = new Map<string, PatronData>();\n\n      const processTransaction = (profileId: string | undefined, amountCents: number, date: string) => {\n        if (!profileId) return;\n        const profile = profiles.find(p => p.id === profileId);\n        if (!profile) return;\n\n        const existing = patronMap.get(profileId);\n        if (existing) {\n          existing.ltvCents += amountCents;\n          existing.transactionCount += 1;\n          if (new Date(date) > new Date(existing.lastTransactionDate)) {\n            existing.lastTransactionDate = date;\n          }\n        } else {\n          patronMap.set(profileId, {\n            profile,\n            ltvCents: amountCents,\n            lastTransactionDate: date,\n            transactionCount: 1,\n            isSinger: !!profile.voicePart\n          });\n        }\n      };\n\n      donations.forEach(d => processTransaction(d.profile, d.amountPaidCents, d.created));\n      paidPurchases.forEach(p => processTransaction(p.profile, p.amountPaidCents, p.created));\n\n      setPatrons(Array.from(patronMap.values()));\n    } catch (err) {\n      console.error('Failed to fetch patrons data:', err);\n    } finally {\n      setLoading(false);\n    }\n  }, []);\n\n  useEffect(() => {\n    fetchData();\n  }, [fetchData]);\n\n  const filteredPatrons = useMemo(() => {\n    const result = patrons.filter(p => {\n      const search = searchQuery.toLowerCase();\n      const matchesSearch =\n        p.profile.name.toLowerCase().includes(search) ||\n        (p.profile.expand?.user?.email || '').toLowerCase().includes(search);\n\n      const date = new Date(p.lastTransactionDate);\n      const matchesStart = !startDate || date >= new Date(startDate);\n      const matchesEnd = !endDate || date <= new Date(endDate + 'T23:59:59');\n\n      return matchesSearch && matchesStart && matchesEnd;\n    });\n\n    result.sort((a, b) => {\n      if (sortBy === 'ltv') return b.ltvCents - a.ltvCents;\n      if (sortBy === 'name') {\n        const lastA = getLastName(a.profile.name).toLowerCase();\n        const lastB = getLastName(b.profile.name).toLowerCase();\n        if (lastA !== lastB) return lastA.localeCompare(lastB);\n        return getFirstName(a.profile.name).localeCompare(getFirstName(b.profile.name));\n      }\n      if (sortBy === 'lastDate') {\n        return new Date(b.lastTransactionDate).getTime() - new Date(a.lastTransactionDate).getTime();\n      }\n      return 0;\n    });\n\n    return result;\n  }, [patrons, searchQuery, sortBy, startDate, endDate]);\n\n  const filteredStats = useMemo(() => {\n    const count = filteredPatrons.length;\n    const totalLtvCents = filteredPatrons.reduce((acc, p) => acc + p.ltvCents, 0);\n    return { count, totalLtvCents };\n  }, [filteredPatrons]);\n\n  const toggleSelectAll = () => {\n    if (selectedIds.size === filteredPatrons.length) {\n      setSelectedIds(new Set());\n    } else {\n      setSelectedIds(new Set(filteredPatrons.map(p => p.profile.id)));\n    }\n  };\n\n  const toggleSelect = (id: string) => {\n    const next = new Set(selectedIds);\n    if (next.has(id)) {\n      next.delete(id);\n    } else {\n      next.add(id);\n    }\n    setSelectedIds(next);\n  };\n\n  const handleSendMessage = () => {\n    if (selectedIds.size === 0) return;\n    const ids = Array.from(selectedIds).join(',');\n    navigate(`/admin/communications?recipientIds=${ids}`);\n  };\n\n  const handleOpenProfile = (profile: Profile) => {\n    setSelectedPatron(profile);\n    setIsModalOpen(true);\n  };\n\n  const handleSaveProfile = async (data: ProfileInput) => {\n    if (selectedPatron) {\n      await profileService.updateProfile(selectedPatron.id, data);\n      await fetchData();\n    }\n  };\n\n  const handleDeleteProfile = async (profile: Profile) => {\n    await profileService.deleteProfile(profile.id);\n    await fetchData();\n  };\n\n  return (\n    <div className=\"p-6 max-w-7xl mx-auto\">\n      <div className=\"flex items-center justify-between mb-6 flex flex-col md:flex-row\">\n        <div>\n          <h1 className=\"text-display\">Patrons Dashboard</h1>\n          <p className=\"text-muted text-sm\">View lifetime value and message your donors and ticket buyers.</p>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <button \n            className=\"btn btn-primary\" \n            onClick={handleSendMessage}\n            disabled={selectedIds.size === 0}\n          >\n            Send Message ({selectedIds.size})\n          </button>\n        </div>\n      </div>\n\n      <div className=\"card p-4 bg-bg\">\n        <div className=\"flex justify-around h-full items-center\">\n          <div className=\"flex flex-col gap-1 text-center\">\n            <span className=\"text-sm text-text-muted font-bold uppercase tracking-wider\">Patrons</span>\n            <span className=\"text-headline font-bold\">{filteredStats.count}</span>\n          </div>\n          <div className=\"flex flex-col gap-1 text-center\">\n            <span className=\"text-sm text-text-muted font-bold uppercase tracking-wider\">Total LTV</span>\n            <span className=\"text-headline font-bold text-primary\">\n              ${(filteredStats.totalLtvCents / 100).toLocaleString(undefined, { minimumFractionDigits: 2 })}\n            </span>\n          </div>\n        </div>\n      </div>\n\n      <AppCard title=\"Patron Directory\">\n        <div className=\"flex flex-col gap-4\">\n          <div className=\"flex flex-col md:flex-row gap-4 items-center w-full flex-wrap max-md:flex-col max-md:items-stretch\">\n            <div className=\"flex-1 min-w-[200px] w-full\">\n              <input \n                type=\"text\"\n                placeholder=\"Search by name or email...\"\n                className=\"card w-full px-3 h-10 border border-border\"\n                value={searchQuery}\n                onChange={e => setSearchQuery(e.target.value)}\n              />\n            </div>\n            <div className=\"flex-1 min-w-[150px]\">\n              <input \n                type=\"date\" \n                className=\"card w-full px-3 h-10 border border-border cursor-pointer\"\n                value={startDate}\n                onChange={e => handleSetStartDate(e.target.value)}\n                placeholder=\"Last Transaction From\"\n              />\n            </div>\n            <div className=\"flex-1 min-w-[150px]\">\n              <input \n                type=\"date\" \n                className=\"card w-full px-3 h-10 border border-border cursor-pointer\"\n                value={endDate}\n                onChange={e => setEndDate(e.target.value)}\n                placeholder=\"To\"\n              />\n            </div>\n            <div className=\"min-w-[200px]\">\n              <select \n                className=\"card w-full px-3 h-10 border border-border cursor-pointer\"\n                value={sortBy}\n                onChange={e => setSortBy(e.target.value as 'ltv' | 'name' | 'lastDate')}\n              >\n                <option value=\"ltv\">Sort by Lifetime Value</option>\n                <option value=\"name\">Sort by Name</option>\n                <option value=\"lastDate\">Sort by Last Transaction</option>\n              </select>\n            </div>\n            <button className=\"btn btn-ghost h-10 min-h-10\" onClick={handleClearFilters}>\n              Reset\n            </button>\n          </div>\n          <div className=\"overflow-x-auto\">\n            <table className=\"border-collapse w-full min-w-[600px] text-left\">\n            <thead>\n              <tr className=\"border-b-2 border-border text-text-muted text-sm\">\n                <th className=\"p-3 w-12 text-center\">\n                  <input \n                    type=\"checkbox\" \n                    checked={filteredPatrons.length > 0 && selectedIds.size === filteredPatrons.length}\n                    onChange={toggleSelectAll}\n                  />\n                </th>\n                <th className=\"p-3 text-left\">Name</th>\n                <th className=\"p-3 text-left\">Email</th>\n                <th className=\"p-3 text-left\">Type</th>\n                <th className=\"p-3 text-right\">LTV</th>\n                <th className=\"p-3 text-left\">Last Transaction</th>\n                <th className=\"p-3 text-right\">Orders</th>\n              </tr>\n            </thead>\n            <tbody>\n              {loading ? (\n                <tr><td colSpan={7} className=\"text-center p-8\">Loading patrons...</td></tr>\n              ) : filteredPatrons.length === 0 ? (\n                <tr><td colSpan={7} className=\"text-center p-8 flex flex-col items-center justify-center py-12 text-text-muted\">No patrons found matching your search.</td></tr>\n              ) : filteredPatrons.map(p => (\n                <tr key={p.profile.id} className=\"border-b border-border text-sm cursor-pointer hover:bg-primary-light\" onClick={() => handleOpenProfile(p.profile)}>\n                  <td className=\"p-3 w-12 text-center\" onClick={e => e.stopPropagation()}>\n                    <input \n                      type=\"checkbox\" \n                      checked={selectedIds.has(p.profile.id)}\n                      onChange={() => toggleSelect(p.profile.id)}\n                    />\n                  </td>\n                  <td className=\"p-3 font-semibold\">{p.profile.name}</td>\n                  <td className=\"p-3 text-sm text-muted\">\n                    {p.profile.expand?.user?.email || 'No email'}\n                  </td>\n                  <td className=\"p-3\">\n                    <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider ${p.isSinger ? 'bg-[#e6fffa] text-[#2c7a7b]' : 'bg-transparent text-text-muted'}`}>\n                      {p.isSinger ? 'Singer' : 'Patron'}\n                    </span>\n                  </td>\n                  <td className=\"p-3 text-right font-bold text-primary\">\n                    ${(p.ltvCents / 100).toLocaleString(undefined, { minimumFractionDigits: 2 })}\n                  </td>\n                  <td className=\"p-3 text-sm\">\n                    {formatInTimezone(p.lastTransactionDate, 'America/New_York', { month: 'short', day: 'numeric', year: 'numeric' })}\n                  </td>\n                  <td className=\"p-3 text-right text-muted\">{p.transactionCount}</td>\n                </tr>\n              ))}\n            </tbody>\n          </table>\n        </div>\n        </div>\n      </AppCard>\n\n      <SingerModal \n        isOpen={isModalOpen}\n        onClose={() => setIsModalOpen(false)}\n        onSave={handleSaveProfile}\n        onDelete={handleDeleteProfile}\n        initialData={selectedPatron}\n      />\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/admin/PollsDashboardView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":255,"column":23,"messageId":"fi