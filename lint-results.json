:215,"column":26,"messageId":"fix:sort","endLine":215,"endColumn":34,"fix":{"range":[8500,8547],"text":"h-[18px] w-[18px] cursor-pointer accent-primary"}},{"ruleId":"tailwindcss/enforces-shorthand","severity":1,"message":"'w-[18px]' can be merged with 'h-[18px]' into 'size-[18px]'","line":215,"column":26,"messageId":"fix:use-shorthand","endLine":215,"endColumn":34,"fix":{"range":[8500,8547],"text":"accent-primary cursor-pointer size-[18px]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":215,"column":35,"messageId":"fix:sort","endLine":215,"endColumn":43},{"ruleId":"tailwindcss/enforces-shorthand","severity":1,"message":"'h-[18px]' can be merged with 'w-[18px]' into 'size-[18px]'","line":215,"column":35,"messageId":"fix:use-shorthand","endLine":215,"endColumn":43,"fix":{"range":[8500,8547],"text":"accent-primary cursor-pointer size-[18px]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":215,"column":44,"messageId":"fix:sort","endLine":215,"endColumn":58},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":215,"column":59,"messageId":"fix:sort","endLine":215,"endColumn":73},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":219,"column":61,"messageId":"fix:sort","endLine":219,"endColumn":69,"fix":{"range":[8724,8779],"text":"flex flex-1 cursor-pointer flex-col gap-0.5 select-none"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":219,"column":70,"messageId":"fix:sort","endLine":219,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":219,"column":78,"messageId":"fix:sort","endLine":219,"endColumn":92},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":219,"column":93,"messageId":"fix:sort","endLine":219,"endColumn":104},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":219,"column":105,"messageId":"fix:sort","endLine":219,"endColumn":111},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":220,"column":40,"messageId":"fix:sort","endLine":220,"endColumn":53,"fix":{"range":[8813,8858],"text":"text-sm leading-tight font-semibold text-text"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":220,"column":54,"messageId":"fix:sort","endLine":220,"endColumn":63},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":220,"column":64,"messageId":"fix:sort","endLine":220,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":40,"messageId":"fix:sort","endLine":223,"endColumn":55,"fix":{"range":[8979,9016],"text":"text-xs leading-tight text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":56,"messageId":"fix:sort","endLine":223,"endColumn":69},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":232,"column":24,"messageId":"issue:unknown-classname","endLine":232,"endColumn":27,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[9236,9284],"text":"btn-primary btn-lg w-full h-12 font-semibold"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-primary' is not a Tailwind CSS class","line":232,"column":28,"messageId":"issue:unknown-classname","endLine":232,"endColumn":39,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-primary"},"fix":{"range":[9236,9284],"text":"btn btn-lg w-full h-12 font-semibold"},"desc":"Remove unknown classname 'btn-primary'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-lg' is not a Tailwind CSS class","line":232,"column":40,"messageId":"issue:unknown-classname","endLine":232,"endColumn":46,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-lg"},"fix":{"range":[9236,9284],"text":"btn btn-primary w-full h-12 font-semibold"},"desc":"Remove unknown classname 'btn-lg'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":232,"column":47,"messageId":"fix:sort","endLine":232,"endColumn":53,"fix":{"range":[9236,9284],"text":"btn btn-primary btn-lg h-12 w-full font-semibold"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":232,"column":54,"messageId":"fix:sort","endLine":232,"endColumn":58}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":108,"fixableErrorCount":0,"fixableWarningCount":28,"source":"import React, { useEffect, useState } from 'react';\nimport { useParams, Link } from 'react-router-dom';\nimport { pb } from '../lib/pocketbase';\nimport { eventService, type Event } from '../services/eventService';\nimport { ticketService } from '../services/ticketService';\nimport { AppCard } from '../components/common/AppCard';\nimport PublicLogo from '../components/common/PublicLogo';\nimport { sanitizeHtml } from '../lib/textSafety';\nimport { useDocumentTitle, useChoirName } from '../hooks/useDocumentTitle';\nimport { fetchChoirTimezone, formatInTimezone } from '../lib/timezone';\n\nexport default function PublicTicketPurchaseView() {\n  useDocumentTitle('Purchase Tickets');\n  const { choirName } = useChoirName();\n  const { eventId } = useParams<{ eventId: string }>();\n  const [event, setEvent] = useState<Event | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState('');\n  const [quantity, setQuantity] = useState(1);\n  const [name, setName] = useState('');\n  const [email, setEmail] = useState('');\n  const [confirmEmail, setConfirmEmail] = useState('');\n  const [marketingOptIn, setMarketingOptIn] = useState(false);\n  const [submitting, setSubmitting] = useState(false);\n  const [timezone, setTimezone] = useState('America/New_York');\n\n  useEffect(() => {\n    async function loadData() {\n      try {\n        if (!eventId) return;\n        const [res, tz] = await Promise.all([\n          eventService.getPublicEventById(eventId),\n          fetchChoirTimezone().catch(() => 'America/New_York')\n        ]);\n        setEvent(res);\n        setTimezone(tz);\n      } catch {\n        setError('Event not found.');\n      } finally {\n        setLoading(false);\n      }\n    }\n    loadData();\n  }, [eventId]);\n\n  if (loading) {\n    return (\n      <div className=\"flex flex-col min-h-screen justify-center items-center w-screen\">\n        <p className=\"text-text-muted\">Loading details...</p>\n      </div>\n    );\n  }\n\n  if (error || !event || !event.isTicketingEnabled || event.isArchived) {\n    return (\n      <div className=\"flex flex-col min-h-screen justify-center items-center w-screen p-4\">\n        <AppCard className=\"w-full max-w-[480px] text-center\">\n          <p className=\"text-danger-text m-0\">\n            {error || (!event ? 'Event not found.' : 'Ticket sales are closed for this event.')}\n          </p>\n          <Link to=\"/tickets\" className=\"btn btn-ghost no-underline\">Back to Events</Link>\n        </AppCard>\n      </div>\n    );\n  }\n\n  const nowFormatted = formatInTimezone(new Date(), timezone, {});\n  const eventFormatted = formatInTimezone(new Date(event.date), timezone, {});\n  const nowStr = nowFormatted.split(\",\")[0];\n  const eventDateStr = eventFormatted.split(\",\")[0];\n\n  const isShowDay = nowStr === eventDateStr;\n  const unitPrice = isShowDay ? (event.dayOfPriceCents || 0) : (event.advancePriceCents || 0);\n\n  const totalTicketsCents = unitPrice * quantity;\n  const feeCents = totalTicketsCents > 0 ? (Math.round(totalTicketsCents * 0.029) + 30) : 0;\n  const totalCents = totalTicketsCents + feeCents;\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (email.trim() !== confirmEmail.trim()) {\n      setError(\"Email addresses must match.\");\n      return;\n    }\n    setSubmitting(true);\n    setError('');\n    try {\n      const session = await ticketService.createCheckoutSession(event.id, quantity, email.trim(), name.trim());\n      if (session.url) {\n        window.location.href = session.url;\n      } else {\n        throw new Error('Stripe Checkout URL not returned');\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err);\n      setError(msg || 'Stripe redirection failed.');\n      setSubmitting(false);\n    }\n  };\n\n  return (\n    <div className=\"flex flex-col min-h-screen justify-start items-center w-screen p-4\">\n      <PublicLogo />\n      <AppCard className=\"w-full max-w-[720px]\">\n        <div className=\"flex flex-col gap-2\">\n          <Link to=\"/tickets\" className=\"btn btn-ghost btn-sm self-start\">← Back to Events</Link>\n          <div className=\"flex flex-col gap-0.5\">\n            {choirName && <span className=\"text-xs text-text-muted font-bold uppercase tracking-wider\">{choirName}</span>}\n            <h1 className=\"text-display m-0\">Buy Tickets</h1>\n          </div>\n        </div>\n\n        <div className=\"card flex flex-col md:flex-row p-4 gap-4 bg-primary-light\">\n          {event.eventGraphic && (\n            <img\n              src={pb.files.getURL(event, event.eventGraphic)}\n              alt={event.title} className=\"w-full max-w-[240px] max-h-40 object-cover rounded-sm\"\n            />\n          )}\n          <div className=\"flex-1 flex flex-col gap-1\">\n            <h3 className=\"m-0 text-primary-deep\">{event.title}</h3>\n            <p className=\"text-body m-0\">\n              Date: <strong>{formatInTimezone(event.date, timezone, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: 'numeric', minute: '2-digit' })}</strong>\n            </p>\n            {event.doorsOpenTime && (\n              <p className=\"text-text-muted text-sm m-0\">\n                Doors Open: <strong>{event.doorsOpenTime}</strong>\n              </p>\n            )}\n          </div>\n        </div>\n\n        {event.publicDetails && (\n          <div className=\"flex flex-col gap-1 border-b border-border pb-4\">\n            <span className=\"text-xs text-text-muted font-bold uppercase\">Event Details</span>\n            <div \n              className=\"text-body\"\n              dangerouslySetInnerHTML={{ __html: sanitizeHtml(event.publicDetails) }}\n            />\n          </div>\n        )}\n\n        <form onSubmit={handleSubmit} className=\"flex flex-col gap-6\">\n          {error && <p className=\"text-danger-text m-0\">{error}</p>}\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-label\">Your Name (for Will Call)</label>\n            <input\n              type=\"text\"\n              required\n              className=\"card px-3 h-10\"\n              value={name}\n              onChange={e => setName(e.target.value)}\n            />\n          </div>\n\n          <div className=\"flex flex-col md:flex-row gap-4\">\n            <div className=\"flex-1 flex flex-col gap-1\">\n              <label className=\"text-label\">Email Address</label>\n              <input\n                type=\"email\"\n                required\n                className=\"card px-3 h-10\"\n                value={email}\n                onChange={e => setEmail(e.target.value)}\n              />\n            </div>\n            <div className=\"flex-1 flex flex-col gap-1\">\n              <label className=\"text-label\">Confirm Email</label>\n              <input\n                type=\"email\"\n                required\n                className=\"card px-3 h-10\"\n                value={confirmEmail}\n                onChange={e => setConfirmEmail(e.target.value)}\n              />\n            </div>\n          </div>\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-label\">Ticket Quantity</label>\n            <input\n              type=\"number\"\n              min=\"1\"\n              max=\"10\"\n              required\n              className=\"card px-3 h-10\"\n              value={quantity}\n              onChange={e => setQuantity(Math.max(1, Math.min(10, Number(e.target.value))))}\n            />\n          </div>\n\n          <div className=\"card w-full p-4 flex flex-col gap-1 bg-neutral-bg\">\n            <h4 className=\"m-0 text-primary-deep\">Pricing Summary</h4>\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span>Ticket Price ({quantity} x ${(unitPrice / 100).toFixed(2)})</span>\n              <span>${((unitPrice * quantity) / 100).toFixed(2)}</span>\n            </div>\n            {feeCents > 0 && (\n              <div className=\"flex flex-row justify-between text-sm\">\n                <span>Processing Fee</span>\n                <span>${(feeCents / 100).toFixed(2)}</span>\n              </div>\n            )}\n            <div className=\"flex flex-row justify-between font-bold border-t border-border pt-1 mt-1\">\n              <span>Total Cost</span>\n              <span>${(totalCents / 100).toFixed(2)}</span>\n            </div>\n          </div>\n\n          <div className=\"flex flex-row p-4 gap-4 items-start bg-neutral-bg border border-border rounded-lg mt-1\">\n            <input\n              id=\"marketingOptIn\"\n              type=\"checkbox\"\n              className=\"w-[18px] h-[18px] accent-primary cursor-pointer\"\n              checked={marketingOptIn}\n              onChange={e => setMarketingOptIn(e.target.checked)}\n            />\n            <label htmlFor=\"marketingOptIn\" className=\"flex flex-col gap-0.5 cursor-pointer select-none flex-1\">\n              <span className=\"text-sm font-semibold text-text leading-tight\">\n                Email me future choir performance announcements.\n              </span>\n              <span className=\"text-xs text-text-muted leading-tight\">\n                No weekly emails. Unsubscribe anytime.\n              </span>\n            </label>\n          </div>\n\n          <button\n            type=\"submit\"\n            disabled={submitting}\n            className=\"btn btn-primary btn-lg w-full h-12 font-semibold\"\n          >\n            {submitting ? \"Opening Secure Checkout…\" : \"Proceed to Payment\"}\n          </button>\n        </form>\n      </AppCard>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/PublicTicketSuccessView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":37,"column":28,"messageId":"fix:sort","endLine":37,"endColumn":36,"fix":{"range":[1248,1311],"text":"flex min-h-screen w-screen flex-col items-center justify-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":37,"column":37,"messageId":"fix:sort","endLine":37,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":37,"column":50,"messageId":"fix:sort","endLine":37,"endColumn":64},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":37,"column":78,"messageId":"fix:sort","endLine":37,"endColumn":86},{"ruleId":"tailwindcss/classnames-order","severity"