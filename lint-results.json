;\n    };\n    document.addEventListener('keydown', handleKey);\n    return () => document.removeEventListener('keydown', handleKey);\n  }, [isOpen, onClose]);\n\n  useEffect(() => {\n    if (!isOpen) return;\n    const firstInput = modalRef.current?.querySelector(\n      'input, button, select, textarea, [tabindex]:not([tabindex=\"-1\"])'\n    ) as HTMLElement | null;\n    firstInput?.focus();\n  }, [isOpen]);\n\n  if (!isOpen) return null;\n\n  const handleOverlayClick = (e: React.MouseEvent) => {\n    if (e.target === e.currentTarget) onClose();\n  };\n\n  return createPortal(\n    <div className=\"fixed inset-0 z-[1000] bg-black/40 flex items-center justify-center p-4 animate-[modal-fade-in_0.2s_ease-out]\" role=\"presentation\" onMouseDown={handleOverlayClick}>\n      <div ref={modalRef} className=\"bg-surface border border-border rounded-lg shadow-md p-6 flex flex-col gap-4 w-full animate-[modal-slide-up_0.3s_cubic-bezier(0.16,1,0.3,1)]\" role=\"dialog\" aria-modal=\"true\"\n        aria-labelledby={title ? titleId : undefined}\n        // @allow-inline-style - dynamic maxWidth from props\n        style={{ maxWidth }}>\n        {title && (\n          <div className=\"flex justify-between items-center\">\n            <h2 className=\"m-0 text-2xl font-semibold text-text\" id={titleId}>{title}</h2>\n            <button className=\"inline-flex items-center justify-center w-8 h-8 border-none bg-transparent text-text-muted cursor-pointer rounded hover:bg-primary-light hover:text-primary-deep text-xl p-0\" onClick={onClose} aria-label=\"Close\" type=\"button\">\n              ✕\n            </button>\n          </div>\n        )}\n        <div className=\"flex-1\">{children}</div>\n        {footer && <div className=\"flex justify-end gap-2 pt-2 border-t border-border\">{footer}</div>}\n      </div>\n    </div>,\n    document.body\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/ui/Pagination/Pagination.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/ui/Pagination/Pagination.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":44,"column":67,"messageId":"fix:sort","endLine":44,"endColumn":79,"fix":{"range":[1823,1903],"text":"inline-flex h-9 min-w-[36px] items-center justify-center text-sm text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":44,"column":80,"messageId":"fix:sort","endLine":44,"endColumn":94},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":44,"column":95,"messageId":"fix:sort","endLine":44,"endColumn":107},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":44,"column":108,"messageId":"fix:sort","endLine":44,"endColumn":111},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":44,"column":112,"messageId":"fix:sort","endLine":44,"endColumn":127},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":44,"column":128,"messageId":"fix:sort","endLine":44,"endColumn":135}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":6,"fixableErrorCount":0,"fixableWarningCount":1,"source":"import { useMemo } from 'react';\nimport { computePaginationRange, DOTS } from '../../../lib/paginationUtils';\nimport type { PaginationProps as CommonPaginationProps } from '../../common/Pagination';\n\nexport type { CommonPaginationProps as PaginationProps };\n\nconst baseBtnClass = [\n  'inline-flex items-center justify-center',\n  'min-w-[36px] h-9 px-1',\n  'border border-border rounded',\n  'bg-surface text-text text-sm',\n  'cursor-pointer transition-colors duration-200',\n  'disabled:opacity-40 disabled:cursor-not-allowed',\n  'hover:bg-primary-light hover:border-primary hover:text-primary-deep',\n].join(' ');\n\nconst activeBtnClass = 'bg-primary text-surface border-primary hover:bg-primary-deep hover:text-surface';\n\nexport function Pagination({\n  currentPage, totalPages, onPageChange, siblingCount = 1,\n}: CommonPaginationProps) {\n  const paginationRange = useMemo(() => {\n    return computePaginationRange(currentPage, totalPages, siblingCount);\n  }, [currentPage, totalPages, siblingCount]);\n\n  if (totalPages <= 1) return null;\n\n  const handlePageChange = (page: number) => {\n    if (page >= 1 && page <= totalPages && page !== currentPage) {\n      onPageChange(page);\n    }\n  };\n\n  return (\n    <nav className=\"flex items-center gap-1\" role=\"navigation\" aria-label=\"Pagination Navigation\">\n      <button type=\"button\" className={baseBtnClass}\n        onClick={() => handlePageChange(1)} disabled={currentPage === 1}\n        aria-label=\"Go to first page\">{'\\u23EE'}</button>\n      <button type=\"button\" className={baseBtnClass}\n        onClick={() => handlePageChange(currentPage - 1)} disabled={currentPage === 1}\n        aria-label=\"Go to previous page\">{'\\u25C0'}</button>\n      {paginationRange.map((pageNumber, idx) => {\n        if (pageNumber === DOTS) {\n          return <span key={`dots-${idx}`} className=\"inline-flex items-center justify-center min-w-[36px] h-9 text-text-muted text-sm\" aria-hidden=\"true\">{'\\u2026'}</span>;\n        }\n        const pageNum = pageNumber as number;\n        const isCurrent = pageNum === currentPage;\n        return (\n          <button key={pageNum} type=\"button\"\n            className={[baseBtnClass, isCurrent ? activeBtnClass : ''].filter(Boolean).join(' ')}\n            onClick={() => handlePageChange(pageNum)}\n            aria-label={`Go to page ${pageNum}`}\n            aria-current={isCurrent ? 'page' : undefined}>\n            {pageNum}\n          </button>\n        );\n      })}\n      <button type=\"button\" className={baseBtnClass}\n        onClick={() => handlePageChange(currentPage + 1)} disabled={currentPage === totalPages}\n        aria-label=\"Go to next page\">{'\\u25B6'}</button>\n      <button type=\"button\" className={baseBtnClass}\n        onClick={() => handlePageChange(totalPages)} disabled={currentPage === totalPages}\n        aria-label=\"Go to last page\">{'\\u23ED'}</button>\n    </nav>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/ui/PhotoUploader/PhotoUploader.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/ui/PhotoUploader/PhotoUploader.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":399,"column":29,"messageId":"fix:sort","endLine":399,"endColumn":41,"fix":{"range":[12045,12129],"text":"relative shrink-0 overflow-hidden rounded-full border border-border bg-primary-light"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":399,"column":58,"messageId":"fix:sort","endLine":399,"endColumn":66},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":399,"column":67,"messageId":"fix:sort","endLine":399,"endColumn":83},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":399,"column":84,"messageId":"fix:sort","endLine":399,"endColumn":90},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":399,"column":91,"messageId":"fix:sor