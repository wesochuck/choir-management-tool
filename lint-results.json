flex shrink-0 items-center rounded-full px-1.5 py-0.5 text-xs font-bold tracking-wide uppercase transition-colors ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":46,"messageId":"fix:sort","endLine":201,"endColumn":57},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":71,"messageId":"fix:sort","endLine":201,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":78,"messageId":"fix:sort","endLine":201,"endColumn":84},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":85,"messageId":"fix:sort","endLine":201,"endColumn":92},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":93,"messageId":"fix:sort","endLine":201,"endColumn":102},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":103,"messageId":"fix:sort","endLine":201,"endColumn":116},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":117,"messageId":"fix:sort","endLine":201,"endColumn":126},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":127,"messageId":"fix:sort","endLine":201,"endColumn":139},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":237,"messageId":"fix:sort","endLine":201,"endColumn":258,"fix":{"range":[9549,9599],"text":"} max-sm:px-1 max-sm:py-0.5 max-sm:text-[0.55rem]`"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":259,"messageId":"fix:sort","endLine":201,"endColumn":270},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":201,"column":271,"messageId":"fix:sort","endLine":201,"endColumn":284}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":147,"fixableErrorCount":0,"fixableWarningCount":29,"source":"import React from 'react';\nimport type { PlayerMediaFile } from '../../services/playerService';\n\nconst MusicIcon = () => (\n  <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n    <path d=\"M9 18V5l12-2v13\"></path>\n    <circle cx=\"6\" cy=\"18\" r=\"3\"></circle>\n    <circle cx=\"18\" cy=\"16\" r=\"3\"></circle>\n  </svg>\n);\n\ninterface PlaylistProps {\n  playlist: PlayerMediaFile[];\n  currentIndex: number;\n  onTrackSelect: (index: number) => void;\n  onDownloadTrack: (track: PlayerMediaFile) => void;\n  onRemoveDownload: (track: PlayerMediaFile) => void;\n  downloadProgressById: Record<string, number>;\n  selectedVoicePart?: string;\n  onDownloadAll: () => void;\n  onClearAll: () => void;\n  isDownloadingAll: boolean;\n}\n\nexport const Playlist: React.FC<PlaylistProps> = ({ \n  playlist, \n  currentIndex, \n  onTrackSelect,\n  onDownloadTrack,\n  onRemoveDownload,\n  downloadProgressById,\n  selectedVoicePart,\n  onDownloadAll,\n  onClearAll,\n  isDownloadingAll,\n}) => {\n  if (playlist.length === 0) return null;\n\n  const renderDownloadStatus = (item: PlayerMediaFile) => {\n    if (item.isFolder) return null;\n\n    const status = item.downloadStatus || 'idle';\n    const progress = downloadProgressById[item.id] || 0;\n\n    const stopPropagation = (e: React.MouseEvent) => {\n      e.stopPropagation();\n    };\n\n    if (status === 'downloading') {\n      return (\n        <span className=\"flex items-center gap-1 shrink-0\" onClick={stopPropagation} aria-label=\"Downloading\">\n          <svg className=\"-rotate-90\" width=\"20\" height=\"20\">\n            <circle\n              className=\"progress-ring__circle-bg\"\n              stroke=\"var(--border-color)\"\n              strokeWidth=\"2\"\n              fill=\"transparent\"\n              r=\"8\"\n              cx=\"10\"\n              cy=\"10\"\n            />\n            <circle\n              className=\"progress-ring__circle\"\n              stroke=\"var(--accent-color)\"\n              strokeWidth=\"2\"\n              fill=\"transparent\"\n              r=\"8\"\n              cx=\"10\"\n              cy=\"10\"\n              strokeDasharray={`${2 * Math.PI * 8}`}\n              strokeDashoffset={`${2 * Math.PI * 8 * (1 - progress / 100)}`}\n            />\n          </svg>\n          <span className=\"text-[10px] text-text-muted tabular-nums\">{progress}%</span>\n        </span>\n      );\n    }\n\n    if (item.isDownloaded) {\n      return (\n        <button\n          className=\"shrink-0 flex items-center justify-center w-8 h-8 rounded-full bg-transparent border-none cursor-pointer text-primary transition-all hover:bg-primary-light hover:text-primary\"\n          onClick={(e) => {\n            e.stopPropagation();\n            onRemoveDownload(item);\n          }}\n          title=\"Remove offline copy\"\n          aria-label=\"Remove download\"\n        >\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n            <polyline points=\"20 6 9 17 4 12\"></polyline>\n          </svg>\n        </button>\n      );\n    }\n\n    if (navigator.onLine) {\n      return (\n        <button\n          className=\"shrink-0 flex items-center justify-center w-8 h-8 rounded-full bg-transparent border-none cursor-pointer text-text-muted transition-all hover:bg-primary-light hover:text-primary\"\n          onClick={(e) => {\n            e.stopPropagation();\n            onDownloadTrack(item);\n          }}\n          title=\"Download for offline playback\"\n          aria-label=\"Download track\"\n        >\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n            <path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"></path>\n            <polyline points=\"7 10 12 15 17 10\"></polyline>\n            <line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\"></line>\n          </svg>\n        </button>\n      );\n    }\n\n    return null;\n  };\n\n  const audioTracks = playlist.filter(f => !f.isFolder);\n  const downloadedCount = audioTracks.filter(f => f.isDownloaded).length;\n  const totalCount = audioTracks.length;\n  const allDownloaded = downloadedCount === totalCount && totalCount > 0;\n\n  return (\n    <div className=\"mt-6 bg-surface rounded-xl max-h-[500px] overflow-y-auto border border-border shadow-md relative max-sm:rounded-lg max-sm:max-h-none max-sm:overflow-y-visible\">\n      <div className=\"sticky top-0 z-10 bg-surface flex items-center justify-between gap-3 px-5 py-4 border-b border-border max-[480px]:flex-col max-[480px]:items-stretch\">\n        <div className=\"flex items-baseline gap-2 min-w-0 max-[480px]:justify-between\">\n          <span className=\"text-base font-bold text-text whitespace-nowrap\">Set List</span>\n          <span className=\"text-xs text-text-muted tabular-nums\">{totalCount} track{totalCount !== 1 ? 's' : ''}</span>\n        </div>\n        <div className=\"flex items-center gap-2 shrink-0 max-[480px]:grid max-[480px]:grid-cols-2 max-[480px]:w-full\">\n          {downloadedCount > 0 && (\n            <button\n              className=\"inline-flex items-center gap-1 px-3 py-1.5 rounded-full border border-border bg-primary-light text-text-muted text-xs font-bold uppercase tracking-wider cursor-pointer whitespace-nowrap transition-all hover:border-danger-text hover:text-danger-text hover:bg-danger-bg disabled:opacity-60 disabled:cursor-default max-[480px]:w-full max-[480px]:justify-center\"\n              onClick={onClearAll}\n              title=\"Remove all offline downloads\"\n              aria-label=\"Clear all downloads\"\n            >\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                <polyline points=\"3 6 5 6 21 6\"></polyline>\n                <path d=\"M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6\"></path>\n                <path d=\"M10 11v6\"></path>\n                <path d=\"M14 11v6\"></path>\n              </svg>\n              Clear ({downloadedCount})\n            </button>\n          )}\n          {!allDownloaded && (\n            <button\n              className={`inline-flex items-center gap-1 px-3 py-1.5 rounded-full border text-xs font-bold uppercase tracking-wider cursor-pointer whitespace-nowrap transition-all disabled:opacity-60 disabled:cursor-default ${isDownloadingAll ? 'bg-primary-light text-primary border-primary' : 'border-primary text-primary bg-primary-light hover:bg-primary hover:text-surface'} max-[480px]:w-full max-[480px]:justify-center`}\n              onClick={onDownloadAll}\n              disabled={isDownloadingAll}\n              title=\"Download all tracks for offline playback\"\n              aria-label=\"Download all tracks\"\n            >\n              {isDownloadingAll ? (\n                <>\n                  <svg className=\"animate-spin\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                    <path d=\"M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83\"/>\n                  </svg>\n                  Downloading…\n                </>\n              ) : (\n                <>\n                  <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                    <path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"></path>\n                    <polyline points=\"7 10 12 15 17 10\"></polyline>\n                    <line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\"></line>\n                  </svg>\n                  Download All\n                </>\n              )}\n            </button>\n          )}\n        </div>\n      </div>\n      <ul className=\"list-none p-2 px-3 pb-3 m-0 max-sm:p-2\">\n        {playlist.map((item, index) => {\n            const activeKey = item.trackKey || 'tutti';\n            const isFallback = selectedVoicePart && selectedVoicePart !== 'tutti' && activeKey === 'tutti';\n            return (\n              <li \n                key={item.id} \n                className={`p-3 px-4 rounded-lg cursor-pointer flex items-center gap-3 transition-colors mb-1 border border-transparent hover:bg-primary-light ${index === currentIndex ? 'bg-primary-light text-primary font-semibold border-primary' : ''} max-sm:p-2 max-sm:px-3 max-sm:gap-2 max-sm:min-h-[56px]`}\n                onClick={() => onTrackSelect(index)}\n              >\n                <span className={`shrink-0 w-7 h-7 flex items-center justify-center ${index === currentIndex ? 'text-primary' : 'text-text-muted'}`}>\n                  <MusicIcon />\n                </span>\n                <div className=\"flex flex-col flex-1 overflow-hidden min-w-0\">\n                  <span className=\"text-sm font-semibold truncate\">{item.name}</span>\n                  {item.parentTitle && (\n                    <span className=\"text-xs text-text-muted opacity-85 font-medium truncate\">\n                      From: {item.parentTitle}\n                    </span>\n                  )}\n                  {item.composer && <span className=\"text-xs text-text-muted opacity-80 truncate\">{item.composer}</span>}\n                </div>\n                {!item.isFolder && (\n                  <span className={`shrink-0 inline-flex items-center px-1.5 py-0.5 text-xs font-bold tracking-wide uppercase rounded-full transition-colors ${isFallback ? 'bg-amber-50 text-amber-600' : 'bg-primary-light text-primary'} max-sm:text-[0.55rem] max-sm:px-1 max-sm:py-0.5`}>\n                    {activeKey.toUpperCase()}\n                  </span>\n                )}\n                {renderDownloadStatus(item)}\n              </li>\n            );\n          })}\n      </ul>\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/player/VoicePartSelector.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":22,"column":21,"messageId":"fix:sort","endLine":22,"endColumn":25,"fix":{"range":[572,612],"text":"mb-6 flex flex-wrap justify-center gap-2"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":22,"column":26,"messageId":"fix:sort","endLine":22,"endColumn":31},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":22,"column":42,"messageId":"fix:sort","endLine":22,"endColumn":46},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":22,"column":47,"messageId":"fix:sort","endLine":22,"endColumn":61},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":27,"column":23,"messageId":"fix:sort","endLine":27,"endColumn":27,"fix":{"range":[732,817],"text":"`cursor-pointer rounded-full border px-4 py-2 text-sm font-semibold transition-all ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":27,"column":28,"messageId":"fix:sort","endLine":27,"endC