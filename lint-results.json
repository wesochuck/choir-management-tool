 h-7 rounded-full border inline-flex items-center justify-center text-xs font-semibold transition-all duration-150 ${\n                isActive ? 'bg-primary border-primary text-white' : \n                isCompleted ? 'bg-primary-light border-border text-text-muted' : \n                'bg-transparent border-border text-text-muted'\n              }`}>\n                {isCompleted ? '✓' : step.number}\n              </span>\n              <span className={`text-sm transition-all duration-150 ${\n                isActive ? 'text-primary-deep font-semibold' : 'text-text-muted'\n              }`}>{step.label}</span>\n            </button>\n\n            {index < steps.length - 1 && (\n              <span className=\"h-px flex-1 bg-border mx-2\" aria-hidden=\"true\" />\n            )}\n          </div>\n        );\n      })}\n    </div>\n  );\n};\n\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/AuditionModal.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":93,"column":44,"messageId":"issue:unknown-classname","endLine":93,"endColumn":47,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[3072,3085],"text":"btn-ghost"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-ghost' is not a Tailwind CSS class","line":93,"column":48,"messageId":"issue:unknown-classname","endLine":93,"endColumn":57,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-ghost"},"fix":{"range":[3072,3085],"text":"btn"},"desc":"Remove unknown classname 'btn-ghost'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":94,"column":65,"messageId":"issue:unknown-classname","endLine":94,"endColumn":68,"suggestions":[{"messageId":"fix