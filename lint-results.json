classname":"btn-primary"},"fix":{"range":[34824,34867],"text":"btn flex items-center gap-[6px]"},"desc":"Remove unknown classname 'btn-primary'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'card' is not a Tailwind CSS class","line":934,"column":25,"messageId":"issue:unknown-classname","endLine":934,"endColumn":29,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[35031,35195],"text":"bg-white text-[#333] border border-[var(--border)] rounded-[var(--radius-md)] p-[var(--space-lg)] font-[Georgia,serif] shadow-[inset_0_2px_4px_rgb(0_0_0_/_6%)]"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":934,"column":30,"messageId":"fix:sort","endLine":934,"endColumn":38,"fix":{"range":[35031,35195],"text":"card rounded-[var(--radius-md)] border border-[var(--border)] bg-white p-[var(--space-lg)] font-[Georgia,serif] text-[#333] shadow-[inset_0_2px_4px_rgb(0_0_0_/_6%)]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":934,"column":39,"messageId":"fix:sort","endLine":934,"endColumn":50},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":934,"column":51,"messageId":"fix:sort","endLine":934,"endColumn":57},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":934,"column":58,"messageId":"fix:sort","endLine":934,"endColumn":80},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":934,"column":81,"messageId":"fix:sort","endLine":934,"endColumn":107},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":934,"column":108,"messageId":"fix:sort","endLine":934,"endColumn":127},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":934,"column":128,"messageId":"fix:sort","endLine":934,"endColumn":148},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":935,"column":27,"messageId":"fix:sort","endLine":935,"endColumn":38,"fix":{"range":[35224,35256],"text":"mb-[var(--space-md)] text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":935,"column":39,"messageId":"fix:sort","endLine":935,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":936,"column":69,"messageId":"fix:sort","endLine":936,"endColumn":80,"fix":{"range":[35286,35348],"text":"!m-0 mb-[var(--space-xxs)] text-[1.4rem] font-bold text-[#111]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":936,"column":81,"messageId":"fix:sort","endLine":936,"endColumn":90},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":939,"column":44,"messageId":"fix:sort","endLine":939,"endColumn":55,"fix":{"range":[35457,35495],"text":"text-[0.85rem] font-medium text-[#666]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":939,"column":56,"messageId":"fix:sort","endLine":939,"endColumn":67},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":945,"column":27,"messageId":"fix:sort","endLine":945,"endColumn":35,"fix":{"range":[35932,35975],"text":"mb-[var(--space-md)] border-b border-[#eee]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":945,"column":36,"messageId":"fix:sort","endLine":945,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid T