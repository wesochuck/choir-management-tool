ne":223,"endColumn":108},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":109,"messageId":"fix:sort","endLine":223,"endColumn":113},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":227,"column":26,"messageId":"fix:sort","endLine":227,"endColumn":34,"fix":{"range":[9098,9145],"text":"h-[18px] w-[18px] cursor-pointer accent-primary"}},{"ruleId":"tailwindcss/enforces-shorthand","severity":1,"message":"'w-[18px]' can be merged with 'h-[18px]' into 'size-[18px]'","line":227,"column":26,"messageId":"fix:use-shorthand","endLine":227,"endColumn":34,"fix":{"range":[9098,9145],"text":"accent-primary cursor-pointer size-[18px]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":227,"column":35,"messageId":"fix:sort","endLine":227,"endColumn":43},{"ruleId":"tailwindcss/enforces-shorthand","severity":1,"message":"'h-[18px]' can be merged with 'w-[18px]' into 'size-[18px]'","line":227,"column":35,"messageId":"fix:use-shorthand","endLine":227,"endColumn":43,"fix":{"range":[9098,9145],"text":"accent-primary cursor-pointer size-[18px]"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":227,"column":44,"messageId":"fix:sort","endLine":227,"endColumn":58},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":227,"column":59,"messageId":"fix:sort","endLine":227,"endColumn":73},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":231,"column":61,"messageId":"fix:sort","endLine":231,"endColumn":69,"fix":{"range":[9322,9377],"text":"flex flex-1 cursor-pointer flex-col gap-0.5 select-none"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":231,"column":70,"messageId":"fix:sort","endLine":231,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":231,"column":78,"messageId":"fix:sort","endLine":231,"endColumn":92},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":231,"column":93,"messageId":"fix:sort","endLine":231,"endColumn":104},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":231,"column":105,"messageId":"fix:sort","endLine":231,"endColumn":111},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":232,"column":40,"messageId":"fix:sort","endLine":232,"endColumn":53,"fix":{"range":[9411,9456],"text":"text-sm leading-tight font-semibold text-text"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":232,"column":54,"messageId":"fix:sort","endLine":232,"endColumn":63},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":232,"column":64,"messageId":"fix:sort","endLine":232,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":235,"column":40,"messageId":"fix:sort","endLine":235,"endColumn":55,"fix":{"range":[9577,9614],"text":"text-xs leading-tight text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":235,"column":56,"messageId":"fix:sort","endLine":235,"endColumn":69},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":244,"column":24,"messageId":"issue:unknown-classname","endLine":244,"endColumn":27,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[9834,9882],"text":"btn-primary btn-lg w-full h-12 font-semibold"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-primary' is not a Tailwind CSS class","line":244,"column":28,"messageId":"issue:unknown-classname","endLine":244,"endColumn":39,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-primary"},"fix":{"range":[9834,9882],"text":"btn btn-lg w-full h-12 font-semibold"},"desc":"Remove unknown classname 'btn-primary'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-lg' is not a Tailwind CSS class","line":244,"column":40,"messageId":"issue:unknown-classname","endLine":244,"endColumn":46,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-lg"},"fix":{"range":[9834,9882],"text":"btn btn-primary w-full h-12 font-semibold"},"desc":"Remove unknown classname 'btn-lg'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":244,"column":47,"messageId":"fix:sort","endLine":244,"endColumn":53,"fix":{"range":[9834,9882],"text":"btn btn-primary btn-lg h-12 w-full font-semibold"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":244,"column":54,"messageId":"fix:sort","endLine":244,"endColumn":58}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":120,"fixableErrorCount":0,"fixableWarningCount":32,"source":"import React, { useEffect, useState } from 'react';\nimport { useParams, Link } from 'react-router-dom';\nimport { pb } from '../lib/pocketbase';\nimport { ticketService, type TicketBundle } from '../services/ticketService';\nimport { AppCard } from '../components/common/AppCard';\nimport { useDocumentTitle, useChoirName } from '../hooks/useDocumentTitle';\nimport { fetchChoirTimezone, formatInTimezone } from '../lib/timezone';\nimport { sanitizeHtml } from '../lib/textSafety';\n\nexport default function PublicBundlePurchaseView() {\n  useDocumentTitle('Purchase Season Tickets');\n  const { choirName } = useChoirName();\n  const { bundleId } = useParams<{ bundleId: string }>();\n  const [bundle, setBundle] = useState<TicketBundle | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState('');\n  const [quantity, setQuantity] = useState(1);\n  const [name, setName] = useState('');\n  const [email, setEmail] = useState('');\n  const [confirmEmail, setConfirmEmail] = useState('');\n  const [marketingOptIn, setMarketingOptIn] = useState(false);\n  const [submitting, setSubmitting] = useState(false);\n  const [timezone, setTimezone] = useState('America/New_York');\n\n  useEffect(() => {\n    async function loadData() {\n      try {\n        if (!bundleId) return;\n        const [res, tz] = await Promise.all([\n          pb.collection('ticketBundles').getOne<TicketBundle>(bundleId, { expand: 'events' }),\n          fetchChoirTimezone().catch(() => 'America/New_York')\n        ]);\n        setBundle(res);\n        setTimezone(tz);\n      } catch {\n        setError('Season Ticket Bundle not found.');\n      } finally {\n        setLoading(false);\n      }\n    }\n    loadData();\n  }, [bundleId]);\n\n  if (loading) {\n    return (\n      <div className=\"flex flex-col min-h-screen justify-center items-center w-screen\">\n        <p className=\"text-text-muted\">Loading details...</p>\n      </div>\n    );\n  }\n\n  if (error || !bundle || !bundle.isActive) {\n    return (\n      <div className=\"flex flex-col min-h-screen justify-center items-center w-screen p-4\">\n        <AppCard className=\"w-full max-w-[480px] text-center\">\n          <p className=\"text-danger-text m-0\">\n            {error || 'This season ticket bundle is not currently active for purchase.'}\n          </p>\n          <Link to=\"/tickets\" className=\"btn btn-ghost no-underline\">Back to Concerts</Link>\n        </AppCard>\n      </div>\n    );\n  }\n\n  const saleEndDate = new Date(bundle.saleEndDate.replace(' ', 'T'));\n  if (new Date() > saleEndDate) {\n    return (\n      <div className=\"flex flex-col min-h-screen justify-center items-center w-screen p-4\">\n        <AppCard className=\"w-full max-w-[480px] text-center\">\n          <p className=\"text-danger-text m-0\">\n            The sale period for this season ticket bundle has ended.\n          </p>\n          <Link to=\"/tickets\" className=\"btn btn-ghost no-underline\">Back to Concerts</Link>\n        </AppCard>\n      </div>\n    );\n  }\n\n  const unitPrice = bundle.priceCents || 0;\n  const totalTicketsCents = unitPrice * quantity;\n  const feeCents = totalTicketsCents > 0 ? (Math.round(totalTicketsCents * 0.029) + 30) : 0;\n  const totalCents = totalTicketsCents + feeCents;\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (email.trim() !== confirmEmail.trim()) {\n      setError(\"Email addresses must match.\");\n      return;\n    }\n    setSubmitting(true);\n    setError('');\n    try {\n      const session = await ticketService.createBundleCheckoutSession(bundle.id, quantity, email.trim(), name.trim());\n      if (session.url) {\n        window.location.href = session.url;\n      } else {\n        throw new Error('Stripe Checkout URL not returned');\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err);\n      setError(msg || 'Stripe redirection failed.');\n      setSubmitting(false);\n    }\n  };\n\n  const includedEvents = bundle.expand?.events || [];\n\n  return (\n    <div className=\"flex flex-col min-h-screen justify-start items-center w-screen p-4\">\n      <AppCard className=\"w-full max-w-[720px]\">\n        <div className=\"flex flex-col gap-2\">\n          <Link to=\"/tickets\" className=\"btn btn-ghost btn-sm self-start\">← Back to Tickets</Link>\n          <div className=\"flex flex-col gap-0.5\">\n            {choirName && <span className=\"text-xs text-text-muted font-bold uppercase tracking-wider\">{choirName}</span>}\n            <h1 className=\"text-display m-0\">Buy Season Tickets</h1>\n          </div>\n        </div>\n\n        <div className=\"card flex flex-col md:flex-row p-4 gap-4 bg-primary-light\">\n          <div className=\"flex-1 flex flex-col gap-1\">\n            <h3 className=\"m-0 text-primary-deep\">{bundle.title}</h3>\n            <p className=\"text-body m-0\">\n              Full Season Access to all performances listed below for one discounted rate.\n            </p>\n          </div>\n        </div>\n\n        <div className=\"flex flex-col gap-1 border-b border-border pb-4\">\n          <span className=\"text-xs text-text-muted font-bold uppercase\">Included Performances</span>\n          <div className=\"flex flex-col gap-2 mt-1\">\n            {includedEvents.map(event => (\n              <div key={event.id} className=\"card p-2 border border-border rounded-sm\">\n                <strong className=\"block text-text\">{event.title}</strong>\n                <span className=\"text-xs text-text-muted\">\n                  {formatInTimezone(event.date, timezone, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: 'numeric', minute: '2-digit' })}\n                </span>\n              </div>\n            ))}\n            {includedEvents.length === 0 && (\n              <p className=\"text-text-muted text-sm m-0\">No concerts currently scheduled in this bundle.</p>\n            )}\n          </div>\n        </div>\n\n        {bundle.publicDetails && (\n          <div className=\"flex flex-col gap-1 border-b border-border pb-4\">\n            <span className=\"text-xs text-text-muted font-bold uppercase\">Bundle Details & Instructions</span>\n            <div \n              className=\"text-body\"\n              dangerouslySetInnerHTML={{ __html: sanitizeHtml(bundle.publicDetails) }}\n            />\n          </div>\n        )}\n\n        <form onSubmit={handleSubmit} className=\"flex flex-col gap-6\">\n          {error && <p className=\"text-danger-text m-0\">{error}</p>}\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-label\">Your Name (for Will Call)</label>\n            <input\n              type=\"text\"\n              required\n              className=\"card px-3 h-10\"\n              value={name}\n              onChange={e => setName(e.target.value)}\n            />\n          </div>\n\n          <div className=\"flex flex-col md:flex-row gap-4\">\n            <div className=\"flex-1 flex flex-col gap-1\">\n              <label className=\"text-label\">Email Address</label>\n              <input\n                type=\"email\"\n                required\n                className=\"card px-3 h-10\"\n                value={email}\n                onChange={e => setEmail(e.target.value)}\n              />\n            </div>\n            <div className=\"flex-1 flex flex-col gap-1\">\n              <label className=\"text-label\">Confirm Email</label>\n              <input\n                type=\"email\"\n                required\n                className=\"card px-3 h-10\"\n                value={confirmEmail}\n                onChange={e => setConfirmEmail(e.target.value)}\n              />\n            </div>\n          </div>\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-label\">Pass Quantity</label>\n            <input\n              type=\"number\"\n              min=\"1\"\n              max=\"10\"\n              required\n              className=\"card px-3 h-10\"\n              value={quantity}\n              onChange={e => setQuantity(Math.max(1, Math.min(10, Number(e.target.value))))}\n            />\n          </div>\n\n          <div className=\"card w-full p-4 flex flex-col gap-1 bg-neutral-bg\">\n            <h4 className=\"m-0 text-primary-deep\">Pricing Summary</h4>\n            <div className=\"flex flex-row justify-between text-sm\">\n              <span>Season Ticket Pass ({quantity} x ${(unitPrice / 100).toFixed(2)})</span>\n              <span>${((unitPrice * quantity) / 100).toFixed(2)}</span>\n            </div>\n            {feeCents > 0 && (\n              <div className=\"flex flex-row justify-between text-sm\">\n                <span>Processing Fee</span>\n                <span>${(feeCents / 100).toFixed(2)}</span>\n              </div>\n            )}\n            <div className=\"flex flex-row justify-between font-bold border-t border-border pt-1 mt-1\">\n              <span>Total Cost</span>\n              <span>${(totalCents / 100).toFixed(2)}</span>\n            </div>\n          </div>\n\n          <div className=\"flex flex-row p-4 gap-4 items-start bg-neutral-bg border border-border rounded-lg mt-1\">\n            <input\n              id=\"marketingOptIn\"\n              type=\"checkbox\"\n              className=\"w-[18px] h-[18px] accent-primary cursor-pointer\"\n              checked={marketingOptIn}\n              onChange={e => setMarketingOptIn(e.target.checked)}\n            />\n            <label htmlFor=\"marketingOptIn\" className=\"flex flex-col gap-0.5 cursor-pointer select-none flex-1\">\n              <span className=\"text-sm font-semibold text-text leading-tight\">\n                Email me future choir performance announcements.\n              </span>\n              <span className=\"text-xs text-text-muted leading-tight\">\n                No weekly emails. Unsubscribe anytime.\n              </span>\n            </label>\n          </div>\n\n          <button\n            type=\"submit\"\n            disabled={submitting}\n            className=\"btn btn-primary btn-lg w-full h-12 font-semibold\"\n          >\n            {submitting ? \"Opening Secure Checkout…\" : \"Proceed to Payment\"}\n          </button>\n        </form>\n      </AppCard>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/PublicDonationSuccessView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":36,"column":28,"messageId":"fix:sort","endLine":36,"endColumn":36,"fix":{"range":[1225,1288],"text":"flex min-h-screen w-screen flex-col items-center justify-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":36,"column":37,"messageId":"fix:sort","endLine":36,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":36,"column":50,"messageId":"fix:sort","endLine":36,"endColumn":64},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":36,"column":78,"messageId":"fix:sort","endLine":36,"endColumn":86},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":37,"column":50,"messageId":"fix:sort","endLine":37,"endColumn":61,"fix":{"range":[1319,1364],"text":"w-full max-w-[480px] items-center text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":37,"column":62,"messageId":"fix:sort","endLine":37,"endColumn":74},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":40,"column":25,"messageId":"fix:sort","endLine":40,"endColumn":40,"fix":{"range":[1484,1507],"text":"text-sm text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":40,"column":41,"messageId":"fix:sort","endLine":40,"endColumn":48},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":41,"column":27,"messageId":"fix:sort","endLine":41,"endColumn":31,"fix":{"range":[1587,1662],"text":"h-10 w-10 animate-spin rounded-full bo