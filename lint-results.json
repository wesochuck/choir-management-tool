-classname","endLine":148,"endColumn":32,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"card"},"fix":{"range":[4676,4690],"text":"h-11 px-3"},"desc":"Remove unknown classname 'card'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":161,"column":29,"messageId":"fix:sort","endLine":161,"endColumn":37,"fix":{"range":[5169,5194],"text":"mt-1 flex-row justify-end"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":161,"column":38,"messageId":"fix:sort","endLine":161,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":161,"column":50,"messageId":"fix:sort","endLine":161,"endColumn":54},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":162,"column":48,"messageId":"issue:unknown-classname","endLine":162,"endColumn":51,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[5244,5257],"text":"btn-ghost"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-ghost' is not a Tailwind CSS class","line":162,"column":52,"messageId":"issue:unknown-classname","endLine":162,"endColumn":61,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-ghost"},"fix":{"range":[5244,5257],"text":"btn"},"desc":"Remove unknown classname 'btn-ghost'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":163,"column":48,"messageId":"issue:unknown-classname","endLine":163,"endColumn":51,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[5340,5355],"text":"btn-primary"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-primary' is not a Tailwind CSS class","line":163,"column":52,"messageId":"issue:unknown-classname","endLine":163,"endColumn":63,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-primary"},"fix":{"range":[5340,5355],"text":"btn"},"desc":"Remove unknown classname 'btn-primary'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":43,"fixableErrorCount":0,"fixableWarningCount":6,"source":"import React, { useEffect, useState } from 'react';\nimport { BaseModal } from '../common/BaseModal';\nimport { pb } from '../../lib/pocketbase';\nimport { useEvents } from '../../hooks/useEvents';\nimport type { RecordModel } from 'pocketbase';\n\n\ninterface PollRecord extends RecordModel {\n  question: string;\n  eventId?: string;\n}\n\ninterface PollSelectionModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  onSelect: (pollId: string, pollQuestion: string) => void;\n}\n\n\nexport const PollSelectionModal: React.FC<PollSelectionModalProps> = ({\n  isOpen,\n  onClose,\n  onSelect,\n}) => {\n  const [tab, setTab] = useState<'list' | 'create'>('list');\n  const [polls, setPolls] = useState<PollRecord[]>([]);\n  const [isLoading, setIsLoading] = useState(false);\n  const [isCreating, setIsCreating] = useState(false);\n  const { events } = useEvents();\n\n  // Create form state\n  const [question, setQuestion] = useState('');\n  const [eventId, setEventId] = useState('');\n\n  const loadPolls = async () => {\n    setIsLoading(true);\n    try {\n      const list = await pb.collection('polls').getFullList<PollRecord>({ sort: '-created' });\n      setPolls(list);\n    } catch (err) {\n      console.error('Failed to load polls', err);\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    if (isOpen) {\n      loadPolls();\n      setTab('list');\n      setQuestion('');\n      setEventId('');\n    }\n  }, [isOpen]);\n\n  const handleCreate = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!question) return;\n\n    setIsCreating(true);\n    try {\n      const record = await pb.collection('polls').create<PollRecord>({\n        question,\n        eventId: eventId || null,\n      });\n      onSelect(record.id, record.question);\n      onClose();\n    } catch (err) {\n      console.error('Failed to create poll', err);\n      alert('Failed to create poll. Please try again.');\n    } finally {\n      setIsCreating(false);\n    }\n  };\n\n  return (\n    <BaseModal\n      isOpen={isOpen}\n      onClose={onClose}\n      title=\"📊 Insert a Poll\"\n      maxWidth=\"500px\"\n    >\n\n      <div className=\"flex-col gap-4\">\n        <div className=\"flex-row gap-1 border-b border-border pb-1\">\n          <button\n            className={`btn btn-sm ${tab === 'list' ? 'btn-primary' : 'btn-ghost'}`}\n            onClick={() => setTab('list')}\n          >\n            Existing Polls\n          </button>\n          <button\n            className={`btn btn-sm ${tab === 'create' ? 'btn-primary' : 'btn-ghost'}`}\n            onClick={() => setTab('create')}\n          >\n            Create New Poll\n          </button>\n        </div>\n\n        {tab === 'list' ? (\n          <div className=\"flex-col gap-2\">\n            <div className=\"flex-col gap-2 max-h-[400px] overflow-y-auto\">\n              {isLoading ? (\n                <p className=\"text-muted text-center p-4\">Loading polls...</p>\n              ) : polls.length === 0 ? (\n                <p className=\"text-muted text-center p-4\">No polls found. Create one to get started!</p>\n              ) : (\n                polls.map(poll => (\n                  <button\n                    key={poll.id}\n                    className=\"card flex-col text-left p-2 px-4 gap-1 cursor-pointer border border-border\"\n                    onClick={() => {\n                      onSelect(poll.id, poll.question);\n                      onClose();\n                    }}\n                  >\n                    <strong className=\"text-[0.95rem]\">{poll.question}</strong>\n                    {poll.eventId && (\n                      <span className=\"text-muted text-xs\">\n                        Linked to: {events.find(e => e.id === poll.eventId)?.title || 'Event'}\n                      </span>\n                    )}\n                  </button>\n                ))\n              )}\n            </div>\n            <div className=\"flex-row justify-end mt-1\">\n              <button type=\"button\" className=\"btn btn-ghost\" onClick={onClose}>Cancel</button>\n            </div>\n          </div>\n        ) : (\n          <form onSubmit={handleCreate} className=\"flex-col gap-4\">\n            <div className=\"flex-col gap-1\">\n              <label className=\"text-label\">Poll Question</label>\n              <input\n                className=\"card h-11 px-3\"\n                autoFocus\n                required\n                value={question}\n                onChange={e => setQuestion(e.target.value)}\n                placeholder=\"e.g. Can you help with riser setup?\"\n              />\n            </div>\n\n            <div className=\"flex-col gap-1\">\n              <label className=\"text-label\">Linked Event (Optional)</label>\n              <select\n                className=\"card h-11 px-3\"\n                value={eventId}\n                onChange={e => setEventId(e.target.value)}\n              >\n                <option value=\"\">No Linked Event</option>\n                {events.map(event => (\n                  <option key={event.id} value={event.id}>\n                    {event.title || event.type} ({new Date(event.date).toLocaleDateString()})\n                  </option>\n                ))}\n              </select>\n            </div>\n\n            <div className=\"flex-row justify-end mt-1\">\n              <button type=\"button\" className=\"btn btn-ghost\" onClick={onClose}>Cancel<