endColumn":93},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":238,"column":94,"messageId":"fix:sort","endLine":238,"endColumn":97},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":238,"column":98,"messageId":"fix:sort","endLine":238,"endColumn":109},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":247,"column":24,"messageId":"issue:unknown-classname","endLine":247,"endColumn":27,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[9512,9560],"text":"btn-primary btn-lg w-full h-12 font-semibold"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-primary' is not a Tailwind CSS class","line":247,"column":28,"messageId":"issue:unknown-classname","endLine":247,"endColumn":39,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-primary"},"fix":{"range":[9512,9560],"text":"btn btn-lg w-full h-12 font-semibold"},"desc":"Remove unknown classname 'btn-primary'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-lg' is not a Tailwind CSS class","line":247,"column":40,"messageId":"issue:unknown-classname","endLine":247,"endColumn":46,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-lg"},"fix":{"range":[9512,9560],"text":"btn btn-primary w-full h-12 font-semibold"},"desc":"Remove unknown classname 'btn-lg'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":247,"column":47,"messageId":"fix:sort","endLine":247,"endColumn":53,"fix":{"range":[9512,9560],"text":"btn btn-primary btn-lg h-12 w-full font-semibold"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":247,"column":54,"messageId":"fix:sort","endLine":247,"endColumn":58},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":252,"column":25,"messageId":"fix:sort","endLine":252,"endColumn":32,"fix":{"range":[9715,9754],"text":"m-0 text-center text-xs text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":252,"column":33,"messageId":"fix:sort","endLine":252,"endColumn":48},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":252,"column":49,"messageId":"fix:sort","endLine":252,"endColumn":60},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":252,"column":61,"messageId":"fix:sort","endLine":252,"endColumn":64}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":131,"fixableErrorCount":0,"fixableWarningCount":30,"source":"import React, { useEffect, useState } from 'react';\nimport { Link } from 'react-router-dom';\nimport { donationService, type DonationLevel } from '../services/donationService';\nimport { AppCard } from '../components/common/AppCard';\nimport PublicLogo from '../components/common/PublicLogo';\nimport { useDocumentTitle, useChoirName } from '../hooks/useDocumentTitle';\n\nexport default function PublicDonationView() {\n  useDocumentTitle('Support Our Music');\n  const { choirName } = useChoirName();\n  \n  const [levels, setLevels] = useState<DonationLevel[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState('');\n  \n  const [selectedLevelId, setSelectedLevelId] = useState<string | 'custom'>('');\n  const [customAmount, setCustomAmount] = useState<string>('');\n  const [name, setName] = useState('');\n  const [email, setEmail] = useState('');\n  const [confirmEmail, setConfirmEmail] = useState('');\n  const [tributeType, setTributeType] = useState<'none' | 'memory' | 'honor'>('none');\n  const [tributeName, setTributeName] = useState('');\n  const [isAnonymous, setIsAnonymous] = useState(false);\n  const [submitting, setSubmitting] = useState(false);\n\n  useEffect(() => {\n    async function loadSettings() {\n      try {\n        const settings = await donationService.getDonationSettings();\n        setLevels(settings.levels);\n        if (settings.levels.length > 0) {\n          setSelectedLevelId(settings.levels[0].id);\n        } else {\n          setSelectedLevelId('custom');\n        }\n      } catch {\n        setError('Failed to load donation settings.');\n      } finally {\n        setLoading(false);\n      }\n    }\n    loadSettings();\n  }, []);\n\n  const getEffectiveAmount = () => {\n    if (selectedLevelId === 'custom') {\n      return parseFloat(customAmount) || 0;\n    }\n    const level = levels.find(l => l.id === selectedLevelId);\n    return level ? level.amount : 0;\n  };\n\n  const handleSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setError('');\n\n    const amount = getEffectiveAmount();\n    if (amount < 5) {\n      setError('Minimum donation amount is $5.00');\n      return;\n    }\n\n    if (email.trim() !== confirmEmail.trim()) {\n      setError('Email addresses must match.');\n      return;\n    }\n\n    setSubmitting(true);\n    try {\n      const session = await donationService.createDonationSession({\n        amountCents: Math.round(amount * 100),\n        email: email.trim(),\n        name: name.trim(),\n        tributeType,\n        tributeName: tributeName.trim(),\n        isAnonymous\n      });\n\n      if (session.url) {\n        window.location.href = session.url;\n      } else {\n        throw new Error('Stripe Checkout URL not returned');\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err);\n      setError(msg || 'Stripe redirection failed.');\n      setSubmitting(false);\n    }\n  };\n\n  if (loading) {\n    return (\n      <div className=\"flex flex-col min-h-screen justify-center items-center w-screen\">\n        <p className=\"text-text-muted\">Loading...</p>\n      </div>\n    );\n  }\n\n  const effectiveAmount = getEffectiveAmount();\n\n  return (\n    <div className=\"flex flex-col min-h-screen justify-start items-center w-screen p-4\">\n      <PublicLogo />\n      <AppCard className=\"w-full max-w-[720px]\">\n        <div className=\"flex flex-col gap-2\">\n          <Link to=\"/tickets\" className=\"btn btn-ghost btn-sm self-start\">← Back to Concerts</Link>\n          <div className=\"flex flex-col gap-0.5\">\n            {choirName && <span className=\"text-xs text-text-muted font-bold uppercase tracking-wider\">{choirName}</span>}\n            <h1 className=\"text-display m-0\">Support Our Music</h1>\n            <p className=\"text-body m-0\">Your tax-deductible contribution helps us keep the music playing.</p>\n          </div>\n        </div>\n\n        <form onSubmit={handleSubmit} className=\"flex flex-col gap-6 mt-6\">\n          {error && <p className=\"text-danger-text m-0\">{error}</p>}\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-label\">Select a Donation Level</label>\n            <div className=\"grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-3 bg-neutral-bg p-4 rounded-lg border border-border\">\n              {levels.map(level => (\n                <div \n                  key={level.id}\n                  className={`flex items-center gap-2.5 p-3 rounded-sm border cursor-pointer select-none transition-all ${selectedLevelId === level.id ? 'border-primary bg-[rgba(74,117,89,0.05)]' : 'border-border bg-surface'}`}\n                  onClick={() => setSelectedLevelId(level.id)}\n                >\n                  <div className=\"flex flex-col flex-1\">\n                    <span className=\"font-semibold\">{level.label}</span>\n                    {level.benefit && <span className=\"text-xs text-text-muted\">{level.benefit}</span>}\n                  </div>\n                  <span className=\"font-bold\">${level.amount}</span>\n                </div>\n              ))}\n              <div \n                className={`flex items-center gap-2.5 p-3 rounded-sm border cursor-pointer select-none transition-all ${selectedLevelId === 'custom' ? 'border-primary bg-[rgba(74,117,89,0.05)]' : 'border-border bg-surface'}`}\n                onClick={() => setSelectedLevelId('custom')}\n              >\n                <div className=\"flex flex-col flex-1\">\n                  <span className=\"font-semibold\">Custom Amount</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          {selectedLevelId === 'custom' && (\n            <div className=\"flex flex-col gap-1\">\n              <label className=\"text-label\">Custom Donation Amount ($)</label>\n              <input\n                type=\"number\"\n                min=\"5\"\n                step=\"0.01\"\n                required\n                placeholder=\"0.00\"\n                className=\"card px-3 h-11\"\n                value={customAmount}\n                onChange={e => setCustomAmount(e.target.value)}\n              />\n            </div>\n          )}\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-label\">Your Name</label>\n            <input\n              type=\"text\"\n              required\n              placeholder=\"Full Name\"\n              className=\"card px-3 h-11\"\n              value={name}\n              onChange={e => setName(e.target.value)}\n            />\n          </div>\n\n          <div className=\"flex flex-col md:flex-row gap-4\">\n            <div className=\"flex-1 flex flex-col gap-1\">\n              <label className=\"text-label\">Email Address</label>\n              <input\n                type=\"email\"\n                required\n                placeholder=\"email@example.com\"\n                className=\"card px-3 h-11\"\n                value={email}\n                onChange={e => setEmail(e.target.value)}\n              />\n            </div>\n            <div className=\"flex-1 flex flex-col gap-1\">\n              <label className=\"text-label\">Confirm Email</label>\n              <input\n                type=\"email\"\n                required\n                placeholder=\"Confirm Email\"\n                className=\"card px-3 h-11\"\n                value={confirmEmail}\n                onChange={e => setConfirmEmail(e.target.value)}\n              />\n            </div>\n          </div>\n\n          <div className=\"flex flex-col gap-1\">\n            <label className=\"text-label\">Tribute Information (Optional)</label>\n            <div className=\"flex flex-col md:flex-row gap-4\">\n              <select \n                className=\"card px-3 h-11 flex-1\"\n                value={tributeType}\n                onChange={e => setTributeType(e.target.value as 'none' | 'memory' | 'honor')}\n              >\n                <option value=\"none\">No Tribute</option>\n                <option value=\"memory\">In Memory Of</option>\n                <option value=\"honor\">In Honor Of</option>\n              </select>\n              {tributeType !== 'none' && (\n                <input\n                  type=\"text\"\n                  required\n                  placeholder=\"Honoree Name\"\n                  className=\"card px-3 flex-[2] h-11\"\n                  value={tributeName}\n                  onChange={e => setTributeName(e.target.value)}\n                />\n              )}\n            </div>\n          </div>\n\n          <div className=\"flex flex-row p-4 gap-4 bg-neutral-bg border border-border rounded-lg mt-1 items-center\">\n            <input\n              id=\"isAnonymous\"\n              type=\"checkbox\"\n              className=\"w-[18px] h-[18px] accent-primary cursor-pointer\"\n              checked={isAnonymous}\n              onChange={e => setIsAnonymous(e.target.checked)}\n            />\n            <label htmlFor=\"isAnonymous\" className=\"flex flex-col gap-0.5 cursor-pointer select-none flex-1\">\n              <span className=\"text-sm font-semibold text-text leading-tight\">\n                I wish to remain anonymous.\n              </span>\n            </label>\n          </div>\n\n          <div className=\"card w-full p-4 flex flex-col gap-1 bg-neutral-bg\">\n            <div className=\"flex flex-row justify-between font-bold border-t-0 pt-0 mt-0 m-0 p-0 border-none\">\n              <span>Total Donation</span>\n              <span>${effectiveAmount.toFixed(2)}</span>\n            </div>\n          </div>\n\n          <button\n            type=\"submit\"\n            disabled={submitting || effectiveAmount < 5}\n            className=\"btn btn-primary btn-lg w-full h-12 font-semibold\"\n          >\n            {submitting ? \"Opening Secure Checkout…\" : `Donate $${effectiveAmount.toFixed(2)}`}\n          </button>\n\n          <p className=\"text-xs text-text-muted text-center m-0\">\n            Secure payment processing provided by Stripe.\n          </p>\n        </form>\n      </AppCard>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/PublicPlayerView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":155,"column":41,"messageId":"fix:sort","endLine":155,"endColumn":52,"fix":{"range":[5904,5921],"text":"pt-16 text-center"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":155,"column":53,"messageId":"fix:sort","endLine":155,"endColumn":58},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'chorus-player' is not a Tailwind CSS class","line":156,"column":37,"messageId":"issue:unknown-classname","endLine":156,"endColumn":50,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"chorus-player"},"fix":{"range":[5986,5999],"text":""},"desc":"Remove unknown classname 'chorus-player'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'error-message' is not a Tailwind CSS class","line":156,"column":68,"messageId":"issue:unknown-classname","endLine":156,"endColumn":81,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"error-message"},"fix":{"range":[6017,6030],"text":""},"desc":"Remove unknown classname 'error-message'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'chorus-player' is not a Tailwind CSS class","line":162,"column":21,"messageId":"issue:unknown-classname","endLine":162,"endColumn":34,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"chorus-player"},"fix":{"range":[6172,6185],"text":""},"desc":"Remove unknown classname 'chorus-player'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'player-back-link' is not a Tailwind CSS class","line":166,"column":37,"messageId":"issue:unknown-classname","endLine":166,"endColumn":53,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"player-back-link"},"fix":{"range":[6291,6307],"text":""},"desc":"Remove unknown classname 'player-back-link'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":171,"column":27,"messageId":"fix:sort","endLine":171,"endColumn":34,"fix":{"range":[6421,6448],"text":"text-text-secondary text-sm"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":171,"column":35,"messageId":"fix:sort","endLine":171,"endColumn":54},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-text-secondary' is not a Tailwind CSS class","line":171,"column":35,"messageId":"issue:unknown-classname","endLine":171,"endColumn":54,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-text-secondary"},"fix":{"range":[6421,6448],"text":"text-sm"},"desc":"Remove unknown classname 'text-text-secondary'"}]}],"suppressedMessages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useCallback has missing dependencies: 'data?.allPieces' and 'data?.voiceParts'. Either include them or remove the dependency array.","line":81,"column":6,"endLine":81,"endColumn":22,"suggestions":[{"desc":"Update the dependencies array to be: [token, eventId, data?.allPieces, data?.voiceParts]","fix":{"range":[3172,3188],"text":"[token, eventId, data?.allPieces, data?.voiceParts]"}}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":9,"fixableErrorCount":0,"fixableWarningCount":2,"source":"import { useEffect, useState, useCallback } from 'react';\nimport { Link, useSearchParams } from 'react-router-dom';\nimport { playerService, type PlayerPlaylist, type PlayerMediaFile } from '../services/playerService';\nimport { Player } from '../components/player/Player';\nimport { Playlist } from '../components/player/Playlist';\nimport { VoicePartSelector } from '../components/player/VoicePartSelector';\nimport { \n  getOfflinePlaylist, \n  downloadTrack, \n  removeOfflineTrack, \n  savePlaylistOffline,\n  hydrateOfflineStatus,\n  clearAllDownloads\n} from '../services/offlineMediaStore';\nimport { safeLocalStorage } from '../lib/storage';\n\nexport default function PublicPlayerView() {\n  const [searchParams] = useSearchParams();\n  let token = searchParams.get('token') || '';\n  const sParam = searchParams.get('s');\n  if (token && sParam && !token.includes('s=')) {\n    token = `${token}&s=${sParam}`;\n  }\n  const eventId = searchParams.get('eventId') || '';\n\n  const [data, setData] = useState<PlayerPlaylist | null>(null);\n  const [playlist, setPlaylist] = useState<PlayerMediaFile[]>([]);\n  const [currentIndex, setCurrentIndex] = useState(0);\n  const [isPlaying, setIsPlaying] = useState(false);\n  const [isLoading, setIsLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  \n  const [selectedVoicePart, setSelectedVoicePart] = useState<string>(() => {\n    return safeLocalStorage.getItem('player-voice-part') || 'tutti';\n  });\n\n  const [downloadProgress, setDownloadProgress] = useState<Record<string, number>>({});\n  const [isDownloadingAll, setIsDownloadingAll] = useState(false);\n\n  const loadData = useCallback(async () => {\n    if (!token && !eventId) {\n      setError('Missing player token or event ID.');\n      setIsLoading(false);\n      return;\n    }\n\n    try {\n      setIsLoading(true);\n      let result: PlayerPlaylist;\n      \n      if (token) {\n        result = await playerService.fetchPlaylistByToken(token);\n        await savePlaylistOffline(token, result.files);\n      } else {\n        result = await playerService.fetchPlaylistByEventId(eventId);\n        await savePlaylistOffline(eventId, result.files);\n      }\n\n      setData(result);\n      \n      const initialPart = safeLocalStorage.getItem('player-voice-part') || 'tutti';\n      const targetedTracks = playerService.applyVoicePartToFiles(result.files, initialPart, result.allPieces, result.voiceParts);\n      const hydrated = await hydrateOfflineStatus(targetedTracks);\n      \n      setPlaylist(hydrated);\n      setIsLoading(false);\n    } catch (err) {\n      console.error('Failed to load playlist', err);\n      const key = token || eventId;\n      const cached = await getOfflinePlaylist(key);\n      if (cached) {\n        const initialPart = safeLocalStorage.getItem('player-voice-part') || 'tutti';\n        const targetedTracks = playerService.applyVoicePartToFiles(cached, initialPart, data?.allPieces || [], data?.voiceParts || []);\n        setPlaylist(await hydrateOfflineStatus(targetedTracks));\n        setIsLoading(false);\n      } else {\n        setError('Failed to load playlist. Please check your link.');\n        setIsLoading(false);\n      }\n    }\n  }, [token, eventId]); // eslint-disable-line react-hooks/exhaustive-deps\n\n  useEffect(() => {\n    loadData();\n  }, [loadData]);\n\n  const handleVoicePartChange = async (part: string) => {\n    setSelectedVoicePart(part);\n    safeLocalStorage.setItem('player-voice-part', part);\n\n    if (!data) return;\n    \n    const updatedPlaylist = playerService.applyVoicePartToFiles(playlist, part, data.allPieces, data.voiceParts);\n    const hydrated = await hydrateOfflineStatus(updatedPlaylist);\n    setPlaylist(hydrated);\n  };\n\n  const handleDownload = async (track: PlayerMediaFile) => {\n    try {\n      setDownloadProgress(prev => ({ ...prev, [track.id]: 0 }));\n      setPlaylist(prev => prev.map(f => f.id === track.id ? { ...f, downloadStatus: 'downloading' } : f));\n\n      await downloadTrack(track, (prog) => {\n        setDownloadProgress(prev => ({ ...prev, [track.id]: prog }));\n      });\n\n      const hydrated = await hydrateOfflineStatus(playlist);\n      setPlaylist(hydrated);\n    } catch (err) {\n      console.error('Download failed', err);\n      setPlaylist(prev => prev.map(f => f.id === track.id ? { ...f, downloadStatus: 'error' } : f));\n    }\n  };\n\n  const handleRemoveDownload = async (track: PlayerMediaFile) => {\n    await removeOfflineTrack(track.id);\n    setPlaylist(await hydrateOfflineStatus(playlist));\n  };\n\n  const handleDownloadAll = async () => {\n    if (isDownloadingAll) return;\n    const toDownload = playlist.filter(f => !f.isFolder && !f.isDownloaded);\n    if (toDownload.length === 0) return;\n    setIsDownloadingAll(true);\n    \n    const errorIds = new Set<string>();\n    \n    // @allow-sequential-await - downloads must be sequential to avoid overwhelming the server\n    for (const track of toDownload) {\n      try {\n        setDownloadProgress(prev => ({ ...prev, [track.id]: 0 }));\n        setPlaylist(prev => prev.map(f => f.id === track.id ? { ...f, downloadStatus: 'downloading' } : f));\n        await downloadTrack(track, (prog) => {\n          setDownloadProgress(prev => ({ ...prev, [track.id]: prog }));\n        });\n      } catch (err) {\n        console.error('Download failed for', track.name, err);\n        errorIds.add(track.id);\n        setPlaylist(prev => prev.map(f => f.id === track.id ? { ...f, downloadStatus: 'error' } : f));\n      }\n    }\n    \n    const hydrated = await hydrateOfflineStatus(playlist);\n    const finalPlaylist = hydrated.map(f => errorIds.has(f.id) ? { ...f, downloadStatus: 'error' as const } : f);\n    setPlaylist(finalPlaylist);\n    setIsDownloadingAll(false);\n  };\n\n  const handleClearAll = async () => {\n    await clearAllDownloads();\n    const hydrated = await hydrateOfflineStatus(playlist);\n    setPlaylist(hydrated);\n  };\n\n  if (isLoading) return <div className=\"text-center pt-16\">Loading playlist...</div>;\n  if (error) return <div className=\"chorus-player\"><div className=\"error-message\">{error}</div></div>;\n  if (!data) return null;\n\n  const showDashboardBackLink = Boolean(eventId && !token);\n\n  return (\n    <div className=\"chorus-player\">\n      <header>\n        <div>\n          {showDashboardBackLink && (\n            <Link to=\"/\" className=\"player-back-link\">\n              ← Dashboard\n            </Link>\n          )}\n          <h1>Chorus</h1>\n          <div className=\"text-sm text-text-secondary\">{data.event.title}</div>\n        </div>\n      </header>\n\n      <VoicePartSelector \n        voiceParts={data.voiceParts} \n        selectedPart={selectedVoicePart}\n        onSelect={handleVoicePartChange}\n      />\n\n      <Player \n        playlist={playlist}\n        currentIndex={currentIndex}\n        onTrackChange={setCurrentIndex}\n        isPlaying={isPlaying}\n        setIsPlaying={setIsPlaying}\n        selectedVoicePart={selectedVoicePart}\n      />\n\n      <Playlist \n        playlist={playlist}\n        currentIndex={currentIndex}\n        onTrackSelect={(idx) => {\n          setCurrentIndex(idx);\n          setIsPlaying(true);\n        }}\n        onDownloadTrack={handleDownload}\n        onRemoveDownload={handleRemoveDownload}\n        downloadProgressById={downloadProgress}\n        selectedVoicePart={selectedVoicePart}\n        onDownloadAll={handleDownloadAll}\n        onClearAll={handleClearAll}\n        isDownloadingAll={isDownloadingAll}\n      />\n\n      <div className=\"mt-8\">\n        You can download tracks for offline practice. They will be saved in your browser.\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/PublicPollView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":83,"column":28,"messageId":"fix:sort","endLine":83,"endColumn":36,"fix":{"range":[2867,2947],"text":"flex min-h-screen w-screen flex-col items-center justify-center bg-primary-light"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":83,"column":37,"messageId":"fix:sort","endLine":83,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":83,"column":50,"messageId":"fix:sort","endLine":83,"endColumn":58},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":83,"column":59,"messageId":"fix:sort","endLine":83,"endColumn":75},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":83,"column":76,"messageId":"fix:sort","endLine":83,"endColumn":88},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":83,"column