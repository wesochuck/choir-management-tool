assname","endLine":223,"endColumn":69,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"bottom-dock-remove-btn"},"fix":{"range":[8411,8587],"text":"no-print bg-transparent border-0 text-text-muted cursor-pointer p-0 ml-1.5 flex items-center justify-center text-xs font-bold transition-all duration-200"},"desc":"Remove unknown classname 'bottom-dock-remove-btn'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":70,"messageId":"fix:sort","endLine":223,"endColumn":84,"fix":{"range":[8411,8587],"text":"no-print bottom-dock-remove-btn ml-1.5 flex cursor-pointer items-center justify-center border-0 bg-transparent p-0 text-xs font-bold text-text-muted transition-all duration-200"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":85,"messageId":"fix:sort","endLine":223,"endColumn":93},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":94,"messageId":"fix:sort","endLine":223,"endColumn":109},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":110,"messageId":"fix:sort","endLine":223,"endColumn":124},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":125,"messageId":"fix:sort","endLine":223,"endColumn":128},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":129,"messageId":"fix:sort","endLine":223,"endColumn":135},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":136,"messageId":"fix:sort","endLine":223,"endColumn":140},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":141,"messageId":"fix:sort","endLine":223,"endColumn":153},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":154,"messageId":"fix:sort","endLine":223,"endColumn":168},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":169,"messageId":"fix:sort","endLine":223,"endColumn":176},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":223,"column":177,"messageId":"fix:sort","endLine":223,"endColumn":186},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'bottom-dock-empty-lane' is not a Tailwind CSS class","line":240,"column":37,"messageId":"issue:unknown-classname","endLine":240,"endColumn":59,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"bottom-dock-empty-lane"},"fix":{"range":[9367,9389],"text":""},"desc":"Remove unknown classname 'bottom-dock-empty-lane'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":82,"fixableErrorCount":0,"fixableWarningCount":13,"source":"import { useMemo } from 'react';\nimport type { Profile } from '../../services/profileService';\nimport { getUniqueDisplayNames } from '../../lib/stringUtils';\nimport type { SectionDef, VoicePartDef } from '../../services/settingsService';\nimport { getContrastColor } from '../../lib/colorUtils';\n\n\ninterface SeatingBottomDockProps {\n  activeProfiles: Profile[];\n  assignments: Record<string, string>;\n  sections: SectionDef[];\n  voiceParts: VoicePartDef[];\n  assignSinger: (seatKey: string, profileId: string, fromSeatKey?: string) => Promise<void>;\n  onAddSinger?: () => void;\n  onLookupSinger?: () => void;\n  onRemoveRsvp?: (profileId: string, name: string) => void;\n  isVoicePartLayout?: boolean;\n  sectionOrder?: string[];\n}\n\nexport function SeatingBottomDock({\n  activeProfiles,\n  assignments,\n  sections,\n  voiceParts,\n  assignSinger,\n  onAddSinger,\n  onLookupSinger,\n  onRemoveRsvp,\n  isVoicePartLayout = false,\n  sectionOrder\n}: SeatingBottomDockProps) {\n  const assignedIds = useMemo(() => new Set(Object.values(assignments)), [assignments]);\n\n  const unassigned = useMemo(() => {\n    return activeProfiles.filter(p => !assignedIds.has(p.id));\n  }, [activeProfiles, assignedIds]);\n\n  const uniqueDisplayNames = useMemo(() => {\n    return getUniqueDisplayNames(activeProfiles);\n  }, [activeProfiles]);\n\n  const displaySections = useMemo(() => {\n    const order = sectionOrder && sectionOrder.length > 0\n      ? sectionOrder\n      : (isVoicePartLayout ? voiceParts.map(vp => vp.label) : sections.map(s => s.code));\n\n    if (isVoicePartLayout) {\n      return order.map(laneKey => {\n        const vpDef = voiceParts.find(vp => vp.label === laneKey);\n        return {\n          key: laneKey,\n          label: vpDef ? vpDef.label : laneKey,\n          color: (() => {\n            if (vpDef) {\n              if (vpDef.color) return vpDef.color;\n              const parentSec = sections.find(s => s.code === vpDef.sectionCode);\n              return parentSec?.color || parentSec?.colorBg || '';\n            }\n            return '';\n          })()\n        };\n      });\n    } else {\n      return order.map(laneKey => {\n        const sectionDef = sections.find(s => s.code === laneKey);\n        return {\n          key: laneKey,\n          label: sectionDef?.name || laneKey,\n          color: sectionDef?.color || sectionDef?.colorBg || ''\n        };\n      });\n    }\n  }, [isVoicePartLayout, sectionOrder, sections, voiceParts]);\n\n  const groupedSingers = useMemo(() => {\n    const groups: Record<string, Profile[]> = {};\n    displaySections.forEach(ds => {\n      groups[ds.key] = [];\n    });\n\n    const hasOtherLane = displaySections.some(ds => ds.key === 'Other');\n\n    unassigned.forEach(p => {\n      let matchedLaneKey: string | null = null;\n\n      if (isVoicePartLayout) {\n        for (const ds of displaySections) {\n          if (ds.key === 'Other') continue;\n          const vpDef = voiceParts.find(vp => vp.label === ds.key);\n          const part = (p.voicePart || '').trim().toLowerCase();\n          if (\n            part === ds.key.toLowerCase() ||\n            (vpDef && part === vpDef.fullName.toLowerCase())\n          ) {\n            matchedLaneKey = ds.key;\n            break;\n          }\n        }\n      } else {\n        const vpDef = voiceParts.find(vp => \n          vp.label === p.voicePart || \n          vp.fullName === p.voicePart || \n          vp.label.toLowerCase() === p.voicePart.toLowerCase() ||\n          vp.fullName.toLowerCase() === p.voicePart.toLowerCase()\n        );\n        let sectionCode = vpDef?.sectionCode;\n        if (!sectionCode) {\n          const part = p.voicePart ? p.voicePart.trim() : '';\n          if (/^(soprano|s)(\\s*\\d+)?$/i.test(part)) sectionCode = 'S';\n          else if (/^(alto|a)(\\s*\\d+)?$/i.test(part)) sectionCode = 'A';\n          else if (/^(tenor|t)(\\s*\\d+)?$/i.test(part)) sectionCode = 'T';\n          else if (/^(bass|b|baritone|bar)(\\s*\\d+)?$/i.test(part)) sectionCode = 'B';\n        }\n\n        if (sectionCode && groups[sectionCode] !== undefined) {\n          matchedLaneKey = sectionCode;\n        }\n      }\n\n      if (matchedLaneKey) {\n        groups[matchedLaneKey].push(p);\n      } else if (hasOtherLane) {\n        if (!groups.Other) groups.Other = [];\n        groups.Other.push(p);\n      }\n    });\n\n    return groups;\n  }, [unassigned, isVoicePartLayout, displaySections, voiceParts]);\n\n  return (\n    <div className=\"no-print seating-bottom-dock\">\n      <div \n        onDragOver={(e) => e.preventDefault()}\n        onDrop={(e) => {\n          e.preventDefault();\n          try {\n            const data = JSON.parse(e.dataTransfer.getData('text/plain'));\n            if (data.fromSeatKey) {\n              assignSinger(data.fromSeatKey, '');\n            }\n          } catch (err) {\n            console.error('Failed to parse bottom dock drop data', err);\n          }\n        }}\n        className=\"flex-col bottom-dock-container\"\n      >\n        <div           className=\"flex-row bottom-dock-header flex w-full items-center justify-between\">\n          <div className=\"flex-col gap-0.5\">\n            <h3 className=\"text-headline bottom-dock-title\">📥 Unassigned Singers Shelf</h3>\n            <span className=\"text-muted bottom-dock-subtitle\">Drag up to assign, or drop here to clear a seat assignment.</span>\n          </div>\n          <div className=\"flex-row no-print gap-1\">\n            {onLookupSinger && (\n              <button\n                type=\"button\"\n                onClick={onLookupSinger}\n                className=\"btn btn-secondary btn-sm flex items-center gap-1.5 font-semibold px-3 h-8 min-h-[32px]\"\n              >\n                🔍 Lookup Singer\n              </button>\n            )}\n            {onAddSinger && (\n              <button\n                type=\"button\"\n                onClick={onAddSinger}\n                className=\"btn btn-secondary btn-sm flex items-center gap-1.5 font-semibold px-3 h-8 min-h-[32px]\"\n              >\n                + Add New Singer\n              </button>\n            )}\n          </div>\n        </div>\n\n        {/* @allow-inline-style - dynamic grid columns based on section count */}\n        <div className=\"bottom-dock-grid\" style={{ gridTemplateColumns: `repeat(${displaySections.length}, 1fr)` }}>\n          {displaySections.map(({ key, label, color }) => {\n            const list = groupedSingers[key] || [];\n            const secColor = color;\n            const badgeStyle = secColor ? {\n              backgroundColor: secColor,\n              color: getContrastColor(secColor),\n              border: `1px solid ${secColor}`\n            } : undefined;\n            const labelStyle = secColor ? {\n              color: secColor,\n              fontWeight: 700\n            } : undefined;\n\n            return (\n              <div key={key} className=\"flex-col bottom-dock-lane\">\n                <div className=\"flex-row bottom-dock-lane-header\">\n                  <span className=\"text-label lane-label\" style={labelStyle}>\n                    {label}\n                  </span>\n                  <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-primary-light text-primary-deep\" style={badgeStyle}>\n                    {list.length}\n                  </span>\n                </div>\n\n                <div className=\"flex-col bottom-dock-lane-list\">\n                  {list.map(p => (\n                    <div \n                      key={p.id}\n                      draggable\n                      onDragStart={(e) => e.dataTransfer.setData('text/plain', JSON.stringify({ profileId: p.id }))}\n                      className=\"flex-row bottom-dock-singer-card\"\n                    >\n                      <span className=\"flex-1 min-w-0 truncate\" title={p.name}>\n                        {uniqueDisplayNames[p.id] || p.name.split(' ').pop()}\n                      </span>\n                      <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-primary-light text-primary-deep\">\n                        {p.voicePart}\n                      </span>\n                      {onRemoveRsvp && (\n                        <button\n                          type=\"button\"\n                          onClick={(e) => {\n                            e.stopPropagation();\n                            onRemoveRsvp(p.id, p.name);\n                          }}\n                          className=\"no-print bottom-dock-remove-btn bg-transparent border-0 text-text-muted cursor-pointer p-0 ml-1.5 flex items-center justify-center text-xs font-bold transition-all duration-200\"\n                          title=\"Mark as Not Attending\"\n                          onMouseEnter={(e) => {\n                            e.currentTarget.style.backgroundColor = 'rgba(239, 68, 68, 0.15)';\n                            e.currentTarget.style.color = '#b91c1c';\n                          }}\n                          onMouseLeave={(e) => {\n                            e.currentTarget.style.backgroundColor = 'transparent';\n                            e.currentTarget.style.color = 'var(--text-muted)';\n                          }}\n                        >\n                          ×\n                        </button>\n                      )}\n                    </div>\n                  ))}\n                  {list.length === 0 && (\n                    <div className=\"bottom-dock-empty-lane\">\n                      <span>Empty</span>\n                    </div>\n                  )}\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/SeatingFormationsEditor.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":56,"column":25,"messageId":"fix:sort","endLine":56,"endColumn":37,"fix":{"range":[2140,2212],"text":"flex shrink-0 cursor-grab items-center text-base text-inherit opacity-55"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":56,"column":38,"messageId":"fix:sort","endLine":56,"endColumn":50},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":56,"column":51,"messageId":"fix:sort","endLine":56,"endColumn":61},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":56,"column":72,"me