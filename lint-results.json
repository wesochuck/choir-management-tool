ndLine":214,"endColumn":67},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":224,"column":34,"messageId":"fix:sort","endLine":224,"endColumn":46,"fix":{"range":[10076,10128],"text":"flex cursor-pointer items-center gap-1.5 select-none"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":224,"column":47,"messageId":"fix:sort","endLine":224,"endColumn":54},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":224,"column":55,"messageId":"fix:sort","endLine":224,"endColumn":69},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":229,"column":26,"messageId":"fix:sort","endLine":229,"endColumn":29,"fix":{"range":[10394,10431],"text":"h-4 w-4 cursor-pointer accent-primary"}},{"ruleId":"tailwindcss/enforces-shorthand","severity":1,"message":"'w-4' can be merged with 'h-4' into 'size-4'","line":229,"column":26,"messageId":"fix:use-shorthand","endLine":229,"endColumn":29,"fix":{"range":[10394,10431],"text":"accent-primary cursor-pointer size-4"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":229,"column":30,"messageId":"fix:sort","endLine":229,"endColumn":33},{"ruleId":"tailwindcss/enforces-shorthand","severity":1,"message":"'h-4' can be merged with 'w-4' into 'size-4'","line":229,"column":30,"messageId":"fix:use-shorthand","endLine":229,"endColumn":33,"fix":{"range":[10394,10431],"text":"accent-primary cursor-pointer size-4"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":229,"column":34,"messageId":"fix:sort","endLine":229,"endColumn":48},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":229,"column":49,"messageId":"fix:sort","endLine":229,"endColumn"