id Tailwind CSS classnames order","line":99,"column":126,"messageId":"fix:sort","endLine":99,"endColumn":142},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":99,"column":143,"messageId":"fix:sort","endLine":99,"endColumn":160},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":105,"column":31,"messageId":"fix:sort","endLine":105,"endColumn":42,"fix":{"range":[3512,3551],"text":"p-4 text-center text-sm text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":105,"column":43,"messageId":"fix:sort","endLine":105,"endColumn":46},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":105,"column":47,"messageId":"fix:sort","endLine":105,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":105,"column":63,"messageId":"fix:sort","endLine":105,"endColumn":70}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":43,"fixableErrorCount":0,"fixableWarningCount":8,"source":"import React, { useState, useEffect, useMemo } from 'react';\nimport type { Profile } from '../../services/profileService';\nimport { profileService } from '../../services/profileService';\nimport { BaseModal } from '../common/BaseModal';\n\ninterface SingerLookupModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n  onSelect: (profile: Profile) => Promise<void>;\n  excludeIds: Set<string>;\n}\n\nexport const SingerLookupModal: React.FC<SingerLookupModalProps> = ({\n  isOpen,\n  onClose,\n  onSelect,\n  excludeIds\n}) => {\n  const [profiles, setProfiles] = useState<Profile[]>([]);\n  const [searchQuery, setSearchQuery] = useState('');\n  const [isLoading, setIsLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n\n  useEffect(() => {\n    if (!isOpen) return;\n\n    const loadProfiles = async () => {\n      setIsLoading(true);\n      setError(null);\n      try {\n        const list = await profileService.getProfiles();\n        setProfiles(list);\n      } catch (err: unknown) {\n        const msg = err instanceof Error ? err.message : String(err);\n        setError(msg);\n      } finally {\n        setIsLoading(false);\n      }\n    };\n\n    loadProfiles();\n  }, [isOpen]);\n\n  const filtered = useMemo(() => {\n    const query = searchQuery.trim().toLowerCase();\n    return profiles.filter(p => {\n      if (excludeIds.has(p.id)) return false;\n      if (!query) return true;\n      return (\n        p.name.toLowerCase().includes(query) ||\n        p.voicePart.toLowerCase().includes(query) ||\n        p.globalStatus.toLowerCase().includes(query)\n      );\n    });\n  }, [profiles, searchQuery, excludeIds]);\n\n  return (\n    <BaseModal\n      isOpen={isOpen}\n      onClose={onClose}\n      title=\"Lookup Singer\"\n      maxWidth=\"500px\"\n      footer={<button type=\"button\" onClick={onClose} className=\"btn btn-ghost\">Cancel</button>}\n    >\n      <div className=\"flex-col gap-4\">\n        <input\n          type=\"text\"\n          value={searchQuery}\n          onChange={(e) => setSearchQuery(e.target.value)}\n          placeholder=\"Search by name, voice part, status...\"\n          className=\"card w-full px-3 h-10 border border-border\"\n          autoFocus\n        />\n\n        {isLoading ? (\n          <div className=\"text-center p-4 text-text-muted\">\n            Loading roster database...\n          </div>\n        ) : error ? (\n          <div className=\"text-danger-text p-4 text-center\">\n            ⚠️ {error}\n          </div>\n        ) : (\n          <div className=\"flex-col gap-[6px] max-h-[300px] overflow-y-auto pr-1\">\n            {filtered.map(p => (\n              <button\n                key={p.id}\n                type=\"button\"\n                onClick={async () => {\n                  await onSelect(p);\n                  onClose();\n                }}\n                className=\"flex-row card p-[10px_14px] justify-between items-center cursor-pointer border border-border bg-bg text-left w-full gap-2\"\n              >\n                <div className=\"flex-col gap-0.5\">\n                  <span className=\"font-semibold text-text\">{p.name}</span>\n                  <span className=\"text-xs text-muted\">Status: {p.globalStatus}</span>\n                </div>\n                <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-primary-light text-primary-deep\">\n                  {p.voicePart || 'Unknown'}\n                </span>\n              </button>\n            ))}\n            {filtered.length === 0 && (\n              <div className=\"text-center p-4 text-text-muted text-sm\">\n                No singers found\n              </div>\n            )}\n          </div>\n        )}\n      </div>\n    </BaseModal>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/SingerModal.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":184,"column":30,"messageId":"issue:unknown-classname","endLine":184,"endColumn":33,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[6074,6096],"text":"btn-danger mr-auto"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-danger' is not a Tailwind CSS class","line":184,"column":34,"messageId":"issue:unknown-classname","endLine":184,"endColumn":44,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-danger"},"fix":{"range":[6074,6096],"text":"btn mr-auto"},"desc":"Remove unknown classname 'btn-danger'"}]},{"ruleId":