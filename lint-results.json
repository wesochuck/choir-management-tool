names-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":74,"column":56,"messageId":"fix:sort","endLine":74,"endColumn":65},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":74,"column":66,"messageId":"fix:sort","endLine":74,"endColumn":71},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":74,"column":72,"messageId":"fix:sort","endLine":74,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":74,"column":78,"messageId":"fix:sort","endLine":74,"endColumn":84},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":74,"column":85,"messageId":"fix:sort","endLine":74,"endColumn":98},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":74,"column":99,"messageId":"fix:sort","endLine":74,"endColumn":109},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":74,"column":110,"messageId":"fix:sort","endLine":74,"endColumn":116},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":74,"column":117,"messageId":"fix:sort","endLine":74,"endColumn":131},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":74,"column":132,"messageId":"fix:sort","endLine":74,"endColumn":138},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":77,"column":40,"messageId":"fix:sort","endLine":77,"endColumn":55,"fix":{"range":[4235,4275],"text":"flex w-full items-center justify-between"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":77,"column":56,"messageId":"fix:sort","endLine":77,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":77,"column":63,"messageId":"fix:sort","endLine":77,"endColumn":75},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":78,"column":39,"messageId":"fix:sort","endLine":78,"endColumn":46,"fix":{"range":[4315,4358],"text":"`rounded px-1.5 py-0.5 text-sm font-bold ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":78,"column":61,"messageId":"fix:sort","endLine":78,"endColumn":68},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":81,"column":46,"messageId":"fix:sort","endLine":81,"endColumn":58,"fix":{"range":[4469,4556],"text":"text-xs font-semibold text-primary opacity-0 transition-opacity group-hover:opacity-100"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":81,"column":59,"messageId":"fix:sort","endLine":81,"endColumn":72},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":81,"column":83,"messageId":"fix:sort","endLine":81,"endColumn":106},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":81,"column":107,"messageId":"fix:sort","endLine":81,"endColumn":125},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":85,"column":36,"messageId":"fix:sort","endLine":85,"endColumn":50,"fix":{"range":[4678,4727],"text":"mt-1 text-[0.72rem] leading-tight text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":85,"column":51,"messageId":"fix:sort","endLine":85,"endColumn":66},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":85,"column":67,"messageId":"fix:sort","endLine":85,"endColumn":71},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":85,"column":72,"messageId":"fix:sort","endLine":85,"endColumn":85}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":45,"fixableErrorCount":0,"fixableWarningCount":9,"source":"import React from 'react';\n\ninterface Placeholder {\n  tag: string;\n  label: string;\n  desc: string;\n  category: 'Recipient' | 'Event' | 'RSVP';\n  className: string;\n}\n\nconst PLACEHOLDERS: Placeholder[] = [\n  { tag: '{singerName}', label: 'Singer Name', desc: \"Recipient's full name (e.g. 'John Doe')\", category: 'Recipient', className: 'text-emerald-600 bg-emerald-50' },\n  { tag: '{eventTitle}', label: 'Event Title', desc: 'The title of the selected event', category: 'Event', className: 'text-blue-600 bg-blue-50' },\n  { tag: '{eventType}', label: 'Event Type', desc: \"The type (e.g. 'Performance', 'Rehearsal')\", category: 'Event', className: 'text-blue-600 bg-blue-50' },\n  { tag: '{eventDate}', label: 'Event Date', desc: 'Formatted date and time of the event', category: 'Event', className: 'text-blue-600 bg-blue-50' },\n  { tag: '{eventLocation}', label: 'Event Location', desc: 'Name of the venue for the event', category: 'Event', className: 'text-blue-600 bg-blue-50' },\n  { tag: '{eventCallTime}', label: 'Event Call Time', desc: 'Formatted call time of the performance (e.g. 6:15 PM)', category: 'Event', className: 'text-blue-600 bg-blue-50' },\n  { tag: '{eventDetails}', label: 'Event Details', desc: 'Administrative details/notes', category: 'Event', className: 'text-blue-600 bg-blue-50' },\n  { tag: '{setlist}', label: 'Set List', desc: \"The performance program (songs, composers, intermissions)\", category: 'Event', className: 'text-blue-600 bg-blue-50' },\n  { tag: '{{PLAYER_LINK}}', label: 'Practice Player', desc: 'Generates an unauthenticated standalone practice player button (requires Event context)', category: 'Event', className: 'text-purple-600 bg-purple-50' },\n  { tag: '{{POLL_LINK:pollId}}', label: 'Engagement Poll', desc: 'Inserts a personalized \"Volunteer\" poll link (choose poll after clicking)', category: 'RSVP', className: 'text-amber-600 bg-amber-50' },\n  { tag: '{{RSVP_LINKS}}', label: 'RSVP Buttons', desc: 'Generates beautiful \"Yes/No\" response buttons', category: 'RSVP', className: 'text-orange-600 bg-orange-50' },\n];\n\ninterface PlaceholderPanelProps {\n  onInsert: (tag: string) => void;\n  hasEvent?: boolean;\n  hasApprovedSetList?: boolean;\n  hasCallTime?: boolean;\n}\n\nexport const PlaceholderPanel: React.FC<PlaceholderPanelProps> = ({ \n  onInsert,\n  hasEvent = true,\n  hasApprovedSetList = true,\n  hasCallTime = true\n}) => {\n  const visiblePlaceholders = PLACEHOLDERS.filter(p => {\n    if (p.category === 'Recipient') return true;\n    if (p.tag.startsWith('{{POLL_LINK:')) return true;\n    if (!hasEvent) return false;\n    if (p.tag === '{eventCallTime}') return hasCallTime;\n    if (p.tag === '{{PLAYER_LINK}}') return hasApprovedSetList;\n    return true;\n  });\n\n  const categories = Array.from(new Set(visiblePlaceholders.map(p => p.category))) as Placeholder['category'][];\n\n  return (\n    <div className=\"card p-4 bg-surface border border-border rounded-xl sticky top-6 max-h-[calc(100vh-120px)] flex flex-col gap-4 shadow-sm\">\n      <div className=\"border-b border-border pb-2\">\n        <div className=\"flex items-center gap-2\">\n          <span>⚡</span>\n          <h4 className=\"m-0 text-sm font-bold text-primary-deep\">Placeholders</h4>\n        </div>\n        <p className=\"text-muted text-xs mt-1 m-0\">\n          Click any badge to insert dynamic text at cursor.\n        </p>\n      </div>\n\n      <div className=\"flex flex-col gap-4 overflow-y-auto overflow-x-hidden pr-1\">\n        {categories.map(cat => {\n          const items = visiblePlaceholders.filter(p => p.category === cat);\n          return (\n            <div key={cat} className=\"flex flex-col gap-1.5\">\n              <div className=\"text-[10px] font-bold uppercase tracking-wider text-text-muted mb-0.5\">\n                {cat} Placeholders\n              </div>\n              {items.map((p) => (\n                <button\n                  key={p.tag}\n                  type=\"button\"\n                  onClick={() => onInsert(p.tag)}\n                  className=\"flex flex-col items-start text-left p-2.5 bg-bg border border-border rounded-md h-auto cursor-pointer w-full transition-all duration-200 hover:bg-primary-light\"\n                  title={`Insert ${p.tag}`}\n                >\n                  <div className=\"flex justify-between w-full items-center\">\n                    <code className={`text-sm px-1.5 py-0.5 rounded font-bold ${p.className}`}>\n                      {p.tag}\n                    </code>\n                    <span className=\"text-xs text-primary font-semibold opacity-0 group-hover:opacity-100 transition-opacity\">\n                      + Insert\n                    </span>\n                  </div>\n                  <span className=\"text-[0.72rem] text-text-muted mt-1 leading-tight\">{p.desc}</span>\n                </button>\n              ))}\n            </div>\n          );\n        })}\n      </div>\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/PollSelectionModal.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":87,"column":25,"messageId":"issue:unknown-classname","endLine":87,"endColumn":28,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[2222,2236],"text":"`btn-sm ${"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname