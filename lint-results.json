:333,"column":50,"messageId":"fix:sort","endLine":333,"endColumn":59},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":333,"column":60,"messageId":"fix:sort","endLine":333,"endColumn":73},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":333,"column":74,"messageId":"fix:sort","endLine":333,"endColumn":83},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":333,"column":99,"messageId":"fix:sort","endLine":333,"endColumn":105},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":333,"column":106,"messageId":"fix:sort","endLine":333,"endColumn":112},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":338,"column":59,"messageId":"fix:sort","endLine":338,"endColumn":71,"fix":{"range":[13987,14107],"text":"flex cursor-pointer items-center gap-2 px-2.5 py-1 transition-colors duration-[0.12s] select-none hover:bg-primary-light"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":338,"column":72,"messageId":"fix:sort","endLine":338,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":338,"column":78,"messageId":"fix:sort","endLine":338,"endColumn":84},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":338,"column":85,"messageId":"fix:sort","endLine":338,"endColumn":89},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":338,"column":90,"messageId":"fix:sort","endLine":338,"endColumn":104},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":343,"column":40,"messageId":"fix:sort","endLine":343,"endColumn":54,"fix":{"range":[14347,14365],"text":"m-0 cursor-pointer"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":343,"column":55,"messageId":"fix:sort","endLine":343,"endColumn":58},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":39,"messageId":"fix:sort","endLine":349,"endColumn":43,"fix":{"range":[14660,14843],"text":"col-span-full mt-1 flex cursor-pointer items-center gap-2 border-t border-dashed border-gray-200 px-2.5 py-1 pt-2 transition-colors duration-[0.12s] select-none hover:bg-primary-light"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":44,"messageId":"fix:sort","endLine":349,"endColumn":56},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":57,"messageId":"fix:sort","endLine":349,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":63,"messageId":"fix:sort","endLine":349,"endColumn":69},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":70,"messageId":"fix:sort","endLine":349,"endColumn":74},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":75,"messageId":"fix:sort","endLine":349,"endColumn":89},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":90,"messageId":"fix:sort","endLine":349,"endColumn":107},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":108,"messageId":"fix:sort","endLine":349,"endColumn":124},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":125,"messageId":"fix:sort","endLine":349,"endColumn":136},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":137,"messageId":"fix:sort","endLine":349,"endColumn":159},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":160,"messageId":"fix:sort","endLine":349,"endColumn":173},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":174,"messageId":"fix:sort","endLine":349,"endColumn":178},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":179,"messageId":"fix:sort","endLine":349,"endColumn":187},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":188,"messageId":"fix:sort","endLine":349,"endColumn":201},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":202,"messageId":"fix:sort","endLine":349,"endColumn":217},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":349,"column":218,"messageId":"fix:sort","endLine":349,"endColumn":222},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":354,"column":36,"messageId":"fix:sort","endLine":354,"endColumn":50,"fix":{"range":[15109,15127],"text":"m-0 cursor-pointer"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":354,"column":51,"messageId":"fix:sort","endLine":354,"endColumn":54},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":26,"messageId":"fix:sort","endLine":366,"endColumn":35,"fix":{"range":[15616,15709],"text":"h-11 w-[200px] rounded-lg border border-gray-200 bg-surface px-3 pr-9 text-base text-gray-800"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":36,"messageId":"fix:sort","endLine":366,"endColumn":40},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":41,"messageId":"fix:sort","endLine":366,"endColumn":45},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":46,"messageId":"fix:sort","endLine":366,"endColumn":50},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":51,"messageId":"fix:sort","endLine":366,"endColumn":64},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":76,"messageId":"fix:sort","endLine":366,"endColumn":85},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":86,"messageId":"fix:sort","endLine":366,"endColumn":92},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":93,"messageId":"fix:sort","endLine":366,"endColumn":108},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":109,"messageId":"fix:sort","endLine":366,"endColumn":119},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":377,"column":26,"messageId":"fix:sort","endLine":377,"endColumn":35,"fix":{"range":[16122,16215],"text":"h-11 w-[200px] rounded-lg border border-gray-200 bg-surface px-3 pr-9 text-base text-gray-800"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":377,"column":36,"messageId":"fix:sort","endLine":377,"endColumn":40},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":377,"column":41,"messageId":"fix:sort","endLine":377,"endColumn":45},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":377,"column":46,"messageId":"fix:sort","endLine":377,"endColumn":50},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":377,"column":51,"messageId":"fix:sort","endLine":377,"endColumn":64},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":377,"column":76,"messageId":"fix:sort","endLine":377,"endColumn":85},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":377,"column":86,"messageId":"fix:sort","endLine":377,"endColumn":92},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":377,"column":93,"messageId":"fix:sort","endLine":377,"endColumn":108},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":377,"column":109,"messageId":"fix:sort","endLine":377,"endColumn":119},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":390,"column":28,"messageId":"issue:unknown-classname","endLine":390,"endColumn":31,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[16725,16789],"text":"btn-secondary h-11 flex items-center gap-1 whitespace-nowrap"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-secondary' is not a Tailwind CSS class","line":390,"column":32,"messageId":"issue:unknown-classname","endLine":390,"endColumn":45,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-secondary"},"fix":{"range":[16725,16789],"text":"btn h-11 flex items-center gap-1 whitespace-nowrap"},"desc":"Remove unknown classname 'btn-secondary'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":390,"column":46,"messageId":"fix:sort","endLine":390,"endColumn":50,"fix":{"range":[16725,16789],"text":"btn btn-secondary flex h-11 items-center gap-1 whitespace-nowrap"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":390,"column":51,"messageId":"fix:sort","endLine":390,"endColumn":55}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":155,"fixableErrorCount":0,"fixableWarningCount":25,"source":"import { useState, useEffect, useMemo } from 'react';\nimport { useSearchParams } from 'react-router-dom';\nimport { useProfiles } from '../../hooks/useProfiles';\nimport { RosterTable } from '../../components/admin/RosterTable';\nimport { SingerModal } from '../../components/admin/SingerModal';\nimport { RosterSummary } from '../../components/admin/RosterSummary';\nimport type { Profile, ProfileInput } from '../../services/profileService';\nimport { RosterImportModal } from '../../components/admin/RosterImportModal';\nimport { exportToCSV } from '../../services/profileService';\nimport { settingsService } from '../../services/settingsService';\nimport { sortProfiles } from '../../lib/singerSort';\nimport { getVoicePartFilterLabel } from '../../lib/voicePartLabels';\nimport { useDues } from '../../hooks/useDues';\nimport { useAuth } from '../../contexts/AuthContext';\nimport { useRosterConfigForm } from '../../hooks/useRosterConfigForm';\nimport { RosterSettingsTab } from '../../components/admin/RosterSettingsTab';\nimport { useVoiceParts } from '../../hooks/useVoiceParts';\nimport { useRateLimitRetryToast } from '../../hooks/useRateLimitRetryToast';\n\nexport default function RosterView() {\n  const { user, updatePreferences } = useAuth();\n  const { onRetry: onRosterRateLimitRetry, reset: resetRosterRateLimitToast } = useRateLimitRetryToast(\n    'Roster loading is being rate-limited; retrying automatically...',\n  );\n  const { allProfiles, profiles, unfilteredByVoicePartProfiles, isLoading, error, filters, setFilter, addProfile, editProfile, removeProfile, refresh } = useProfiles({\n    onRateLimitRetry: onRosterRateLimitRetry,\n  });\n  const { currentSeason, duesMap, toggleDues } = useDues();\n  const [searchParams, setSearchParams] = useSearchParams();\n  const initialVoicePart = searchParams.get('voicePart') || '';\n  const { labels: voicePartLabels, sections: configSectionsHook, refresh: refreshVoiceParts } = useVoiceParts();\n\n  const [activeTab, setActiveTab] = useState<'roster' | 'config'>('roster');\n  const [isModalOpen, setIsModalOpen] = useState(false);\n  const [isImportModalOpen, setIsImportModalOpen] = useState(false);\n  const [editingProfile, setEditingProfile] = useState<Profile | null>(null);\n  const [isDropdownOpen, setIsDropdownOpen] = useState(false);\n\n  // Roster Sort user preference & fallback\n  const [defaultSort, setDefaultSort] = useState<'lastName' | 'voicePart'>('lastName');\n  const sortBy = user?.preferences?.rosterSort || defaultSort;\n  const setSortBy = (val: 'lastName' | 'voicePart') => {\n    updatePreferences({ rosterSort: val });\n  };\n\n  // Pagination State\n  const [currentPage, setCurrentPage] = useState(1);\n  const [pageSize] = useState(25);\n\n  // Reset to first page when search filters or sorting selections change\n  useEffect(() => {\n    if (isLoading) {\n      resetRosterRateLimitToast();\n    }\n  }, [isLoading, resetRosterRateLimitToast]);\n\n  useEffect(() => {\n    setCurrentPage(1);\n  }, [filters.name, filters.voiceParts, filters.status, sortBy, pageSize]);\n\n  // Handle deep linking for a specific singer profile\n  useEffect(() => {\n    if (isLoading) return;\n    const singerId = searchParams.get('singerId');\n    const openModal = searchParams.get('openModal') === 'true';\n    const addNew = searchParams.get('add') === 'true';\n\n    if (singerId && openModal && allProfiles.length > 0) {\n      const found = allProfiles.find(p => p.id === singerId);\n      if (found) {\n        setEditingProfile(found);\n        setIsModalOpen(true);\n        // Clear search parameters\n        const newParams = new URLSearchParams(searchParams);\n        newParams.delete('singerId');\n        newParams.delete('openModal');\n        setSearchParams(newParams, { replace: true });\n      }\n    } else if (addNew) {\n      setEditingProfile(null);\n      setIsModalOpen(true);\n      // Clear search parameter\n      const newParams = new URLSearchParams(searchParams);\n      newParams.delete('add');\n      setSearchParams(newParams, { replace: true });\n    }\n  }, [allProfiles, isLoading, searchParams, setSearchParams]);\n\n  // Config hook integration\n  const {\n    configDefaultStatus,\n    setConfigDefaultStatus,\n    configSeason,\n    setConfigSeason,\n    configSections,\n    setConfigSections,\n    configVoiceParts,\n    setConfigVoiceParts,\n    configAutomationEnabled,\n    setConfigAutomationEnabled,\n    configAutomationMissThreshold,\n    setConfigAutomationMissThreshold,\n    configAutomationRecoveryEnabled,\n    setConfigAutomationRecoveryEnabled,\n    configMaxRehearsalMisses,\n    setConfigMaxRehearsalMisses,\n    isSavingConfig,\n    configMessage,\n    isConfigDirty,\n    activeColorPickerIndex,\n    setActiveColorPickerIndex,\n    handleConfigSave,\n    handleConfigDiscard,\n  } = useRosterConfigForm({\n    setFilter,\n    refreshRoster: refresh,\n    refreshVoiceParts,\n  });\n\n  useEffect(() => {\n    settingsService.getRosterSettings().then(settings => {\n      if (settings && settings.defaultSort !== undefined) {\n        setDefaultSort(settings.defaultSort);\n      }\n    }).catch(err => {\n      console.error('Failed to load roster settings:', err);\n    });\n  }, []);\n\n  useEffect(() => {\n    if (initialVoicePart) {\n      setFilter('voiceParts', [initialVoicePart]);\n    }\n  }, [initialVoicePart, setFilter]);\n\n  useEffect(() => {\n    if (!isDropdownOpen) return;\n    const handleOutsideClick = (e: MouseEvent) => {\n      const target = e.target as HTMLElement;\n      if (!target.closest('#voice-part-dropdown-container')) {\n        setIsDropdownOpen(false);\n      }\n    };\n    document.addEventListener('mousedown', handleOutsideClick);\n    return () => document.removeEventListener('mousedown', handleOutsideClick);\n  }, [isDropdownOpen]);\n\n  const sortedProfiles = useMemo(() => {\n    return sortProfiles(profiles, sortBy, voicePartLabels);\n  }, [profiles, sortBy, voicePartLabels]);\n\n  const paginatedProfiles = useMemo(() => {\n    const startIndex = (currentPage - 1) * pageSize;\n    return sortedProfiles.slice(startIndex, startIndex + pageSize);\n  }, [sortedProfiles, currentPage, pageSize]);\n\n  const handleVoicePartToggle = (part: string) => {\n    const active = filters.voiceParts || [];\n    const next = active.includes(part)\n      ? active.filter(p => p !== part)\n      : [...active, part];\n    setFilter('voiceParts', next);\n  };\n\n  const getDropdownLabel = () => {\n    const active = filters.voiceParts || [];\n    return getVoicePartFilterLabel(active, configSectionsHook, voicePartLabels);\n  };\n\n\n\n\n\n  const handleEdit = (profile: Profile) => {\n    setEditingProfile(profile);\n    setIsModalOpen(true);\n  };\n\n  const handleAdd = () => {\n    setEditingProfile(null);\n    setIsModalOpen(true);\n  };\n\n  const handleSave = async (data: ProfileInput) => {\n    if (editingProfile) {\n      await editProfile(editingProfile.id, data);\n    } else {\n      await addProfile(data);\n    }\n  };\n\n  const handleDelete = async (profile: Profile) => {\n    await removeProfile(profile.id);\n  };\n\n  const handleExportCSV = () => {\n    const csvContent = exportToCSV(profiles);\n    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });\n    const url = URL.createObjectURL(blob);\n    const link = document.createElement('a');\n    link.setAttribute('href', url);\n    link.setAttribute('download', 'choir_roster_export.csv');\n    link.style.visibility = 'hidden';\n    document.body.appendChild(link);\n    link.click();\n    document.body.removeChild(link);\n  };\n\n  if (isLoading && profiles.length === 0) return <div className=\"p-5\">Loading roster...</div>;\n  if (error) return <div className=\"p-5 text-red-500\">Error: {error}</div>;\n\n  return (\n    <div className=\"flex flex-col gap-6 pb-8\">\n      <div className=\"flex items-center justify-between mb-6\">\n        <h1 className=\"admin-view-title\">Global Roster</h1>\n        {activeTab === 'roster' && (\n          <div className=\"flex items-center gap-2\">\n            <button onClick={handleExportCSV} className=\"btn btn-secondary\">Export Roster</button>\n            <button onClick={() => setIsImportModalOpen(true)} className=\"btn btn-secondary\">Import CSV</button>\n            <button onClick={handleAdd} className=\"btn btn-primary\">+ Add Singer</button>\n          </div>\n        )}\n      </div>\n\n      {/* Segmented Tab Navigation */}\n      <div className=\"flex flex-row gap-2 no-print border-b border-gray-200 pb-1 mb-2\">\n        <button\n          onClick={() => setActiveTab('roster')}\n          className={`btn ${activeTab === 'roster' ? 'btn-primary' : 'btn-ghost'} px-4 py-2 text-base`}\n        >\n          Singer Directory\n        </button>\n        <button\n          onClick={() => setActiveTab('config')}\n          className={`btn ${activeTab === 'config' ? 'btn-primary' : 'btn-ghost'} px-4 py-2 text-base`}\n        >\n          Roster Settings\n        </button>\n      </div>\n\n      {activeTab === 'roster' ? (\n        <>\n          <RosterSummary \n            profiles={unfilteredByVoicePartProfiles} \n            selectedVoiceParts={filters.voiceParts}\n            onVoicePartToggle={handleVoicePartToggle}\n          />\n\n          <div className=\"flex flex-row flex-wrap gap-4 items-end\">\n            <div className=\"relative flex-1 min-w-[250px]\">\n              <input\n                type=\"text\"\n                placeholder=\"Search by name or email...\"\n                value={filters.name || ''}\n                onChange={(e) => setFilter('name', e.target.value)}\n                className=\"card w-full h-11 pl-10 pr-3 text-base\"\n              />\n              <span className=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                  <circle cx=\"11\" cy=\"11\" r=\"8\"></circle>\n                  <line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"></line>\n                </svg>\n              </span>\n              {filters.name && (\n                <button\n                  onClick={() => setFilter('name', '')}\n                  className=\"absolute right-3 top-1/2 -translate-y-1/2 bg-none border-none text-gray-500 cursor-pointer flex items-center justify-center p-1 rounded-full hover:bg-black/5\"\n                  title=\"Clear search\"\n                >\n                  <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"3\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                    <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n                    <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n                  </svg>\n                </button>\n              )}\n            </div>\n\n            <div id=\"voice-part-dropdown-container\" className=\"relative w-[200px]\">\n              <button\n                type=\"button\"\n                onClic