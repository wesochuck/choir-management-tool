leId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'arrow-btn' is not a Tailwind CSS class","line":108,"column":43,"messageId":"issue:unknown-classname","endLine":108,"endColumn":52,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"arrow-btn"},"fix":{"range":[3543,3555],"text":"}`"},"desc":"Remove unknown classname 'arrow-btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'arrow-btn' is not a Tailwind CSS class","line":119,"column":43,"messageId":"issue:unknown-classname","endLine":119,"endColumn":52,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"arrow-btn"},"fix":{"range":[3840,3852],"text":"}`"},"desc":"Remove unknown classname 'arrow-btn'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":22,"fixableErrorCount":0,"fixableWarningCount":2,"source":"import React from 'react';\n\nexport interface PaginationProps {\n  currentPage: number;\n  totalPages: number;\n  onPageChange: (page: number) => void;\n  siblingCount?: number;\n}\n\nimport { computePaginationRange, DOTS } from '../../lib/paginationUtils';\n\nconst paginationBtnClass =\n  'inline-flex justify-center items-center min-w-[38px] h-[38px] px-2 rounded-lg border border-border bg-white text-text text-sm font-medium cursor-pointer transition-all duration-200 outline-none ' +\n  'disabled:opacity-40 disabled:cursor-not-allowed disabled:bg-gray-100 disabled:text-text-muted disabled:border-border disabled:transform-none ' +\n  'hover:enabled:border-primary-deep hover:enabled:bg-gray-50 hover:enabled:text-primary-deep hover:enabled:-translate-y-px ' +\n  'active:enabled:translate-y-0 ' +\n  'focus-visible:shadow-[0_0_0_2px_white,0_0_0_4px_var(--primary-deep)] ' +\n  'motion-reduce:transition-none motion-reduce:transform-none';\n\nconst activeBtnClass =\n  '!bg-primary-deep !text-white !border-primary-deep font-semibold shadow-md hover:enabled:translate-y-0';\n\nexport const Pagination: React.FC<PaginationProps> = ({\n  currentPage,\n  totalPages,\n  onPageChange,\n  siblingCount = 1,\n}) => {\n  // Compute sliding window page array using extracted helper\n  const paginationRange = React.useMemo(() => {\n    return computePaginationRange(currentPage, totalPages, siblingCount);\n  }, [currentPage, totalPages, siblingCount]);\n\n\n  // If there is only 1 page, don't display pagination at all or show simple page info\n  if (totalPages <= 1) {\n    return null;\n  }\n\n  const handlePageChange = (page: number) => {\n    if (page >= 1 && page <= totalPages && page !== currentPage) {\n      onPageChange(page);\n    }\n  };\n\n  return (\n    <nav \n      className=\"flex-row m-4 mx-auto select-none flex justify-center items-center gap-1 flex-wrap\" \n      role=\"navigation\" \n      aria-label=\"Pagination Navigation\"\n    >\n      {/* First Page Button */}\n      <button\n        type=\"button\"\n        className={`${paginationBtnClass} arrow-btn`}\n        onClick={() => handlePageChange(1)}\n        disabled={currentPage === 1}\n        aria-label=\"Go to first page\"\n      >\n        ⏮\n      </button>\n\n      {/* Previous Page Button */}\n      <button\n        type=\"button\"\n        className={`${paginationBtnClass} arrow-btn`}\n        onClick={() => handlePageChange(currentPage - 1)}\n        disabled={currentPage === 1}\n        aria-label=\"Go to previous page\"\n      >\n        ◀\n      </button>\n\n      {/* Page Numbers */}\n      {paginationRange.map((pageNumber, idx) => {\n        if (pageNumber === DOTS) {\n          return (\n            <span \n              key={`dots-${idx}`} \n              className=\"inline-flex items-center justify-center min-w-[32px] h-[38px] text-base text-text-muted cursor-default px-3 font-semibold\"\n              aria-hidden=\"true\"\n            >\n              &#8230;\n            </span>\n          );\n        }\n\n        const pageNum = pageNumber as number;\n        const isCurrent = pageNum === currentPage;\n\n        return (\n          <button\n            key={pageNum}\n            type=\"button\"\n            className={`${paginationBtnClass} num-btn ${isCurrent ? activeBtnClass : ''}`}\n            onClick={() => handlePageChange(pageNum)}\n            aria-label={`Go to page ${pageNum}`}\n            aria-current={isCurrent ? 'page' : undefined}\n          >\n            {pageNum}\n          </button>\n        );\n      })}\n\n      {/* Next Page Button */}\n      <button\n        type=\"button\"\n        className={`${paginationBtnClass} arrow-btn`}\n        onClick={() => handlePageChange(currentPage + 1)}\n        disabled={currentPage === totalPages}\n        aria-label=\"Go to next page\"\n      >\n        ▶\n      </button>\n\n      {/* Last Page Button */}\n      <button\n        type=\"button\"\n        className={`${paginationBtnClass} arrow-btn`}\n        onClick={() => handlePageChange(totalPages)}\n        disabled={currentPage === totalPages}\n        aria-label=\"Go to last page\"\n      >\n        ⏭\n      </button>\n    </nav>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/common/PhotoUploader.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'photo-uploader-avatar' is not a Tailwind CSS class","line":414,"column":20,"messageId":"issue:unknown-classname","endLine":414,"endColumn":41,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"photo-uploader-avatar"},"fix":{"range":[12640,12661],"text":""},"desc":"Remove unknown classname 'photo-uploader-avatar'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'photo-uploader-avatar-img' is not a Tailwind CSS class","line":421,"column":24,"messageId":"issue:unknown-classname","endLine":421,"endColumn":49,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"photo-uploader-av