ition-all duration-150 cursor-pointer ml-auto ${activeTab === 'compose' ? 'bg-primary border-primary text-white' : 'bg-primary-light border-primary-light text-primary-deep hover:bg-primary hover:border-primary hover:text-white'}`}\n        onClick={() => onTabChange('compose')}\n      >\n        <span aria-hidden=\"true\">+</span>\n        <span>New Message</span>\n      </button>\n    </div>\n  );\n};\n\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/ComposeStep.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'composer-form' is not a Tailwind CSS class","line":32,"column":21,"messageId":"issue:unknown-classname","endLine":32,"endColumn":34,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"composer-form"},"fix":{"range":[889,917],"text":"flex-col gap-4"},"desc":"Remove unknown classname 'composer-form'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":33,"column":32,"messageId":"fix:sort","endLine":33,"endColumn":44,"fix":{"range":[942,979],"text":"flex-row flex-wrap items-center gap-2"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":33,"column":45,"messageId":"fix:sort","endLine":33,"endColumn":50},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":33,"column":51,"messageId":"fix:sort","endLine":33,"endColumn":60},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'composer-subject-field' is not a Tailwind CSS class","line":34,"column":25,"messageId":"issue:unknown-classname","endLine":34,"endColumn":47,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"composer-subject-field"},"fix":{"range":[1006,1048],"text":"flex flex-col gap-1"},"desc":"Remove unknown classname 'composer-subject-field'"