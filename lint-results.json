r-2 text-center transition-all duration-200 hover:-translate-y-0.5 hover:opacity-90 hover:shadow-sm ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":96,"column":36,"messageId":"fix:sort","endLine":96,"endColumn":47},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":96,"column":48,"messageId":"fix:sort","endLine":96,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":96,"column":63,"messageId":"fix:sort","endLine":96,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":96,"column":78,"messageId":"fix:sort","endLine":96,"endColumn":90},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":96,"column":91,"messageId":"fix:sort","endLine":96,"endColumn":99},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":96,"column":123,"messageId":"fix:sort","endLine":96,"endColumn":138},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":96,"column":139,"messageId":"fix:sort","endLine":96,"endColumn":155},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":130,"column":27,"messageId":"fix:sort","endLine":130,"endColumn":35,"fix":{"range":[5056,5201],"text":"`cursor-pointer flex-col border text-center transition-all duration-200 hover:-translate-y-px hover:border-primary-deep hover:bg-primary-light ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":130,"column":36,"messageId":"fix:sort","endLine":130,"endColumn":47},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":130,"column":48,"messageId":"fix:sort","endLine":130,"endColumn":62},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":130,"column":63,"messageId":"fix:sort","endLine":130,"endColumn":77},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":130,"column":78,"messageId":"fix:sort","endLine":130,"endColumn":90},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":130,"column":91,"messageId":"fix:sort","endLine":130,"endColumn":97},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":130,"column":98,"messageId":"fix:sort","endLine":130,"endColumn":123},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":130,"column":124,"messageId":"fix:sort","endLine":130,"endColumn":146},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":130,"column":147,"messageId":"fix:sort","endLine":130,"endColumn":168},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":141,"column":31,"messageId":"fix:sort","endLine":141,"endColumn":38,"fix":{"range":[5798,5816],"text":"text-muted text-xs"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":141,"column":39,"messageId":"fix:sort","endLine":141,"endColumn":49},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-muted' is not a Tailwind CSS class","line":141,"column":39,"messageId":"issue:unknown-classname","endLine":141,"endColumn":49,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-muted"},"fix":{"range":[5798,5816],"text":"text-xs"},"desc":"Remove unknown classname 'text-muted'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-label' is not a Tailwind CSS class","line":143,"column":31,"messageId":"issue:unknown-classname","endLine":143,"endColumn":41,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-label"},"fix":{"range":[5958,5968],"text":""},"desc":"Remove unknown classname 'text-label'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":42,"fixableErrorCount":0,"fixableWarningCount":5,"source":"import React, { useMemo, useState, useEffect } from 'react';\nimport type { Profile } from '../../services/profileService';\nimport { getVoicePartsAndSections, type VoicePartDef, type SectionDef } from '../../services/settingsService';\nimport { getSectionFromVoicePart, getSectionsFromVoiceParts } from '../../lib/voicePartUtils';\nimport { AppCard } from '../common/AppCard';\n\ninterface RosterSummaryProps {\n  profiles: Profile[];\n  selectedVoiceParts?: string[];\n  onVoicePartToggle?: (part: string) => void;\n}\n\nexport const RosterSummary: React.FC<RosterSummaryProps> = ({ \n  profiles, \n  selectedVoiceParts = [], \n  onVoicePartToggle \n}) => {\n  const [voiceParts, setVoiceParts] = useState<VoicePartDef[]>([]);\n  const [sections, setSections] = useState<SectionDef[]>([]);\n\n  useEffect(() => {\n    getVoicePartsAndSections().then((settings) => {\n      setVoiceParts(settings.voiceParts);\n      setSections(settings.sections);\n    }).catch(() => undefined);\n  }, []);\n\n  const { partCounts, sectionCounts, sectionsList } = useMemo(() => {\n    const pc: Record<string, number> = {};\n    const sc: Record<string, number> = {};\n    \n    const sectionsListToUse = sections.length > 0 ? sections : getSectionsFromVoiceParts(voiceParts);\n    \n    voiceParts.forEach(part => pc[part.label] = 0);\n    sectionsListToUse.forEach((sec: SectionDef) => sc[sec.code] = 0);\n\n    profiles.forEach(p => {\n      if (p.voicePart) {\n        if (pc[p.voicePart] !== undefined) {\n          pc[p.voicePart]++;\n        } else {\n          pc[p.voicePart] = 1;\n        }\n\n        const vpDef = voiceParts.find(vp => vp.label === p.voicePart);\n        const section = vpDef ? vpDef.sectionCode : getSectionFromVoicePart(p.voicePart);\n\n        if (sc[section] !== undefined) {\n          sc[section]++;\n        } else {\n          sc[section] = (sc[section] || 0) + 1;\n        }\n      }\n    });\n    \n    return { partCounts: pc, sectionCounts: sc, sectionsList: sectionsListToUse };\n  }, [profiles, voiceParts, sections]);\n\n  const singerTotal = profiles.filter(p => !!p.voicePart).length;\n  const staffTotal = profiles.length - singerTotal;\n\n  return (\n    <AppCard \n      title=\"Voice Part Balance\"\n      actions={\n        <div className=\"flex gap-2\">\n          <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-primary-light text-primary-deep\">\n            {singerTotal} Singers\n          </span>\n          {staffTotal > 0 && (\n            <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-gray-500/10 text-gray-600 border border-gray-500/20\">\n              {staffTotal} Staff\n            </span>\n          )}\n        </div>\n      }\n      className=\"admin-settings-group\"\n    >\n      {/* Section Subtotals */}\n      <div \n        className=\"roster-summary-sections\"\n        // @allow-inline-style - dynamic grid columns based on section list length\n        style={{ \n          display: 'grid', \n          gridTemplateColumns: `repeat(${sectionsList.length}, 1fr)`, \n          gap: 'var(--space-md)',\n          paddingBottom: 'var(--space-md)',\n          borderBottom: '1px solid var(--border)'\n        }}\n      >\n        {sectionsList.map((sec: SectionDef) => {\n          const isSelected = selectedVoiceParts.includes(sec.code);\n          return (\n            <div \n              key={sec.code} \n              className={`flex-col text-center cursor-pointer transition-all duration-200 border-2 hover:-translate-y-0.5 hover:shadow-sm hover:opacity-90 ${isSelected ? 'border-primary shadow-[0_0_0_1px_var(--primary)]' : 'border-transparent'}`}\n              onClick={() => onVoicePartToggle?.(sec.code)}\n              // @allow-inline-style - dynamic padding based on selection state\n              style={{ \n                padding: 'calc(var(--space-md) - 2px)', \n                borderRadius: 'var(--radius-md)', \n                backgroundColor: 'var(--primary-light)',\n                gap: 'var(--space-xs)'\n              }}\n            >\n              {/* @allow-inline-style - typography overrides */}\n              <div className=\"text-xs\" style={{ color: 'var(--primary-deep)', fontWeight: 700, textTransform: 'uppercase', letterSpacing: '0.05em' }}>\n                {sec.name}\n              </div>\n              {/* @allow-inline-style - typography overrides */}\n              <div style={{ fontSize: '2rem', fontWeight: 800, color: 'var(--primary-deep)', lineHeight: 1 }}>{sectionCounts[sec.code] || 0}</div>\n            </div>\n          );\n        })}\n      </div>\n\n      {/* Individual Part Breakdowns */}\n      {/* @allow-inline-style - dynamic grid layout configuration */}\n      <div style={{ \n        display: 'grid', \n        gridTemplateColumns: 'repeat(auto-fit, minmax(80px, 1fr))', \n        gap: 'var(--space-sm)',\n        marginTop: 0\n      }}>\n        {voiceParts.map(vp => {\n          const isSelected = selectedVoiceParts.includes(vp.label);\n          return (\n            <div \n              key={vp.label} \n              className={`flex-col text-center cursor-pointer transition-all duration-200 border hover:border-primary-deep hover:bg-primary-light hover:-translate-y-px ${isSelected ? 'border-primary bg-primary-light' : 'border-border bg-[var(--bg)]'}`}\n              onClick={() => onVoicePartToggle?.(vp.label)}\n              // @allow-inline-style - dynamic padding based on selection state\n              style={{ \n                borderRadius: 'var(--radius-sm)', \n                gap: '2px',\n                borderWidth: isSelected ? '2px' : '1px',\n                padding: isSelected ? 'calc(var(--space-sm) - 1px)' : 'var(--space-sm)'\n              }}\n            >\n              {/* @allow-inline-style - typography overrides */}\n              <div className=\"text-xs text-muted\" style={{ fontWeight: 700 }}>{vp.label}</div>\n              {/* @allow-inline-style - typography overrides */}\n              <div className=\"text-label\" style={{ fontWeight: 700 }}>{partCounts[vp.label] || 0}</div>\n            </div>\n          );\n        })}\n      </div>\n    </AppCard>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/RosterTable.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":38,"column":23,"messageId":"fix:sort","endLine":38,"endColumn":38,"fix":{"range":[1092,1114],"text":"w-full overflow-x-auto"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":38,"column":39,"messageId":"fix:sort","endLine":38,"endColumn":45},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-label' is not a Tailwind CSS class","line":42,"column":30,"messageId":"issue:unknown-classname","endLine":42,"endColumn":40,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-label"},"fix":{"range":[1242,1252],"text":""},"desc":"Remove unknown classname 'text-label'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-label' is not a Tailwind CSS class","line":43,"column":30,"messageId":"issue:unknown-classname","endLine":43,"endColumn":40,"suggestions":[{"messageId":"fix:unknown-classname:remove","data