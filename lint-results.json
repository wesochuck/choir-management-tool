,"endColumn":126},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":332,"column":69,"messageId":"fix:sort","endLine":332,"endColumn":77,"fix":{"range":[14010,14051],"text":"flex animate-login-fade-in flex-col gap-6"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":332,"column":78,"messageId":"fix:sort","endLine":332,"endColumn":83},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":332,"column":84,"messageId":"fix:sort","endLine":332,"endColumn":105},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-label' is not a Tailwind CSS class","line":334,"column":37,"messageId":"issue:unknown-classname","endLine":334,"endColumn":47,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-label"},"fix":{"range":[14144,14154],"text":""},"desc":"Remove unknown classname 'text-label'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":341,"column":32,"messageId":"fix:sort","endLine":341,"endColumn":36,"fix":{"range":[14452,14643],"text":"h-11 w-full rounded-lg border border-border bg-surface px-3 font-sans text-base text-text transition-all focus:border-primary focus:shadow-[0_0_0_3px_rgba(109,40,217,0.15)] focus:outline-none"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":341,"column":37,"messageId":"fix:sort","endLine":341,"endColumn":41},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":341,"column":42,"messageId":"fix:sort","endLine":341,"endColumn":48},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":341,"column":70,"messageId":"fix:sort","endLine":341,"endColumn":80},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":341,"column":81,"messageId":"fix:sort","endLine":341,"endColumn":91},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":341,"column":92,"messageId":"fix:sort","endLine":341,"endColumn":101},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":341,"column":102,"messageId":"fix:sort","endLine":341,"endColumn":111},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":341,"column":112,"messageId":"fix:sort","endLine":341,"endColumn":121},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":346,"column":49,"messageId":"fix:sort","endLine":346,"endColumn":64,"fix":{"range":[14833,14875],"text":"flex flex-row items-center justify-between"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":346,"column":65,"messageId":"fix:sort","endLine":346,"endColumn":77},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'text-label' is not a Tailwind CSS class","line":347,"column":39,"messageId":"issue:unknown-classname","endLine":347,"endColumn":49,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"text-label"},"fix":{"range":[14916,14926],"text":""},"desc":"Remove unknown classname 'text-label'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":350,"column":34,"messageId":"fix:sort","endLine":350,"endColumn":37,"fix":{"range":[15067,15170],"text":"h-auto min-h-0 cursor-pointer border-none bg-none p-0 text-xs text-text-muted underline hover:text-text"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":350,"column":38,"messageId":"fix:sort","endLine":350,"endColumn":49},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":350,"column":50,"messageId":"fix:sort","endLine":350,"endColumn":57},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":350,"column":58,"messageId":"fix:sort","endLine":350,"endColumn":64},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":350,"column":65,"messageId":"fix:sort","endLine":350,"endColumn":72},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":350,"column":73,"messageId":"fix:sort","endLine":350,"endColumn":80},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":350,"column":81,"messageId":"fix:sort","endLine":350,"endColumn":96},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":350,"column":97,"messageId":"fix:sort","endLine":350,"endColumn":106},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":350,"column":107,"messageId":"fix:sort","endLine":350,"endColumn":121},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":32,"messageId":"fix:sort","endLine":366,"endColumn":36,"fix":{"range":[15746,15937],"text":"h-11 w-full rounded-lg border border-border bg-surface px-3 font-sans text-base text-text transition-all focus:border-primary focus:shadow-[0_0_0_3px_rgba(109,40,217,0.15)] focus:outline-none"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":37,"messageId":"fix:sort","endLine":366,"endColumn":41},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":42,"messageId":"fix:sort","endLine":366,"endColumn":48},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":70,"messageId":"fix:sort","endLine":366,"endColumn":80},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":81,"messageId":"fix:sort","endLine":366,"endColumn":91},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":92,"messageId":"fix:sort","endLine":366,"endColumn":101},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":102,"messageId":"fix:sort","endLine":366,"endColumn":111},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":366,"column":112,"messageId":"fix:sort","endLine":366,"endColumn":121},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":369,"column":41,"messageId":"fix:sort","endLine":369,"endColumn":57,"fix":{"range":[16023,16051],"text":"m-0 text-xs text-danger-text"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":369,"column":66,"messageId":"fix:sort","endLine":369,"endColumn":69},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":373,"column":30,"messageId":"issue:unknown-classname","endLine":373,"endColumn":33,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[16190,16217],"text":"btn-primary w-full mt-4"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-primary' is not a Tailwind CSS class","line":373,"column":34,"messageId":"issue:unknown-classname","endLine":373,"endColumn":45,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-primary"},"fix":{"range":[16190,16217],"text":"btn w-full mt-4"},"desc":"Remove unknown classname 'btn-primary'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":373,"column":46,"messageId":"fix:sort","endLine":373,"endColumn":52,"fix":{"range":[16190,16217],"text":"btn btn-primary mt-4 w-full"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":373,"column":53,"messageId":"fix:sort","endLine":373,"endColumn":57}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":221,"fixableErrorCount":0,"fixableWarningCount":42,"source":"import React, { useState, useEffect } from 'react';\nimport { pb } from '../lib/pocketbase';\nimport { useNavigate } from 'react-router-dom';\nimport { useDocumentTitle } from '../hooks/useDocumentTitle';\n\ntype LoginMode = 'otp' | 'password';\ntype OtpStep = 'request' | 'verify';\n\nexport default function LoginView() {\n  useDocumentTitle('Login');\n  const navigate = useNavigate();\n\n  const [email, setEmail] = useState('');\n  const [password, setPassword] = useState('');\n  const [loginMode, setLoginMode] = useState<LoginMode>('otp');\n  const [isForgotMode, setIsForgotMode] = useState(false);\n  const [isLoading, setIsLoading] = useState(false);\n  const [error, setError] = useState('');\n  const [resetSuccess, setResetSuccess] = useState('');\n\n  const [otpStep, setOtpStep] = useState<OtpStep>('request');\n  const [otpId, setOtpId] = useState('');\n  const [otpCode, setOtpCode] = useState('');\n  const [countdown, setCountdown] = useState(0);\n  const [resendCooldown, setResendCooldown] = useState(0);\n\n  useEffect(() => {\n    let interval: ReturnType<typeof setInterval> | null = null;\n    if (countdown > 0) {\n      interval = setInterval(() => {\n        setCountdown((prev) => prev - 1);\n      }, 1000);\n    } else if (countdown === 0 && otpStep === 'verify') {\n      setError('Login code has expired. Please request a new one.');\n    }\n    return () => {\n      if (interval) clearInterval(interval);\n    };\n  }, [countdown, otpStep]);\n\n  useEffect(() => {\n    let interval: ReturnType<typeof setInterval> | null = null;\n    if (resendCooldown > 0) {\n      interval = setInterval(() => {\n        setResendCooldown((prev) => prev - 1);\n      }, 1000);\n    }\n    return () => {\n      if (interval) clearInterval(interval);\n    };\n  }, [resendCooldown]);\n\n  const formatCountdown = (seconds: number): string => {\n    const mins = Math.floor(seconds / 60);\n    const secs = seconds % 60;\n    return `${mins}:${secs.toString().padStart(2, '0')}`;\n  };\n\n  const handleSwitchMode = (mode: LoginMode) => {\n    setLoginMode(mode);\n    setIsForgotMode(false);\n    setError('');\n    setResetSuccess('');\n    setOtpStep('request');\n    setOtpCode('');\n    setPassword('');\n  };\n\n  const handlePasswordSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setIsLoading(true);\n    setError('');\n    \n    try {\n      await pb.collection('users').authWithPassword(email.trim().toLowerCase(), password);\n      navigate('/');\n    } catch {\n      setError('Invalid email or password');\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleRequestReset = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setIsLoading(true);\n    setError('');\n    setResetSuccess('');\n\n    try {\n      await pb.collection('users').requestPasswordReset(email.trim().toLowerCase());\n      setResetSuccess('A password reset link has been sent to your email.');\n      setEmail('');\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : 'Failed to request password reset. Please try again.';\n      setError(msg);\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleRequestOTP = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setIsLoading(true);\n    setError('');\n    \n    try {\n      const result = await pb.collection('users').requestOTP(email.trim().toLowerCase());\n      setOtpId(result.otpId);\n      setOtpStep('verify');\n      setCountdown(1800);\n      setResendCooldown(60);\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : 'No account found with this email, or failed to send login code.';\n      setError(msg);\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleResendOTP = async () => {\n    if (resendCooldown > 0) return;\n    setIsLoading(true);\n    setError('');\n    setOtpCode('');\n    \n    try {\n      const result = await pb.collection('users').requestOTP(email.trim().toLowerCase());\n      setOtpId(result.otpId);\n      setCountdown(1800);\n      setResendCooldown(60);\n      setResetSuccess('A fresh 6-digit login code has been sent to your email.');\n      setTimeout(() => setResetSuccess(''), 6000);\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : 'Failed to resend code. Please try again.';\n      setError(msg);\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleVerifyOTP = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setIsLoading(true);\n    setError('');\n    \n    try {\n      await pb.collection('users').authWithOTP(otpId, otpCode.trim());\n      navigate('/');\n    } catch {\n      setError('Invalid or expired login code. Please check and try again.');\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  return (\n    <div className=\"flex flex-col items-center justify-center min-h-screen w-screen p-4 bg-bg\">\n      <div className=\"w-full max-w-[min(400px,calc(100vw-32px))] shadow-[0_10px_25px_-5px_rgb(0_0_0_/_5%),0_8px_16px_-6px_rgb(0_0_0_/_3%)] transition-all duration-300 bg-surface rounded-xl border border-border p-8 hover:-translate-y-0.5 hover:shadow-[0_20px_30px_-10px_rgb(91_33_182_/_6%),0_10px_20px_-8px_rgb(0_0_0_/_4%)] hover:border-[rgba(109,40,217,0.2)]\">\n        <h1 className=\"text-center text-3xl font-extrabold text-text mb-6 tracking-tight\">\n          {isForgotMode ? 'Reset Password' : 'Singer Portal'}\n        </h1>\n\n        {!isForgotMode && otpStep === 'request' && (\n          <div className=\"flex border-b-2 border-border mb-6 gap-1\">\n            <button\n              type=\"button\"\n              className={`flex-1 bg-transparent border-none text-sm font-semibold py-2 cursor-pointer relative transition-all text-center outline-none ${loginMode === 'otp' ? 'text-primary font-bold after:content-[\"\"] after:absolute after:bottom-[-2px] after:left-0 after:right-0 after:h-0.5 after:bg-primary after:rounded-sm' : 'text-text-muted hover:text-text'}`}\n              onClick={() => handleSwitchMode('otp')}\n            >\n              Email Code\n            </button>\n            <button\n              type=\"button\"\n              className={`flex-1 bg-transparent border-none text-sm font-semibold py-2 cursor-pointer relative transition-all text-center outline-none ${loginMode === 'password' ? 'text-primary font-bold after:content-[\"\"] after:absolute after:bottom-[-2px] after:left-0 after:right-0 after:h-0.5 after:bg-primary after:rounded-sm' : 'text-text-muted hover:text-text'}`}\n              onClick={() => handleSwitchMode('password')}\n            >\n              Password\n            </button>\n          </div>\n        )}\n\n        {isForgotMode ? (\n          <form onSubmit={handleRequestReset} className=\"flex flex-col gap-6 animate-login-fade-in\">\n            <p className=\"m-0 text-center text-sm text-text-muted leading-relaxed\">\n              Enter your email address and we'll send you a custom link to reset your password.\n            </p>\n\n            <div className=\"flex flex-col gap-1\">\n              <label className=\"text-label\" htmlFor=\"forgot-email\">Email Address</label>\n              <input\n                id=\"forgot-email\"\n                type=\"email\"\n                value={email}\n                onChange={(e) => setEmail(e.target.value)}\n                required\n                className=\"px-3 h-11 w-full border border-border rounded-lg bg-surface text-text font-sans text-base transition-all focus:border-primary focus:shadow-[0_0_0_3px_rgba(109,40,217,0.15)] focus:outline-none\"\n                placeholder=\"e.g. singer@choir.org\"\n              />\n            </div>\n\n            {error && <p className=\"text-danger-text text-xs m-0\">{error}</p>}\n            {resetSuccess && <p className=\"text-primary text-xs font-semibold m-0\">{resetSuccess}</p>}\n\n            <button\n              type=\"submit\"\n              disabled={isLoading}\n              className=\"btn btn-primary w-full mt-1\"\n            >\n              {isLoading ? 'Sending reset link...' : 'Send Reset Link'}\n            </button>\n\n            <button\n              type=\"button\"\n              className=\"self-center underline cursor-pointer h-auto p-0 text-xs text-text-muted hover:text-text\"\n              onClick={() => setIsForgotMode(false)}\n            >\n              ← Back to Login\n            </button>\n          </form>\n        ) : (\n          <div>\n            {loginMode === 'otp' && (\n              <div className=\"animate-login-fade-in\">\n                {otpStep === 'request' ? (\n                  <form onSubmit={handleRequestOTP} className=\"flex flex-col gap-6\">\n                    <p className=\"m-0 text-center text-sm text-text-muted leading-relaxed\">\n                      Sign in securely without a password. We'll email you a 6-digit login code.\n                    </p>\n                    <div className=\"flex flex-col gap-1\">\n                      <label className=\"text-label\" htmlFor=\"otp-email\">Email Address</label>\n                      <input\n                