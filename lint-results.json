"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-ghost' is not a Tailwind CSS class","line":161,"column":62,"messageId":"issue:unknown-classname","endLine":161,"endColumn":71,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-ghost"},"fix":{"range":[6962,6982],"text":"btn btn-sm"},"desc":"Remove unknown classname 'btn-ghost'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-sm' is not a Tailwind CSS class","line":161,"column":72,"messageId":"issue:unknown-classname","endLine":161,"endColumn":78,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-sm"},"fix":{"range":[6962,6982],"text":"btn btn-ghost"},"desc":"Remove unknown classname 'btn-sm'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":164,"column":58,"messageId":"issue:unknown-classname","endLine":164,"endColumn":61,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[7149,7173],"text":"btn-secondary btn-sm"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-secondary' is not a Tailwind CSS class","line":164,"column":62,"messageId":"issue:unknown-classname","endLine":164,"endColumn":75,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-secondary"},"fix":{"range":[7149,7173],"text":"btn btn-sm"},"desc":"Remove unknown classname 'btn-secondary'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-sm' is not a Tailwind CSS class","line":164,"column":76,"messageId":"issue:unknown-classname","endLine":164,"endColumn":82,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-sm"},"fix":{"range":[7149,7173],"text":"btn btn-secondary"},"desc":"Remove unknown classname 'btn-sm'"}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":84,"fixableErrorCount":0,"fixableWarningCount":13,"source":"import { useEffect, useState } from 'react';\nimport { type MessageRecord, type CommunicationRecipient } from '../../services/communicationService';\nimport { type Event } from '../../services/eventService';\nimport { type CommunicationSettings } from '../../services/settingsService';\nimport { resolvePreviewContent } from '../../lib/communicationUtils';\nimport { Pagination } from '../common/Pagination';\n\ninterface MessageHistoryProps {\n  history: MessageRecord[];\n  currentPage: number;\n  totalPages: number;\n  onPageChange: (page: number) => void;\n  historySearchQuery: string;\n  onHistorySearchChange: (query: string) => void;\n  onViewDetails: (message: MessageRecord) => void;\n  onCopyDraft: (message: MessageRecord) => void;\n  onViewRecipients: (recipients: CommunicationRecipient[], title: string) => void;\n  events: Event[];\n  commSettings: CommunicationSettings;\n}\n\nexport function MessageHistory({\n  history,\n  currentPage,\n  totalPages,\n  onPageChange,\n  historySearchQuery,\n  onHistorySearchChange,\n  onViewDetails,\n  onCopyDraft,\n  onViewRecipients,\n  events,\n  commSettings,\n}: MessageHistoryProps) {\n  const [searchTerm, setSearchTerm] = useState(historySearchQuery);\n\n  useEffect(() => {\n    const timeout = window.setTimeout(() => {\n      if (searchTerm !== historySearchQuery) {\n        onHistorySearchChange(searchTerm);\n      }\n    }, 300);\n    return () => window.clearTimeout(timeout);\n  }, [searchTerm, historySearchQuery, onHistorySearchChange]);\n\n  useEffect(() => {\n    setSearchTerm(historySearchQuery);\n  }, [historySearchQuery]);\n\n  return (\n    <div className=\"flex flex-col gap-4\">\n      <div className=\"flex gap-2 mb-1\">\n        <div className=\"relative flex-1\">\n          <input\n            type=\"text\"\n            className=\"card w-full h-10 px-3 border border-gray-200\"\n            placeholder=\"Search message history (subject, content, type)...\"\n            value={searchTerm}\n            onChange={(e) => setSearchTerm(e.target.value)}\n            style={{ paddingRight: searchTerm ? '32px' : '12px' }} // @allow-inline-style - dynamic padding based on clear button\n          />\n          {searchTerm && (\n            <button\n              type=\"button\"\n              className=\"absolute right-2 top-1/2 -translate-y-1/2 bg-transparent border-0 cursor-pointer text-text-muted text-xl leading-none\"\n              onClick={() => {\n                setSearchTerm('');\n                onHistorySearchChange('');\n              }}\n              title=\"Clear search\"\n            >\n              ×\n            </button>\n          )}\n        </div>\n      </div>\n\n      <div className=\"overflow-x-auto\">\n        <table className=\"border-collapse w-full min-w-[700px] text-left\">\n          <thead>\n            <tr className=\"border-b-2 border-gray-200 text-gray-500 text-sm\">\n              <th className=\"p-3 px-4 text-left\">Date</th>\n              <th className=\"p-3 px-4 text-left\">Type</th>\n              <th className=\"p-3 px-4 text-left\">Subject</th>\n              <th className=\"p-3 px-4 text-center\">Recipients</th>\n              <th className=\"p-3 px-4 text-left\">Status</th>\n              <th className=\"p-3 px-4 text-right\">Actions</th>\n            </tr>\n          </thead>\n          <tbody>\n            {history.length === 0 ? (\n              <tr>\n                <td colSpan={6} className=\"text-center p-8 text-gray-500\">\n                  {historySearchQuery\n                    ? `No messages found matching \"${historySearchQuery}\".`\n                    : 'No messages logged yet.'}\n                </td>\n              </tr>\n            ) : (\n              history.map((message) => {\n                const mFilters = message.filters as Record<string, unknown>;\n                const mType = mFilters?.type as string | undefined;\n                const isAutomated = mType?.startsWith('Automated') || mType === 'Attendance Report';\n\n                const eventId = mFilters?.eventId as string | undefined;\n                const linkedEvent = events.find(e => e.id === eventId) || null;\n                const resolvedSubject = resolvePreviewContent(\n                  message.subject || 'SMS message',\n                  linkedEvent,\n                  null,\n                  commSettings.mailingAddress\n                );\n\n                return (\n                  <tr key={message.id} className=\"border-b border-gray-200 text-sm\">\n                    <td className=\"p-3 px-4 whitespace-nowrap\">\n                      {new Date(message.created).toLocaleString()}\n                    </td>\n                    <td className=\"p-3 px-4\">\n                      <div className=\"flex flex-col gap-1\">\n                        <span className=\"inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider bg-primary-light text-primary-deep w-fit\">\n                          {message.type}\n                        </span>\n                        {isAutomated && (\n                          <span className=\"inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wider bg-performance-bg text-performance-text opacity-80 w-fit\">\n                            {mType}\n                          </span>\n                        )}\n                      </div>\n                    </td>\n                    <td className=\"p-3 px-4 font-semibold max-w-[300px] truncate\">\n                      {resolvedSubject}\n                    </td>\n                    <td className=\"p-3 px-4 text-center\">\n                      <button\n                        type=\"button\"\n                        className=\"btn btn-ghost p-0 border-0 bg-transparent min-h-0 h-auto text-xs text-primary underline cursor-pointer\"\n                        onClick={() =>\n                          onViewRecipients(\n                            message.recipients,\n                            `Recipients — ${resolvedSubject}`\n                          )\n                        }\n                      >\n                        {message.recipients.length} recipient{message.recipients.length !== 1 ? 's' : ''}\n                      </button>\n                    </td>\n                    <td className=\"p-3 px-4\">\n                      {message.status === 'Archived' ? (\n                        <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-slate-400 text-white\">\n                          Archived\n                        </span>\n                      ) : (\n                        <span className=\"inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-success-bg text-success-text\">\n                          Sent\n                        </span>\n                      )}\n                    </td>\n                    <td className=\"p-3 px-4 text-right whitespace-nowrap\">\n                      <div className=\"flex gap-2 justify-end\">\n                        <button type=\"button\" className=\"btn btn-ghost btn-sm\" onClick={() => onViewDetails(message)}>\n                          Details\n                        </button>\n                        <button type=\"button\" className=\"btn btn-secondary btn-sm\" onClick={() => onCopyDraft(message)}>\n                          Copy to Draft\n                        </button>\n                      </div>\n                    </td>\n                  </tr>\n                );\n              })\n            )}\n          </tbody>\n        </table>\n      </div>\n\n      <Pagination\n        currentPage={currentPage}\n        totalPages={totalPages}\n        onPageChange={onPageChange}\n      />\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/admin/MusicImportModal.tsx","messages":[{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":211,"column":59,"messageId":"issue:unknown-classname","endLine":211,"endColumn":62,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[6363,6376],"text":"btn-ghost"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-ghost' is not a Tailwind CSS class","line":211,"column":63,"messageId":"issue:unknown-classname","endLine":211,"endColumn":72,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-ghost"},"fix":{"range":[6363,6376],"text":"btn"},"desc":"Remove unknown classname 'btn-ghost'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":217,"column":54,"messageId":"issue:unknown-classname","endLine":217,"endColumn":57,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[6520,6541],"text":"btn-ghost mr-auto"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn-ghost' is not a Tailwind CSS class","line":217,"column":58,"messageId":"issue:unknown-classname","endLine":217,"endColumn":67,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn-ghost"},"fix":{"range":[6520,6541],"text":"btn mr-auto"},"desc":"Remove unknown classname 'btn-ghost'"}]},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":218,"column":66,"messageId":"issue:unknown-classname","endLine":218,"endColumn":69,"suggestions":[{"messageId":"fix:unknown-classname:re