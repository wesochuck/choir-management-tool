d":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":160,"column":200,"messageId":"fix:sort","endLine":160,"endColumn":213},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'btn' is not a Tailwind CSS class","line":172,"column":31,"messageId":"issue:unknown-classname","endLine":172,"endColumn":34,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"btn"},"fix":{"range":[6983,7066],"text":"`flex-1 h-16 font-extrabold text-lg justify-center rounded-xl transition-all ${"},"desc":"Remove unknown classname 'btn'"}]},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":35,"messageId":"fix:sort","endLine":172,"endColumn":41,"fix":{"range":[6983,7066],"text":"`btn h-16 flex-1 justify-center rounded-xl text-lg font-extrabold transition-all ${"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":42,"messageId":"fix:sort","endLine":172,"endColumn":46},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":47,"messageId":"fix:sort","endLine":172,"endColumn":61},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":62,"messageId":"fix:sort","endLine":172,"endColumn":69},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":70,"messageId":"fix:sort","endLine":172,"endColumn":84},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":85,"messageId":"fix:sort","endLine":172,"endColumn":95},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":142,"messageId":"fix:sort","endLine":172,"endColumn":175,"fix":{"range":[7095,7165],"text":"border border-border bg-[var(--primary-light,#f1f5f9)] text-text-muted"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":176,"messageId":"fix:sort","endLine":172,"endColumn":191},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":192,"messageId":"fix:sort","endLine":172,"endColumn":198},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":172,"column":199,"messageId":"fix:sort","endLine":172,"endColumn":212},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":185,"column":31,"messageId":"fix:sort","endLine":185,"endColumn":42,"fix":{"range":[7626,7714],"text":"rounded border border-green-200 bg-green-50 p-2 text-center font-semibold text-green-800"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":185,"column":43,"messageId":"fix:sort","endLine":185,"endColumn":46},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":185,"column":47,"messageId":"fix:sort","endLine":185,"endColumn":58},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":185,"column":59,"messageId":"fix:sort","endLine":185,"endColumn":66},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":185,"column":67,"messageId":"fix:sort","endLine":185,"endColumn":73},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":185,"column":74,"messageId":"fix:sort","endLine":185,"endColumn":90},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":185,"column":91,"messageId":"fix:sort","endLine":185,"endColumn":105},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":185,"column":106,"messageId":"fix:sort","endLine":185,"endColumn":119}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":110,"fixableErrorCount":0,"fixableWarningCount":26,"source":"import { useEffect, useState } from 'react';\nimport { useSearchParams } from 'react-router-dom';\nimport { AppCard } from '../components/common/AppCard';\nimport { useDocumentTitle } from '../hooks/useDocumentTitle';\nimport { pollService, type PollDetails } from '../services/pollService';\nimport { formatInTimezone } from '../lib/timezone';\nimport { pb } from '../lib/pocketbase';\nimport { useDialog } from '../contexts/DialogContext';\n\nexport default function PublicPollView() {\n  const dialog = useDialog();\n  const [searchParams] = useSearchParams();\n  const token = searchParams.get('token') || '';\n\n  const [status, setStatus] = useState<'loading' | 'success' | 'error'>('loading');\n  const [errorMessage, setErrorMessage] = useState('');\n  \n  const [pollData, setPollData] = useState<PollDetails | null>(null);\n  const [selectedResponse, setSelectedResponse] = useState<'Yes' | 'No' | ''>('');\n  const [isUpdating, setIsUpdating] = useState(false);\n  const [timezone, setTimezone] = useState('America/New_York');\n\n  useDocumentTitle(pollData?.poll.question ? `Poll: ${pollData.poll.question}` : 'Engagement Poll');\n\n  useEffect(() => {\n    if (!token) {\n      setStatus('error');\n      setErrorMessage('Invalid poll link. Missing secure verification token.');\n      return;\n    }\n\n    const loadDetails = async () => {\n      try {\n        const res = await pollService.getPollDetails(token);\n        \n        let tz = 'America/New_York';\n        try {\n          const setting = await pb.collection('appSettings').getFirstListItem<{ value: { timezone?: string } }>('key = \"timezone\"');\n          if (setting?.value?.timezone) tz = setting.value.timezone;\n        } catch {\n          // ignore error and fallback to default timezone\n          void 0;\n        }\n\n        setPollData(res);\n        setSelectedResponse(res.currentStatus);\n        setTimezone(tz);\n        setStatus('success');\n      } catch (err: unknown) {\n        setStatus('error');\n        const errObj = err as { data?: { error?: string } } | null;\n        setErrorMessage(\n          errObj?.data?.error || \n          'Failed to load poll details. The link may have expired or is invalid.'\n        );\n      }\n    };\n\n    void loadDetails();\n  }, [token]);\n\n  const handleSubmitResponse = async (val: 'Yes' | 'No') => {\n    if (!token || isUpdating) return;\n\n    setIsUpdating(true);\n    try {\n      await pollService.submitResponse(token, val);\n      setSelectedResponse(val);\n    } catch (err: unknown) {\n      const errObj = err as { data?: { error?: string } } | null;\n      await dialog.showMessage({\n        title: 'Could not record response',\n        message: errObj?.data?.error || 'Failed to record response. Please try again.',\n        variant: 'danger',\n      });\n    } finally {\n      setIsUpdating(false);\n    }\n  };\n\n  if (status === 'loading') {\n    return (\n      <div className=\"flex flex-col min-h-screen w-screen bg-primary-light items-center justify-center\">\n        <div className=\"flex flex-col items-center gap-4\">\n          <div className=\"text-4xl animate-spin\">🔄</div>\n          <h2 className=\"text-primary-deep font-extrabold m-0\">Loading Poll Details...</h2>\n        </div>\n      </div>\n    );\n  }\n\n  if (status === 'error' || !pollData) {\n    return (\n      <div className=\"flex flex-col min-h-screen w-screen bg-[#fef2f2] items-center justify-center\">\n        <AppCard className=\"w-full max-w-[min(440px,calc(100vw-32px))] p-6 text-center border border-red-100\">\n          <div className=\"flex flex-col gap-4 items-center\">\n            <div className=\"text-5xl\">⚠️</div>\n            <h2 className=\"m-0 text-red-800 font-extrabold\">Poll Request Failed</h2>\n            <p className=\"text-text-muted leading-relaxed mt-1 m-0\">\n              {errorMessage}\n            </p>\n            <div className=\"mt-4 w-full flex flex-col gap-2\">\n              <a\n                href=\"/login\"\n                className=\"btn btn-primary inline-flex w-full justify-center items-center no-underline h-11 font-bold\"\n              >\n                Sign In to Member Portal\n              </a>\n            </div>\n          </div>\n        </AppCard>\n      </div>\n    );\n  }\n\n  const { poll } = pollData;\n  const hasResponded = selectedResponse !== '';\n\n  return (\n    <div className=\"flex flex-col min-h-screen w-screen bg-primary-light items-center justify-start px-4 sm:px-6 py-6 lg:py-8\">\n      <div className=\"m-auto w-full max-w-[540px]\">\n        <AppCard className=\"w-full p-6 flex flex-col gap-6 border box-border\">\n          \n          <div className=\"flex flex-col gap-6\">\n            <div className=\"flex flex-col items-center text-center gap-1 pb-4 border-b border-border\">\n              <div className=\"text-5xl mb-2\">📊</div>\n              <h1 className=\"text-2xl font-extrabold m-0 text-primary-deep\">\n                Engagement Poll\n              </h1>\n              <p className=\"m-0 text-sm text-text-muted\">\n                Quick question for our choir members.\n              </p>\n            </div>\n\n            <div className=\"flex flex-col gap-4 p-4 bg-[var(--neutral-bg,#f8fafc)] rounded-lg border border-border\">\n              <h2 className=\"m-0 text-lg font-bold text-center text-text-muted\">\n                {poll.question}\n              </h2>\n\n              {poll.event && (\n                <div className=\"border-t border-border pt-2 mt-2 text-center\">\n                  <span className=\"text-xs text-text-muted uppercase font-bold\">Related Event</span>\n                  <div className=\"font-semibold\">{poll.event.title}</div>\n                  <div className=\"text-xs text-text-muted\">\n                    {formatInTimezone(poll.event.date, timezone, { weekday: 'long', month: 'long', day: 'numeric' })}\n                  </div>\n                </div>\n              )}\n            </div>\n\n            <div className=\"flex flex-col gap-3\">\n              <p className=\"text-sm text-text-muted text-center font-semibold m-0\">\n                {hasResponded ? 'Your current response:' : 'Can you help or volunteer?'}\n              </p>\n              \n              <div className=\"flex gap-2 w-full\">\n                <button\n                  onClick={() => handleSubmitResponse('Yes')}\n                  disabled={isUpdating}\n                  className={`btn flex-1 h-16 font-extrabold text-lg justify-center rounded-xl transition-all ${selectedResponse !== 'Yes' ? 'bg-[var(--primary-light,#f1f5f9)] text-text-muted border border-border' : ''}`}\n                  style={selectedResponse === 'Yes' ? {\n                    backgroundColor: 'var(--primary)',\n                    color: 'white',\n                    border: '2px solid var(--primary-deep)',\n                  } : undefined}\n                >\n                  {isUpdating && selectedResponse === 'Yes' ? '...' : 'Yes / Volunteer'}\n                </button>\n                <button\n                  onClick={() => handleSubmitResponse('No')}\n                  disabled={isUpdating}\n                  className={`btn flex-1 h-16 font-extrabold text-lg justify-center rounded-xl transition-all ${selectedResponse !== 'No' ? 'bg-[var(--primary-light,#f1f5f9)] text-text-muted border border-border' : ''}`}\n                  style={selectedResponse === 'No' ? {\n                    backgroundColor: '#ef4444',\n                    color: 'white',\n                    border: '2px solid #991b1b',\n                  } : undefined}\n                >\n                  {isUpdating && selectedResponse === 'No' ? '...' : 'No / Cannot'}\n                </button>\n              </div>\n            </div>\n\n            {hasResponded && (\n              <div className=\"text-center p-2 bg-green-50 rounded border border-green-200 text-green-800 font-semibold\">\n                ✓ Your response has been recorded. Thank you!\n              </div>\n            )}\n\n            <div className=\"border-t border-border pt-4 text-center\">\n              <a href=\"/login\" className=\"text-xs text-text-muted underline\">\n                Go to Member Portal\n              </a>\n            </div>\n          </div>\n\n        </AppCard>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/views/PublicRsvpView.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":196,"column":23,"messageId":"fix:sort","endLine":196,"endColumn":27,"fix":{"range":[5949,6025],"text":"bg-neutral-bg flex flex-col gap-2 rounded-xl border border-border p-4 sm:p-5"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":196,"column":28,"messageId":"fix:sort","endLine":196,"endColumn":36},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":196,"column":37,"messageId":"fix:sort","endLine":196,"endColumn":42},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":196,"column":43,"messageId":"fix:sort","endLine":196,"endColumn":56},{"ruleId":"tailwindcss/no-custom-classname","severity":1,"message":"Classname 'bg-neutral-bg' is not a Tailwind CSS class","line":196,"column":43,"messageId":"issue:unknown-classname","endLine":196,"endColumn":56,"suggestions":[{"messageId":"fix:unknown-classname:remove","data":{"classname":"