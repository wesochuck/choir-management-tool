-all duration-200 no-underline whitespace-nowrap\" title=\"Dashboard\">🏠 Home</Link>\n            <div className=\"flex flex-col\">\n              <h2 className=\"text-xl font-bold text-text\">{title}</h2>\n              {subtitle && <p className=\"text-[0.8125rem] text-text-muted\">{subtitle}</p>}\n            </div>\n          </div>\n          {(actions || user?.role === 'admin') && (\n            <div className=\"flex items-center gap-4\">\n              {actions}\n              {user?.role === 'admin' && (\n                <>\n                  <Link to=\"/profile\" className=\"inline-flex items-center justify-center rounded-md text-sm font-medium bg-transparent text-text-muted border border-border hover:bg-primary-light hover:text-primary-deep px-3 py-1.5\">My Profile</Link>\n                  <button onClick={handleLogout} className=\"inline-flex items-center justify-center rounded-md text-sm font-medium bg-transparent text-text-muted border border-border hover:bg-primary-light hover:text-primary-deep px-3 py-1.5 cursor-pointer\">Logout</button>\n                </>\n              )}\n            </div>\n          )}\n        </div>\n      </header>\n\n      {/* @allow-inline-style - maxWidth varies per page layout variant */}\n      <main className=\"w-full mx-auto px-6 py-8\" style={{ maxWidth }}>\n        {children}\n      </main>\n    </div>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"/Users/wesosborn/Downloads/choir-management-tool/src/components/common/Pagination.tsx","messages":[{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":48,"column":18,"messageId":"fix:sort","endLine":48,"endColumn":26,"fix":{"range":[1749,1830],"text":"m-4 mx-auto flex flex-row flex-wrap items-center justify-center gap-1 select-none"}},{"ruleId":"tailwindcss/classnames-order","severity":1,"message":"Invalid Tailwind CSS classnames order","line":48,"column":18,"messageId":"fix:sort","endLine":48,"endColumn":22}